# ===== 服务器配置（apps/server）=====
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== 数据库 =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qmwx_dev
REDIS_URL=redis://localhost:6379

# ===== JWT =====
# ⚠️  生产环境必须用 `openssl rand -hex 32` 生成 32+ 字符随机串
# 占位仅用于本地 dev，部署到 staging/prod 前必须替换
JWT_SECRET=change-me-32-chars-min-please-only-for-local-dev
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d

# ===== 微信小程序 =====
# ⚠️  生产环境必须填写真实值（mp.weixin.qq.com 开发者后台）
# 不要再使用 wx426885831a05f18e 等历史默认；如未填写请明确置空触发 env.ts Zod 报错
WX_APPID=your-wx-appid
WX_SECRET=your-wx-app-secret
WX_MCH_ID=your-merchant-id
WX_PAY_KEY=your-pay-key
WX_NOTIFY_URL=https://api.example.com/api/wallet/pay-callback
# 退款回调（Phase 4.1 微信退款闭环）；未开通支付前可保持 example.com
WX_REFUND_NOTIFY_URL=https://api.example.com/api/wxpay/refund-callback

# ===== 本地开发 =====
# 登录旁路：=1 时跳过微信 code2Session，用固定 dev 用户登录（无需真实 AppSecret）。
# 仅 NODE_ENV!=production 生效；正式环境务必删除或置空。
DEV_LOGIN_BYPASS=0

# ===== 功能开关（对应 app_config.feature_flags）=====
FEATURE_WALLET=false
FEATURE_PAYMENT=false
FEATURE_MEMBERSHIP_PURCHASE=false
FEATURE_SMART_AGENT=false
FEATURE_BIND_APP=false