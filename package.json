{
  "name": "qm-wx",
  "version": "0.1.0",
  "private": true,
  "description": "青沐生命科技微信小程序 + Node 后端 monorepo",
  "author": "湖南青沐生命科技有限公司 (Hunan Qingmu Life Technology Co., Ltd.)",
  "license": "MIT",
  "copyright": "© 2026 湖南青沐生命科技有限公司",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:server": "pnpm --filter @qm-wx/server dev",
    "dev:miniprogram": "pnpm --filter @qm-wx/miniprogram dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --filter @qm-wx/shared --filter @qm-wx/server typecheck",
    "build:mp-shared": "node scripts/build-mp-shared.mjs",
    "prisma:generate": "pnpm --filter @qm-wx/server prisma:generate",
    "prisma:migrate": "pnpm --filter @qm-wx/server prisma:migrate",
    "prisma:studio": "pnpm --filter @qm-wx/server prisma:studio",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo coverage",
    "wx:status": "./bin/wx status",
    "wx:open": "./bin/wx open",
    "wx:login": "./bin/wx login",
    "wx:islogin": "./bin/wx islogin",
    "wx:auto": "./bin/wx auto",
    "wx:preview": "./bin/wx preview",
    "wx:auto-preview": "./bin/wx auto-preview",
    "wx:upload": "./bin/wx upload",
    "wx:build-npm": "./bin/wx build-npm",
    "wx:close": "./bin/wx close",
    "wx:quit": "./bin/wx quit"
  },
  "bin": {
    "wx": "./bin/wx"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "commander": "^15.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "miniprogram-automator": "^0.12.1",
    "prettier": "^3.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
