{
  "name": "@qm-wx/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "湖南青沐生命科技有限公司",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./constants/*": {
      "types": "./src/constants/*.ts",
      "default": "./dist/constants/*.js"
    },
    "./api-contracts": {
      "types": "./src/api-contracts/endpoints.ts",
      "default": "./dist/api-contracts/endpoints.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "rm -f tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/spy": "^3.2.6",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
