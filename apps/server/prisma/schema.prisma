// QM-WX PostgreSQL schema
// 详细字段移植自 reviews/running-group-stats/02-architecture.md §4

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 用户 =====
model User {
  id             String    @id @default(cuid())
  openid         String    @unique
  unionid        String?   @unique
  nickname       String?
  avatarUrl      String?
  phone          String?   @unique // V0.1.129 手机号登录（生产 0 重复安全）
  email          String?   @unique // V0.1.129 邮箱密码登录
  passwordHash   String? // V0.1.129 bcrypt hash（邮箱/admin 密码登录）
  username       String?   @unique // V0.1.129 admin Web 账号登录
  memberLevel    String    @default("free") // free | monthly | quarterly | yearly
  memberExpireAt DateTime?
  points         Int       @default(0)
  totalPointsEarned Int      @default(0) // V0.2.7 累计积分（只增，成长等级判定；points 余额可被兑换消耗）
  invitedBonusDays  Int      @default(0) // V0.2.7 邀请奖励累计天数（封顶校验用，仅邀请场景累加）
  certified      Boolean   @default(false)
  customMilestones Json? @default("[]") // V0.1.135 自定义里程碑 [{km, title, icon?}, ...]
  // V0.1.40 个人资料扩展（profile 完整实现）
  gender         String? // male | female | unknown
  birthday       String? // YYYY-MM-DD
  region         String? // 如"北京"
  height         Int? // cm
  weight         Float? // kg
  stats          Json      @default("{\"totalDistance\":0,\"totalCheckins\":0,\"totalPoints\":0}")
  // V0.1.18：黑名单字段（admin banUser/unbanUser 维护）
  isBanned       Boolean   @default(false)
  bannedAt       DateTime?
  bannedReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  checkins               Checkin[]
  orders                 Order[]
  reviews                Review[] // V0.1.113 评价
  wallet                 Wallet?
  groupMembers           GroupMember[]
  ownedGroups            Group[]                 @relation("GroupOwner")
  deviceBindings         DeviceBinding[]
  meals                  Meal[]
  idMapping              IdMapping?
  // 佳明数据导入（B-2）：Activity 复用 RawActivity（无 relation），其余 3 表反向
  garminSleeps           GarminSleep[]
  garminFitnessAges      GarminFitnessAge[]
  garminMetrics          GarminMetric[]
  // 购物车 + 签到（V0.1.22 B-核心）
  carts                  Cart[]
  signinRecords          SigninRecord[]
  addresses              Address[]
  coupons                Coupon[]
  shoes                  Shoe[] // V0.1.26 跑鞋
  goals                  Goal[] // V0.1.28 跑步目标
  favorites              Favorite[] // V0.1.29 收藏
  feeds                  Feed[] // V0.1.30 动态
  feedLikes              FeedLike[] // V0.1.30 点赞
  feedComments           FeedComment[] // V0.1.30 评论
  notifications          Notification[] // V0.1.31 收到的通知（接收者视角）
  uploads                UploadRecord[]          @relation("UserUploads") // V0.1.150 上传记录（COS 中转异步解析）
  notifActions           Notification[]          @relation("NotifActor") // V0.1.31 触发的通知（actor 视角）
  following              Follow[]                @relation("Follower") // V0.1.32 我关注的人（follower 视角）
  followers              Follow[]                @relation("Followee") // V0.1.32 关注我的人（followee 视角）
  familiesOwned          Family[]                @relation("FamilyOwner") // V0.1.34 创建的家庭（owner 视角）
  familyMember           FamilyMember? // V0.1.34 我的家庭关系（1:1，一人一家庭）
  trainingEnrollment     UserPlanEnrollment? // V0.1.41 当前训练计划（1:1，一人一活跃计划）
  weRunRecords           WeRunRecord[] // V0.1.43 微信运动步数（每日）
  heartRateRecords       HeartRateRecord[] // V0.1.43 心率历史（BLE 0x180D + 微信运动）
  spo2Records            SpO2Record[] // V0.1.43 血氧历史（BLE 0x1822）
  sleepRecords           SleepRecord[] // V0.1.43 睡眠历史（小米数据包导入）
  bodyCompositionRecords BodyCompositionRecord[] // V0.1.124 体脂秤数据（BLE 小米体脂秤）
  interpretRecords       InterpretRecord[] // V0.2.33 资料解读（minimax M3）
  corosRawEvents         CorosRawEvent[] // V0.1.130 COROS Terra webhook 原始数据
  conversationTurns      ConversationTurn[] // V0.1.139 AI 私教对话（多轮记忆）
  dailyReports           DailyReport[] // V0.1.144 每日 AI 健康简报（健康分数+AI 解读）
  withdrawalRequests     WithdrawalRequest[] // V0.1.105 提现申请（pending/approved/rejected）
  groupBuyMembers        GroupBuyMember[] // V0.1.37 团购参与记录
  // 分销（V0.1.24）
  inviteCode             String?                 @unique
  distributorLevel       String                  @default("V0") // V0 | V1 | V2 | V3
  onboardingDone         Boolean                 @default(false) // V0.1.43 新用户激活向导完成标记
  aiCoachPersona         String? // V0.1.140 AI 私教人设（scientist|coach|buddy|strict，默认 buddy）
  distributionOrders     DistributionOrder[]
  teamInvites            Team[]                  @relation("TeamInviter")
  teamInvitees           Team[]                  @relation("TeamInvitee")
  commissionLogs         CommissionLog[]

  @@index([openid])
  @@index([isBanned])
}

// ===== 打卡 =====
model Checkin {
  id               String   @id @default(cuid())
  userId           String
  groupId          String?
  distance         Float // km
  durationSec      Int?
  pace             String? // mm:ss
  heartRate        Int?
  cadence          Int?
  points           Int      @default(0)
  date             String // YYYY-MM-DD
  dataSource       String   @default("manual") // manual | garmin
  garminActivityId String?  @unique // 佳明去重键（null = 手动打卡）
  sportType        String? // run | hike | ride | other
  shoeId           String? // 关联跑鞋（打卡时选 → 跑鞋自动累计里程，V0.1.26）
  // V0.2.0 天气快照 + 地点（打卡时采和风，关联分析用）
  weatherTemp      Float? // 气温 °C
  humidity         Float? // 湿度 %
  aqi              Int? // 空气质量指数（PM2.5 换算或和风 air）
  lat              Float? // 打卡纬度（授权定位）
  lon              Float? // 打卡经度
  createdAt        DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])
  shoe  Shoe?  @relation(fields: [shoeId], references: [id])

  @@index([userId, date])
  @@index([groupId, date])
  @@index([userId, sportType, date])
}

// ===== 跑群 =====
model Group {
  id          String   @id @default(cuid())
  opengid     String?  @unique
  name        String
  ownerId     String
  memberCount Int      @default(0)
  announce    String? // V0.1.42 群公告（owner 发，可选）
  createdAt   DateTime @default(now())

  owner    User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members  GroupMember[]
  checkins Checkin[]
}

model GroupMember {
  groupId   String
  userId    String
  nickname  String
  avatarUrl String?
  role      String   @default("member") // owner | member
  joinedAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@index([userId])
}

// ===== 商城 =====
model Product {
  id             String   @id @default(cuid())
  name           String
  category       String
  brand          String?
  price          Decimal  @db.Decimal(10, 2)
  originalPrice  Decimal? @db.Decimal(10, 2)
  memberDiscount Float?
  images         String[]
  description    String?
  stock          Int      @default(0)
  status         String   @default("on") // on | off
  sort           Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[]
  carts      Cart[]
  groupBuys  GroupBuy[] // V0.1.37 团购
  reviews    Review[] // V0.1.113 评价

  @@index([category, status])
}

// ===== 团购（V0.1.37，2764 电商团购 — 简化 MVP）=====
// admin 创建团购活动（团购价 + 目标人数）；用户参与（join）达目标 → reached + notify 参与者
// MVP：参与 = 记录意向（无支付/退款）；达目标后通知引导下单（复用 mall）
model GroupBuy {
  id           String    @id @default(cuid())
  productId    String
  groupPrice   Decimal   @db.Decimal(10, 2) // 团购价（低于商品原价）
  targetCount  Int // 成团目标人数
  currentCount Int       @default(0) // 当前参与人数
  status       String    @default("active") // active | reached
  endDate      DateTime? // 团购截止（MVP 不强制，仅展示）
  createdAt    DateTime  @default(now())

  product Product          @relation(fields: [productId], references: [id])
  members GroupBuyMember[]
  orders  Order[] // V0.1.37 团购订单

  @@index([status])
}

model GroupBuyMember {
  id         String   @id @default(cuid())
  groupBuyId String
  userId     String
  joinedAt   DateTime @default(now())

  groupBuy GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupBuyId, userId]) // 防同一团购重复参与
  @@index([userId])
}

// ===== 购物车（V0.1.22 B-核心，跨设备持久化）=====
model Cart {
  id        String   @id @default(cuid())
  userId    String
  productId String
  qty       Int      @default(1)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // 同商品合并 qty
  @@index([userId])
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  items             OrderItem[]
  totalAmount       Decimal     @db.Decimal(10, 2)
  pointsUsed        Int         @default(0)
  payAmount         Decimal     @db.Decimal(10, 2)
  status            String      @default("pending_pay") // pending_pay | paid | shipped | done | cancelled
  payment           Json?
  address           Json?
  // Phase 4 微信支付 V3 新增
  payChannel        String? // wxpay | points（默认 null）
  prepayId          String?
  wxTransactionId   String?     @unique // 幂等 key
  paidAt            DateTime?
  // V0.1.24 分销：推广来源分销人（带 inviteCode 下单时落）
  sourceUserId      String?
  // V0.1.37 团购订单关联（null=普通订单；有值=团购价订单）
  groupBuyId        String?
  // V0.1.118 赛事报名支付（null=商品订单；'enroll'=赛事报名）
  contentType       String?
  contentId         String?
  // V0.1.107 GAP-6 自提核销（订单号末 6 位 + 3 位大写字母数字作 pickupCode）
  pickupCode        String?     @unique
  pickupExpiresAt   DateTime? // 默认 30 天过期
  pickupConfirmedAt DateTime? // 核销时间
  pickupConfirmedBy String? // 核销人（admin openid）
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  groupBuy          GroupBuy?          @relation(fields: [groupBuyId], references: [id], onDelete: SetNull)
  distributionOrder DistributionOrder?
  reviews           Review[] // V0.1.113 评价

  @@index([userId, createdAt])
  @@index([sourceUserId])
  @@index([groupBuyId]) // V0.1.37 团购订单查询
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Decimal @db.Decimal(10, 2)
  qty       Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ===== 评价（V0.1.113 电商闭环最后一块）=====
// 用户对已购商品评价（rating 1-5 + content + images）；create 校验订单已购 + 商品在订单内 + @@unique 防重
model Review {
  id           String    @id @default(cuid())
  userId       String
  productId    String
  orderId      String // 评价来源订单（校验已购 + 防重）
  rating       Int // 1-5 星
  content      String?
  images       String[]
  createdAt    DateTime  @default(now())
  replyContent String? // V0.1.116 admin/商家回复
  repliedAt    DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId]) // 防重：同一订单同一商品只评一次
  @@index([productId, createdAt]) // 商品评价列表
  @@index([userId, createdAt]) // 我的评价
}

// ===== 积分流水 =====
model PointsRecord {
  id        String   @id @default(cuid())
  userId    String
  change    Int
  type      String // checkin | signup_bonus | order_deduct | member_gift
  refId     String?
  balance   Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ===== 签到记录（V0.1.22 B-核心，连续签到）=====
model SigninRecord {
  id             String   @id @default(cuid())
  userId         String
  date           String // YYYY-MM-DD（东八区）
  continuousDays Int      @default(1)
  pointsAwarded  Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date]) // 防同日重复签
  @@index([userId])
}

// ===== 跑鞋（V0.1.26，跑者向 — 里程管理 + 更换提醒）=====
// 打卡时关联跑鞋 → currentKm 自动累计 → 达 thresholdKm 提醒更换（防受伤）
model Shoe {
  id          String    @id @default(cuid())
  userId      String
  brand       String // 品牌（Nike / 必迈 / 路征 ...）
  model       String // 型号（如 Vaporfly Next%）
  nickname    String? // 用户起的名（如"战靴一号"）
  currentKm   Float     @default(0) // 当前累计里程（km，打卡自动累计）
  thresholdKm Float     @default(800) // 更换阈值（默认 800km，防受伤）
  status      String    @default("active") // active | retired
  purchasedAt DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  checkins Checkin[] // 关联打卡（里程来源）
  feeds    Feed[] // V0.1.136 关联动态

  @@index([userId, status])
}

// ===== 家庭空间（V0.1.34，pic 2776 家庭方向）=====
// 一家一组，owner 创建 + 邀请家人加入；FamilyMember.userId @@unique 强制一人一家庭
model Family {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  inviteCode String   @unique // 邀请码（家人 joinFamily 输入）
  createdAt  DateTime @default(now())

  owner   User           @relation("FamilyOwner", fields: [ownerId], references: [id])
  members FamilyMember[]
  goals   Goal[]

  @@index([ownerId])
}

model FamilyMember {
  id       String   @id @default(cuid())
  familyId String
  userId   String   @unique // 一人一家庭（@@unique 强制）
  role     String   @default("member") // owner | member
  joinedAt DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

// ===== 跑步目标（V0.1.28，跑者向 — 月度/年度/自定义 + 进度跟踪）=====
// 进度由 Checkin aggregate 动态算（periodStart-End 范围内 distance 之和）
model Goal {
  id             String   @id @default(cuid())
  userId         String
  type           String // monthly | yearly | custom
  title          String? // 自定义标题（optional）
  targetDistance Float // 目标距离 km
  periodStart    DateTime // 周期开始（东八区 0 点）
  periodEnd      DateTime // 周期结束（exclusive）
  familyId       String? // V0.1.34 家庭目标（null=个人；有值=家庭目标，进度按家庭成员算）
  status         String   @default("active") // active | archived
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([familyId]) // V0.1.34 家庭目标查询
}

// ===== 收藏（V0.1.29，社交向 — Content/Product 收藏）=====
// targetType: content | product；unique 防重复收藏
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  targetType String // content | product
  targetId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

// ===== 关注关系（V0.1.32，社交向深化 — 关注/粉丝）=====
// followerId 关注 followeeId；unique 防重；onDelete Cascade（任一用户删除→关系级联）
model Follow {
  id         String   @id @default(cuid())
  followerId String // 关注者
  followeeId String // 被关注者
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId]) // 防重复关注
  @@index([followeeId]) // 查粉丝列表
  @@index([followerId]) // 查关注列表
}

// ===== 通知（V0.1.31，社交向 — 点赞/评论/系统消息提醒）=====
// feed.like / feed.comment 触发时落库；自己触发自己不发（userId === actorId）
model Notification {
  id         String   @id @default(cuid())
  userId     String // 接收者（看到通知的人）
  actorId    String // 触发者（点赞/评论的人）
  type       String // like | comment | follow | system
  targetType String? // feed | goal | ...（点击跳转用）
  targetId   String? // 对应实体 id（feedId 等）
  content    String? // 通知文案/评论摘要
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("NotifActor", fields: [actorId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

// ===== 动态（V0.1.30，社交向 — 运动动态发布/点赞/评论）=====
model Feed {
  id           String   @id @default(cuid())
  userId       String
  content      String // 文字内容（最长 500）
  images       String[] // 图片 URL 列表（最多 9）
  checkinId    String? // 关联打卡（可选，运动动态）
  distanceKm   Float? // 冗余跑量（避免 join，展示用）
  topic        String? // V0.1.36 话题（如 "马拉松"；null=无话题）
  videoUrl     String? // V0.1.36 外部视频链接（mp4 URL，<video> 播放）
  shoeId       String? // V0.1.136 关联跑鞋（可选，动态卡显示跑鞋信息）
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  shoe     Shoe?         @relation(fields: [shoeId], references: [id], onDelete: SetNull)
  likes    FeedLike[]
  comments FeedComment[]

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([topic]) // V0.1.36 话题聚合查询
  @@index([shoeId])
}

// 动态点赞（unique 防重复）
model FeedLike {
  id        String   @id @default(cuid())
  feedId    String
  userId    String
  createdAt DateTime @default(now())

  feed Feed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([feedId, userId])
  @@index([feedId])
}

// 动态评论
model FeedComment {
  id        String   @id @default(cuid())
  feedId    String
  userId    String
  content   String // 评论内容（最长 200）
  createdAt DateTime @default(now())

  feed Feed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([feedId, createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  status    String   @default("active") // active | frozen
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id              String   @id @default(cuid())
  userId          String
  walletId        String
  type            String // recharge | consume | refund
  amount          Decimal  @db.Decimal(10, 2)
  orderId         String?
  wxTransactionId String?
  // 微信退款商户单号（out_refund_no）：与微信请求一致，用于幂等 + 对账匹配。
  // 唯一约束防止同一笔退款重复落库。
  outRefundNo     String?  @unique
  status          String   @default("success") // success | pending | failed
  createdAt       DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([userId, createdAt])
}

// ===== 地址（V0.1.23 个人中心电商版）=====
model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  province  String
  city      String
  district  String
  detail    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ===== 优惠券（V0.1.23，单表实例；模板用 service 常量）=====
model Coupon {
  id         String    @id @default(cuid())
  userId     String
  title      String
  type       String // fixed | percent
  amount     Float // fixed: 减金额 | percent: 折扣（0.9 = 9折）
  minSpend   Float // 满减门槛
  expireAt   DateTime
  status     String    @default("unused") // unused | used | expired
  receivedAt DateTime  @default(now())
  usedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

// ===== 分销（V0.1.24，方案 1 全持久化）=====
// 推广订单：分销人 ↔ 订单关联 + 佣金快照（下单时落 pending，支付回调结算 settled）
model DistributionOrder {
  id               String    @id @default(cuid())
  userId           String // 分销人（拿佣金的）
  orderId          String    @unique // 关联订单（一单一记）
  orderAmount      Decimal   @db.Decimal(10, 2) // 订单实付金额快照
  commissionRate   Decimal   @db.Decimal(4, 3) // 佣金比例快照（0.100=10%）
  commissionAmount Decimal   @db.Decimal(10, 2) // 佣金金额快照
  status           String    @default("pending") // pending | settled | cancelled
  settledAt        DateTime?
  createdAt        DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([userId, createdAt])
}

// 邀请关系（团队树，inviteeId 一人一上线）
model Team {
  id        String   @id @default(cuid())
  inviterId String // 邀请人（上线）
  inviteeId String   @unique // 被邀请人（下线，一人仅一个直接上线）
  level     Int      @default(1) // 1=直推 2=间推（冗余便于查询）
  joinedAt  DateTime @default(now())

  inviter User @relation("TeamInviter", fields: [inviterId], references: [id])
  invitee User @relation("TeamInvitee", fields: [inviteeId], references: [id])

  @@index([inviterId])
}

// 佣金流水（分销专用；正=结算入账，负=退款冲红）
model CommissionLog {
  id           String   @id @default(cuid())
  userId       String // 归属分销人
  orderId      String? // 关联订单（结算/冲红同单）
  amount       Decimal  @db.Decimal(10, 2) // 正=入账 负=扣减
  type         String // settle | clawback | adjust
  balanceAfter Decimal  @db.Decimal(10, 2) // 入账后佣金累计快照
  note         String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ===== 内容（赛事/酒店/景区/餐饮/乡村振兴 统一）=====
model Content {
  id         String   @id @default(cuid())
  type       String // marathon | hotel | scenic | food | rural
  title      String
  cover      String?
  summary    String?
  detail     Json?
  price      Decimal? @db.Decimal(10, 2)
  fee        Decimal? @db.Decimal(10, 2)
  date       String?
  validRange Json?
  location   String?
  tags       String[]
  actionType String   @default("none") // enroll | book | link | none
  status     String   @default("on") // on | off
  sort       Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  enrollments Enrollment[]

  @@index([type, status, sort])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  type      String
  formData  Json
  status    String   @default("submitted") // submitted | confirmed | cancelled
  orderId   String? // V0.1.118 赛事报名支付关联（wxpay 回调查 enrollment confirmed）
  createdAt DateTime @default(now())

  content    Content     @relation(fields: [contentId], references: [id])
  raceResult RaceResult? // V0.1.134 赛事成绩 1:1

  @@index([userId, contentId])
}

// ===== V0.1.134 赛事成绩 =====
// 一人(报名)一成绩，可改（upsert）
model RaceResult {
  id               String   @id @default(cuid())
  enrollmentId     String   @unique // 1:1
  userId           String   // 冗余（避免 join Enrollment 查排行榜）
  contentId        String   // 冗余（避免 join Enrollment 查排行榜）
  finishTimeSec    Int?     // 完赛时间（秒）
  paceSecPerKm     Int?     // 配速（秒/公里），后端算
  rank             Int?     // 排名（DNF/null 不入榜）
  bibNumber        String?  // 号码布
  finisherPhotoUrl String?  // 终点照 URL
  source           String   @default("user_report") // user_report | admin_input
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([contentId, rank])
  @@index([contentId, finishTimeSec])
  @@index([userId])
}

// ===== 远程配置 / 功能开关 =====
model AppConfig {
  id        String   @id // feature_flags | member_levels | points_rules | admin_whitelist ...
  value     Json
  updatedAt DateTime @updatedAt
}

// ===== 审计日志（V0.1.18）=====
// 关键 admin 操作留痕：refundOrder / setConfig / banUser / unbanUser
// 写失败只 log error 不 throw（业务不能被审计拖累）
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actorOpenid String // 操作者 openid
  action      String // e.g. 'admin.refundOrder' | 'admin.banUser' | 'admin.setConfig'
  target      String? // 目标实体 id（如 user openid / order id / config key）
  payload     Json // 操作内容（脱敏后的关键字段）
  ip          String? // 来源 IP（route 层 req.ip 传入）
  createdAt   DateTime @default(now())

  @@index([actorOpenid, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// ===== 周报 =====
model GroupReport {
  id        String   @id @default(cuid())
  groupId   String
  period    String // YYYY-WW
  summary   Json
  imageUrl  String?
  createdAt DateTime @default(now())

  @@unique([groupId, period])
}

// ===== V2 · 设备绑定（一人多厂商）=====
model DeviceBinding {
  id              String    @id @default(cuid())
  userId          String
  vendor          String // werun | garmin | huawei | xiaomi | honor | coros | zepp
  accessTokenEnc  String? // AES 加密
  refreshTokenEnc String?
  expireAt        DateTime?
  vendorUserId    String?
  scopes          String[]
  status          String    @default("active") // active | expired | revoked
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, vendor])
  @@index([status])
}

// ===== V2 · 设备原始活动（留底可追溯）=====
model RawActivity {
  id               String    @id @default(cuid())
  userId           String
  vendor           String
  vendorActivityId String // vendor + vendorActivityId 唯一防重
  type             String // running | walking | cycling
  startTime        DateTime
  durationSec      Int?
  distanceMeters   Float?
  avgHr            Int?
  maxHr            Int?
  cadence          Int?
  raw              Json
  ingestedAt       DateTime  @default(now())
  normalizedAt     DateTime?
  status           String    @default("pending") // pending | imported | ignored
  importedAt       DateTime?
  importCheckinId  String? // 导入后指向 Checkin.id（1-1）

  @@unique([vendor, vendorActivityId])
  @@index([userId, startTime])
  @@index([userId, status])
}

// ===== V0.1.150 · 上传记录（COS 中转 + 异步解析留底，后台可追溯/重跑）=====
model UploadRecord {
  id           String   @id @default(cuid())
  userId       String
  type         String // xiaomi_zip | coros_fit | sport_screenshot（Phase 2/3 扩 garmin_fit|huawei_export|apple_health）
  cosUrl       String // 公开 URL（CDN 或 COS 默认域名）
  objectKey    String // COS key（后台 getObject 下载用）
  mime         String
  size         Int
  status       String   @default("pending") // pending | parsing | parsed | failed
  password     String?  // 小米 ZIP 加密包（仅 xiaomi_zip，上传时一并传）
  parsedResult Json?    // 解析结果摘要（导入条数/距离/时长）
  errorMsg     String?
  createdAt    DateTime @default(now())

  user User @relation("UserUploads", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

// ===== V2 · 菜谱 =====
model Recipe {
  id          String   @id @default(cuid())
  title       String
  coverFileId String?
  category    String // breakfast | prerun | postrun | lowcal | homedish
  tags        String[]
  ingredients Json // [{name, amount, isMain}]
  steps       Json // [{order, text, imageFileId}]
  nutrition   Json? // {calorie, protein, fat, carb, per}
  durationMin Int?
  difficulty  Int?
  servings    Int?
  source      Json // {type, vendor, vendorId, license}
  audit       Json // {status, reviewer, reviewedAt}
  stats       Json     @default("{\"views\":0,\"favorites\":0}")
  fingerprint String?  @unique // 去重指纹
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, updatedAt])
}

// ===== V2 · 营养缓存 =====
model FoodCache {
  id        String   @id @default(cuid())
  keyword   String
  source    String // juhe | tianapi | baidu
  payload   Json
  hitCount  Int      @default(0)
  expiredAt DateTime
  createdAt DateTime @default(now())

  @@unique([keyword, source])
  @@index([expiredAt])
}

// ===== V2 · 饮食日记 =====
model Meal {
  id           String   @id @default(cuid())
  userId       String
  mealType     String // breakfast | lunch | dinner | snack
  items        Json // V0.2.0 宏量升级：[{name, calorie, protein?, fat?, carb?, qty?, foodId?}]
  totalCalorie Int
  date         String // YYYY-MM-DD
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

// ===== V2 · 律动账号映射 =====
model IdMapping {
  id           String   @id @default(cuid())
  userId       String   @unique
  ludongUserId String   @unique
  boundAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ===== V2 · 出站队列（小程序 → 律动）=====
model SyncOutbox {
  id          String    @id @default(cuid())
  eventType   String // user.upsert | checkin.batch | order.sync | points.sync
  path        String // /open/v1/...
  payload     Json
  status      String    @default("pending") // pending | done | dead
  retryCount  Int       @default(0)
  nextRetryAt DateTime  @default(now())
  lastError   String?
  createdAt   DateTime  @default(now())
  doneAt      DateTime?

  @@index([status, nextRetryAt])
}

// ===== V2 · 入站幂等（律动 → 小程序 webhook）=====
model InboundEvent {
  id         String   @id // 律动 eventId
  type       String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

// ===== 佳明（Garmin）数据导入 — 方案 B-2：核心厚表 + Metrics 通用宽表 =====
// 数据来源：佳明账户导出包（userProfileId 11032831 / 张晨）
// 关联现有 User（vendor=garmin）；活动复用 RawActivity，不新建活动表

/// 佳明睡眠（厚表）— 来源 DI-Connect-Wellness/sleepData，按日一条
model GarminSleep {
  id                  String    @id @default(cuid())
  userId              String
  calendarDate        DateTime
  sleepStartGMT       DateTime?
  sleepEndGMT         DateTime?
  deepSleepSeconds    Int?
  lightSleepSeconds   Int?
  remSleepSeconds     Int?
  awakeSleepSeconds   Int?
  unmeasurableSeconds Int?
  averageRespiration  Float?
  lowestRespiration   Float?
  highestRespiration  Float?
  awakeCount          Int?
  avgSleepStress      Float?
  sleepScores         Json? // 嵌套评分（overall/quality/...）
  raw                 Json
  ingestedAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, calendarDate])
  @@index([userId, calendarDate])
}

/// 佳明健身年龄（厚表）— 来源 fitnessAgeData，按日一条
model GarminFitnessAge {
  id                String   @id @default(cuid())
  userId            String
  asOfDate          DateTime
  chronologicalAge  Int?
  bmi               Float?
  rhr               Int? // 静息心率
  vo2Max            Float? // biometricVo2Max
  currentBioAge     Float?
  totalVigorousDays Int?
  raw               Json
  ingestedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, asOfDate])
  @@index([userId, asOfDate])
}

/// 佳明指标（通用宽表）— 来源 DI-Connect-Metrics（8 类）+ Wellness 杂项
/// metricType: training_readiness | hill_score | endurance_score | acute_load |
///             heat_acclimation | heat_acclimation | max_met | run_race_predictions | training_history
model GarminMetric {
  id           String    @id @default(cuid())
  userId       String
  metricType   String
  sport        String? // 按运动细分的指标（training_history/max_met 有；其余 null）
  calendarDate DateTime?
  value        Float?
  level        String? // NONE | LOW | MEDIUM | HIGH（部分类型）
  raw          Json
  ingestedAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, metricType, sport, calendarDate])
  @@index([userId, metricType, calendarDate])
}

// ===== 训练计划（V0.1.41，配置化 — admin CRUD + 用户加入）=====
// TrainingPlan：admin 维护的计划模板（替 V0.1.25 硬编码常量）；key @unique 幂等
// UserPlanEnrollment：用户加入记录，userId @unique 强制 1 人 1 活跃计划（切换=替换）
model TrainingPlan {
  id            String   @id @default(cuid())
  key           String   @unique // '5k' / '10k' / 'half' / 'full' / 自定义（admin CRUD 幂等 + seed 安全复跑）
  name          String
  weeks         Int
  level         String // beginner | intermediate | challenge | extreme（英文 key，wxss 中文 selector 坑）
  goal          String
  desc          String
  weeklyMileage String
  targetKm      Float // 计划总目标跑量（进度计算分母）
  status        String   @default("active") // active | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments UserPlanEnrollment[]

  @@index([status])
}

model UserPlanEnrollment {
  id       String   @id @default(cuid())
  userId   String   @unique // 1 人 1 活跃计划（切换 = delete 旧 + create 新）
  planId   String
  joinedAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

// ===== 微信运动步数（V0.1.43，方案 3 微信运动入库）=====
// syncWeRun 从微信运动拉 stepList → upsert（按 userId+date 防重，同一日取 max step）
model WeRunRecord {
  id        String   @id @default(cuid())
  userId    String
  date      String // YYYY-MM-DD（CN 时区）
  step      Int // 当日步数
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // 同一日只一条（upsert 防重）
  @@index([userId, date])
}

// ===== 心率历史（V0.1.43，BLE 心率 0x180D notify 批量落库）=====
// submitHeartRate 写 Redis（实时 ble:hr:{userId}）+ createMany 落历史
// myHealthHistory 按 type=hr + dateRange 查询；myTodayHealth 取今日 latest
model HeartRateRecord {
  id        String   @id @default(cuid())
  userId    String
  value     Int // 心率 bpm
  timestamp DateTime // 测量时间（前端上报，BLE notify 时间）
  source    String   @default("ble") // ble | werun | manual
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

// ===== 血氧历史（V0.1.43，BLE 血氧 0x1822 / 0x2A5F spot-check）=====
model SpO2Record {
  id        String   @id @default(cuid())
  userId    String
  value     Int // 血氧百分比 0-100
  timestamp DateTime // 测量时间
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

// ===== 睡眠历史（V0.1.43，小米数据包导入）=====
// importXiaomiZip 解析小米睡眠 JSON → upsert by userId+date
// myTodayHealth 可加 latestSleep 展示（阶段 2 扩展）
model SleepRecord {
  id              String    @id @default(cuid())
  userId          String
  date            String // YYYY-MM-DD（CN 时区，一日一条）
  bedtime         DateTime? // 入睡时间
  wakeTime        DateTime? // 起床时间
  durationSeconds Int? // 总时长（秒）
  deepSeconds     Int? // 深睡
  lightSeconds    Int? // 浅睡
  remSeconds      Int? // REM
  awakeSeconds    Int? // 清醒
  score           Int? // 睡眠评分
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // 一日一条（upsert 防重）
  @@index([userId, date])
}

// ===== 体脂秤数据（V0.1.124，BLE 小米体脂秤 0x181B/0x181D）=====
// 体重（必有）+ 体成分（体脂率/BMI/肌肉/骨骼/水分/内脏脂肪/阻抗，体成分秤才有）
model BodyCompositionRecord {
  id          String   @id @default(cuid())
  userId      String
  weight      Float // 体重 kg（BLE uint16 ×0.01）
  bodyFat     Float? // 体脂率 %
  bmi         Float? // BMI（weight / height²）
  muscle      Float? // 肌肉量 kg
  bone        Float? // 骨量 kg
  water       Float? // 水分率 %
  visceralFat Float? // 内脏脂肪等级 1-30
  impedance   Int? // 原始阻抗值（体成分秤 BIA）
  source      String   @default("ble") // ble | manual
  timestamp   DateTime // 测量时间
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

// 提现申请（V0.1.105 GAP-6）
// 用户提交提现 → admin 后台手动审核 → 标记 approved/rejected
// - pending：钱包不扣（避免申请→消费佣金→退款时余额不足竞态）
// - approved：事务内钱包扣减 + WalletTransaction(type=withdraw) + status=approved
// - rejected：仅标记状态（不动钱包）
// - 微信企业付款 API 真对接留待 GAP-6.2（需商户号 + APIv3 证书）
model WithdrawalRequest {
  id          String    @id @default(cuid())
  userId      String
  amount      Decimal   @db.Decimal(10, 2) // 申请金额（元，≥10）
  status      String    @default("pending") // pending | approved | rejected
  reason      String? // 拒绝原因（rejected 时填）
  processedBy String? // admin openid（approved/rejected 时填）
  processedAt DateTime? // 审核时间
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status]) // 用户查自己的 + admin 按 status 筛选
  @@index([status, createdAt]) // admin 待审核列表
}

// ===== V0.1.130 COROS Terra webhook 聚合 =====
model CorosRawEvent {
  id          String   @id @default(cuid())
  userId      String
  terraUserId String // Terra 返回的 user_id（webhook payload 含）
  type        String // activity | daily | sleep
  payload     Json // 原始 webhook payload（Terra 标准化 JSON）
  processed   Boolean  @default(false) // activity 已解析到 RawActivity
  receivedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, receivedAt])
  @@index([terraUserId])
}

// ===== AI 私教对话（V0.1.139，多轮记忆）=====
// chat/chatStream 每轮 user+assistant 落库；下次请求带最近 N 轮作上下文
// onDelete Cascade（User 删→对话级联）；conversationId 一次会话一组（uuid）
model ConversationTurn {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  role           String // user | assistant
  content        String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, conversationId, createdAt])
  @@index([conversationId])
}

// ===== 每日 AI 健康简报（V0.1.144，原型图"今日"tab 核心）=====
// 健康分数（0-100，聚合步数/心率/睡眠算）+ AI 解读文本（每日 1 次生成 + 缓存）
// @@unique([userId, date]) 防重；onDelete Cascade（User 删→简报级联）
model DailyReport {
  id          String   @id @default(cuid())
  userId      String
  date        String // YYYY-MM-DD（CN 时区）
  healthScore Int // 0-100
  reportText  String // AI 解读文本
  alertText   String? // AI 主动提醒（睡眠不足/心率异常等）
  steps       Int @default(0) // 当日步数（趋势对比用）
  restingHr   Int? // 静息心率
  sleepHours  Float? // 昨晚睡眠时长
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ===== V0.2.8 独立 Admin 账号体系（替白名单 openid）=====
// RBAC 3 角色：super-admin（全部）/ admin（运营）/ operator（只读+轻操作）
// 预置 root(super-admin) + admin(admin)，密码 env 注入 bcrypt hash
model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("operator") // super-admin | admin | operator
  nickname     String?
  lastLoginAt  DateTime?
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  loginLogs AdminLoginLog[]

  @@index([role])
}

// admin 登录日志（审计）
model AdminLoginLog {
  id        String   @id @default(cuid())
  adminId   String
  ip        String?
  ua        String?
  ok        Boolean  @default(true) // 登录成功/失败
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
}

// V0.2.33 interpret module：资料解读记录（佳明 FIT/ZIP / 病历图片 / 运动截图 → minimax M3 解读）
model InterpretRecord {
  id           String   @id @default(cuid())
  userId       String
  type         String   // garmin_fit | garmin_zip | medical | screenshot
  inputKey     String   // 上传资料 COS object key
  result       String   @db.Text // minimax 解读文本
  model        String   // 模型名（MiniMax-M3）
  inputTokens  Int?     // 输入 token 数
  outputTokens Int?     // 输出 token 数
  cost         Float?   // 估算费用（元）
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
}
