    "@types/csv-parse": "^1.2.5",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "prisma": "^5.10.0",
    "supertest": "^6.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.6"
  }
}
