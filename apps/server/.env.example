# ===== apps/server 环境变量 =====
# 复制此文件为 .env，根据实际环境填写

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
# CORS：逗号分隔。微信小程序 wx.request 不走 CORS（仅浏览器 / qm-admin 后台走）。
# dev：仅 localhost；production：必须含 https://qingmulife.cn（企业官网共用域名）。
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产示例：CORS_ORIGINS=https://qingmulife.cn,http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qmwx_dev
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-32-char-random-string
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d

WX_APPID=wx8c37d7ac5b7d0a83
WX_SECRET=your-wx-app-secret
WX_MCH_ID=your-merchant-id
WX_PAY_KEY=your-pay-key-32-bytes
WX_NOTIFY_URL=https://api.example.com/api/wxpay
# Phase 4 微信支付 V3 证书（沙箱可空，真生产必填）
WX_MCH_SERIAL_NO=your-mch-serial-no
WX_MCH_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
WX_PLAT_CERT_PATH=/path/to/wechatpay_cert.pem
# Phase 4.1 退款结果通知（可选 — MVP 同步 refund 不订阅回调）
WX_REFUND_NOTIFY_URL=

# V0.1.130 COROS Terra 聚合（可选 — 缺省 stub，配齐后 COROS 活动自动同步）
TERRA_API_KEY=
TERRA_DEV_ID=
TERRA_WEBHOOK_SECRET=

# V0.1.129 多方式认证（短信/邮件，缺省 stub，配齐后启用真实发送）
SMS_AK=
SMS_SK=
SMS_SIGN=
SMS_TEMPLATE=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# V0.1.139 AI 私教 LLM（智谱 GLM；缺省走 Stub 规则话术，配齐后切真模型）
# 协议：智谱开放平台 v4 API（Bearer 鉴权，API key 格式 {id}.{secret}）
# Coding Plan 套餐模型：glm-4.7（推荐）/ glm-4.6 / glm-4.5 / glm-4-plus / glm-4-air
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=
LLM_MODEL=glm-4.7

# V0.1.144 MQTT（EMQX Cloud Serverless，AI 简报推送；缺省走 API 拉）
MQTT_HOST=rd133da1.ala.cn-hangzhou.emqxsl.cn
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CA_PATH=certs/emqxsl-ca.crt

# V0.1.148 和风天气 QWeather（stats.weather action；缺省走 stub 长沙晴 25°C）
QWEATHER_KEY=<your-qweather-api-key>
QWEATHER_API_HOST=nf5b5vtkcp.re.qweatherapi.com

# V0.1.149 腾讯云 COS 对象存储（upload phase 1.1）
# 地域：ap-guangzhou（广州）；单桶 qm-wx-1418512491，公有读 + server 写入
# CDN 域名：cos-cdn.qingmulife.cn（可选；空走 COS 默认域名）
# 缺省走 本地 fallback（即不填也能跑，仅落 uploads/，重启丢）
COS_SECRET_ID=<your-cos-secret-id>
COS_SECRET_KEY=<your-cos-secret-key>
COS_REGION=ap-guangzhou
COS_BUCKET=qm-wx-1418512491
COS_CDN_DOMAIN=cos-cdn.qingmulife.cn
