<view class="page">
  <!-- 标题 + 统计 -->
  <view class="header bg-white">
    <view class="title">我的跑鞋</view>
    <view class="stats-row" wx:if="{{stats.total > 0}}">
      <view class="stat"><text class="v">{{stats.activeCount}}</text><text class="u">活跃</text></view>
      <view class="stat"><text class="v">{{stats.totalKm}}</text><text class="u">总里程km</text></view>
      <view class="stat" wx:if="{{stats.retiringSoonCount > 0}}">
        <text class="v warn">{{stats.retiringSoonCount}}</text><text class="u">待更换</text>
      </view>
      <view class="stat compare-btn" wx:if="{{stats.activeCount >= 2}}" catchtap="onComparePick">
        <text class="v" style="font-size:28rpx;">对比 2 双 ›</text>
      </view>
    </view>
  </view>

  <!-- 跑鞋列表 -->
  <view class="list" wx:if="{{!loading}}">
    <view wx:if="{{shoes.length === 0}}" class="empty">
      <view class="empty-text">还没有跑鞋记录</view>
      <view class="empty-tip">添加你的第一双跑鞋，打卡自动累计里程</view>
    </view>

    <view
      class="shoe-card {{item.status === 'retired' ? 'retired' : ''}} {{selectedShoeId === item.id ? 'expanded' : ''}}"
      wx:for="{{shoes}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onTapShoe"
    >
      <view class="shoe-head">
        <view class="shoe-name">{{item.nickname || (item.brand + ' ' + item.model)}}</view>
        <view class="shoe-status {{item.status}}">{{item.status === 'active' ? '使用中' : '已退役'}}</view>
      </view>
      <view class="shoe-sub">{{item.brand}} · {{item.model}}</view>

      <!-- 里程进度条 -->
      <view class="progress">
        <view class="progress-bar">
          <view
            class="progress-fill {{item.healthRatio >= 100 ? 'red' : (item.healthRatio >= 70 ? 'yellow' : 'green')}}"
            style="width: {{item.healthRatio > 100 ? 100 : item.healthRatio}}%;"
          ></view>
        </view>
        <view class="progress-text">
          <text class="current">{{item.currentKm}}</text> / {{item.thresholdKm}} km
          <text class="pct">（{{item.healthRatio}}%）</text>
        </view>
      </view>

      <!-- 健康度提示 -->
      <view class="shoe-tip {{item.healthRatio >= 100 ? 'red' : (item.healthRatio >= 70 ? 'yellow' : 'green')}}">
        <block wx:if="{{item.healthRatio >= 100}}">⚠️ 已超阈值，建议尽快更换（防受伤）</block>
        <block wx:elif="{{item.healthRatio >= 70}}">⏰ 接近更换阈值，注意规划</block>
        <block wx:else>✓ 状态良好 · 点查看详情</block>
      </view>

      <!-- 展开详情区（V0.1.143 合并 shoes-detail） -->
      <block wx:if="{{selectedShoeId === item.id}}">
        <view class="detail-loading" wx:if="{{detailLoading}}">加载中...</view>
        <block wx:elif="{{detail}}">
          <view class="detail-section">
            <view class="detail-meta" wx:if="{{detail.purchasedAt}}">购入：{{detail.purchasedAt}} · 已使用 {{detail.daysSincePurchase}} 天</view>
            <view class="detail-meta" wx:if="{{detail.note}}">备注：{{detail.note}}</view>
          </view>

          <!-- 阈值编辑器 -->
          <view class="detail-section">
            <view class="detail-title">更换阈值（km）</view>
            <view class="threshold-current">
              <text class="num">{{detail.thresholdKm}}</text>
              <text class="unit">km</text>
            </view>
            <slider
              min="100" max="2000" step="50"
              value="{{detail.thresholdKm}}"
              bindchanging="onThresholdChanging"
              bindchange="onThresholdChange"
              activeColor="#0FAF8E"
              block-size="20"
              show-value="{{false}}"
              disabled="{{savingThreshold}}"
            />
            <view class="threshold-meta">
              <text>100</text>
              <text class="draft">待保存：{{thresholdDraft}} km</text>
              <text>2000</text>
            </view>
          </view>

          <!-- 累计统计 -->
          <view class="detail-section stats-grid">
            <view class="stat-cell">
              <text class="stat-num">{{detail.currentKm}}</text>
              <text class="stat-label">当前里程(km)</text>
            </view>
            <view class="stat-cell">
              <text class="stat-num health-{{detail.healthRatio < 70 ? 'good' : detail.healthRatio <= 100 ? 'warn' : 'bad'}}">{{detail.healthRatio}}%</text>
              <text class="stat-label">健康度</text>
            </view>
            <view class="stat-cell">
              <text class="stat-num">{{detail.totalCheckins}}</text>
              <text class="stat-label">累计打卡</text>
            </view>
            <view class="stat-cell">
              <text class="stat-num">{{mileageHistory.totalKm}}</text>
              <text class="stat-label">合计里程(km)</text>
            </view>
          </view>

          <!-- 里程曲线 -->
          <view class="detail-section">
            <view class="detail-title-row">
              <text class="detail-title">里程曲线</text>
              <view class="period-tabs">
                <view class="tab {{period === 'weekly' ? 'active' : ''}}" data-period="weekly" bindtap="onPeriodChange">周</view>
                <view class="tab {{period === 'monthly' ? 'active' : ''}}" data-period="monthly" bindtap="onPeriodChange">月</view>
              </view>
            </view>
            <view wx:if="{{mileageHistory.totalCheckins === 0}}" class="detail-empty">
              <text>暂无里程数据</text>
              <text class="detail-empty-tip">去 [sport 打卡] 试试，选这双跑鞋</text>
            </view>
            <block wx:else>
              <mileage-chart
                points="{{period === 'weekly' ? mileageHistory.weekly : mileageHistory.monthly}}"
                width="{{chartWidth}}"
                height="{{chartHeight}}"
              />
            </block>
          </view>
        </block>
      </block>

      <!-- 操作按钮 -->
      <view class="shoe-actions" wx:if="{{item.status === 'active'}}">
        <view class="retire-btn" data-id="{{item.id}}" catchtap="onRetire">退役</view>
      </view>
    </view>
  </view>

  <view class="loading" wx:else>加载中...</view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="onAdd">+ 添加跑鞋</view>

  <!-- 对比弹层（V0.1.143 合并 shoes-compare） -->
  <view class="mask" wx:if="{{compareVisible}}" bindtap="closeCompare">
    <view class="compare-panel" catchtap="">
      <view class="compare-title">跑鞋对比</view>
      <view wx:if="{{compareLoading}}" class="compare-loading">加载中...</view>
      <block wx:elif="{{compareShoes.length === 2}}">
        <view class="compare-header">
          <view class="compare-name">{{compareShoes[0].nickname || (compareShoes[0].brand + ' ' + compareShoes[0].model)}}</view>
          <view class="compare-vs">VS</view>
          <view class="compare-name">{{compareShoes[1].nickname || (compareShoes[1].brand + ' ' + compareShoes[1].model)}}</view>
        </view>
        <view class="compare-table">
          <view class="compare-row compare-header-row">
            <view class="compare-cell label">维度</view>
            <view class="compare-cell">{{compareShoes[0].nickname || compareShoes[0].brand}}</view>
            <view class="compare-cell">{{compareShoes[1].nickname || compareShoes[1].brand}}</view>
          </view>
          <view wx:for="{{compareRows}}" wx:key="label" class="compare-row">
            <view class="compare-cell label">{{item.label}}</view>
            <view class="compare-cell {{item.winnerIdx === 0 ? 'winner' : ''}}">{{item.values[0]}}</view>
            <view class="compare-cell {{item.winnerIdx === 1 ? 'winner' : ''}}">{{item.values[1]}}</view>
          </view>
        </view>
      </block>
      <view class="form-actions">
        <button class="btn-cancel" bindtap="closeCompare">关闭</button>
      </view>
    </view>
  </view>

  <!-- 添加弹层 -->
  <view class="mask" wx:if="{{formVisible}}" bindtap="closeForm">
    <view class="form-panel" catchtap="">
      <view class="form-title">添加跑鞋</view>
      <view class="form-item">
        <text class="label">品牌 *</text>
        <input class="input" value="{{form.brand}}" data-field="brand" bindinput="onInput" placeholder="如 Nike / 必迈 / 路征" />
      </view>
      <view class="form-item">
        <text class="label">型号 *</text>
        <input class="input" value="{{form.model}}" data-field="model" bindinput="onInput" placeholder="如 Vaporfly Next%" />
      </view>
      <view class="form-item">
        <text class="label">昵称</text>
        <input class="input" value="{{form.nickname}}" data-field="nickname" bindinput="onInput" placeholder="如 战靴一号" />
      </view>
      <view class="form-item">
        <text class="label">更换阈值</text>
        <view class="threshold-row">
          <slider
            min="100" max="2000" step="50"
            value="{{form.thresholdKm}}"
            bindchanging="onFormThresholdChanging"
            activeColor="#0FAF8E"
            block-size="20"
            show-value="{{false}}"
            class="threshold-slider"
          />
          <text class="threshold-val">{{form.thresholdKm}} km</text>
        </view>
        <view class="threshold-tip">拖动滑块调整（100-2000，默认 800）</view>
      </view>
      <view class="form-actions">
        <button class="btn-cancel" bindtap="closeForm">取消</button>
        <van-button type="primary" block bindtap="onSubmit" loading="{{submitting}}">添加</van-button>
      </view>
    </view>
  </view>
</view>
