/* pages/shoes/index.wxss — 我的跑鞋（V0.1.143 合并 shoes-detail + shoes-compare） */
.page { min-height: 100vh; background: #f5f5f5; padding: 16rpx; padding-bottom: 140rpx; box-sizing: border-box; }
.bg-white { background: #fff; }

/* 标题 + 统计 */
.header { padding: 32rpx; border-radius: 16rpx; margin-bottom: 16rpx; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.stats-row { display: flex; gap: 40rpx; margin-top: 20rpx; align-items: baseline; }
.stat { display: flex; align-items: baseline; gap: 4rpx; }
.stat .v { font-size: 36rpx; font-weight: 600; color: #2D9D78; }
.stat .v.warn { color: #fa8c16; }
.stat .u { font-size: 22rpx; color: #999; }
.compare-btn { margin-left: auto; }

/* 空态 */
.empty { text-align: center; padding: 120rpx 0; }
.empty-text { font-size: 30rpx; color: #666; }
.empty-tip { font-size: 24rpx; color: #bbb; margin-top: 12rpx; }
.loading { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

/* 跑鞋卡 */
.shoe-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.shoe-card.retired { opacity: 0.55; }
.shoe-card.expanded { box-shadow: 0 4rpx 20rpx rgba(15,175,142,0.12); }
.shoe-head { display: flex; justify-content: space-between; align-items: center; }
.shoe-name { font-size: 32rpx; font-weight: 600; color: #333; flex: 1; }
.shoe-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx; }
.shoe-status.active { background: #E6F7F2; color: #2D9D78; }
.shoe-status.retired { background: #f5f5f5; color: #999; }
.shoe-sub { font-size: 24rpx; color: #999; margin-top: 6rpx; }

/* 里程进度条 */
.progress { margin-top: 20rpx; }
.progress-bar { height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 8rpx; transition: width 0.3s; }
.progress-fill.green { background: #2D9D78; }
.progress-fill.yellow { background: #fa8c16; }
.progress-fill.red { background: #e64340; }
.progress-text { font-size: 24rpx; color: #666; margin-top: 8rpx; }
.progress-text .current { font-size: 30rpx; font-weight: 600; color: #333; }
.progress-text .pct { color: #999; margin-left: 8rpx; }

/* 健康度提示 */
.shoe-tip { font-size: 24rpx; margin-top: 12rpx; }
.shoe-tip.green { color: #2D9D78; }
.shoe-tip.yellow { color: #fa8c16; }
.shoe-tip.red { color: #e64340; }

.shoe-actions { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; display: flex; justify-content: flex-end; }
.retire-btn { font-size: 24rpx; color: #999; padding: 8rpx 20rpx; border: 1rpx solid #ddd; border-radius: 8rpx; }

/* === 展开详情区（合并自 shoes-detail） === */
.detail-loading { text-align: center; padding: 40rpx; color: #999; font-size: 26rpx; }
.detail-section { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #f0f0f0; }
.detail-section:first-child { border-top: none; }
.detail-meta { font-size: 24rpx; color: #666; margin-top: 8rpx; }
.detail-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.detail-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }

.threshold-current { text-align: center; margin: 16rpx 0; }
.threshold-current .num { font-size: 56rpx; font-weight: 700; color: #2D9D78; }
.threshold-current .unit { font-size: 28rpx; color: #888; margin-left: 8rpx; }
.threshold-meta { display: flex; justify-content: space-between; font-size: 22rpx; color: #999; margin-top: 8rpx; }
.threshold-meta .draft { color: #2D9D78; font-weight: 600; }

.stats-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.stat-cell { flex: 0 0 48%; text-align: center; padding: 12rpx 0; }
.stat-num { display: block; font-size: 40rpx; font-weight: 700; color: #222; margin-bottom: 6rpx; }
.stat-num.health-good { color: #2D9D78; }
.stat-num.health-warn { color: #f59e0b; }
.stat-num.health-bad { color: #ef4444; }
.stat-label { font-size: 24rpx; color: #888; }

.period-tabs { display: flex; background: #f5f5f5; border-radius: 24rpx; padding: 4rpx; }
.period-tabs .tab { font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 20rpx; color: #666; }
.period-tabs .tab.active { background: #2D9D78; color: #fff; }
.detail-empty { text-align: center; padding: 40rpx 0; color: #999; }
.detail-empty-tip { display: block; margin-top: 12rpx; font-size: 24rpx; color: #bbb; }

/* === 对比弹层（合并自 shoes-compare） === */
.compare-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; box-sizing: border-box; max-height: 80vh; overflow-y: auto; }
.compare-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; text-align: center; }
.compare-loading { text-align: center; padding: 60rpx 0; color: #999; }
.compare-header { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; margin-bottom: 16rpx; }
.compare-name { flex: 1; font-size: 26rpx; font-weight: 600; color: #222; text-align: center; }
.compare-vs { font-size: 28rpx; font-weight: 700; color: #ef4444; padding: 0 16rpx; }
.compare-table { background: #f9fafb; border-radius: 12rpx; overflow: hidden; }
.compare-row { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.compare-row:last-child { border-bottom: none; }
.compare-header-row { background: #f0f0f0; font-weight: 600; }
.compare-cell { flex: 1; padding: 20rpx 12rpx; font-size: 26rpx; text-align: center; color: #333; }
.compare-cell.label { flex: 0 0 200rpx; background: #fafbfc; color: #666; font-size: 24rpx; }
.compare-cell.winner { color: #2D9D78; font-weight: 700; background: #f0f9f6; }

/* 悬浮添加按钮 */
.fab {
  position: fixed; bottom: 40rpx; left: 50%; transform: translateX(-50%);
  background: #2D9D78; color: #fff; padding: 20rpx 48rpx;
  border-radius: 40rpx; font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 175, 142, 0.4);
  z-index: 10;
}

/* 弹层遮罩 */
.mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
  display: flex; align-items: flex-end;
}
.form-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; box-sizing: border-box; }
.form-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.form-item { margin-bottom: 20rpx; }
.form-item .label { font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx; }
.input { background: #f5f5f5; padding: 16rpx 20rpx; border-radius: 8rpx; font-size: 28rpx; }
.threshold-row { display: flex; align-items: center; gap: 16rpx; }
.threshold-slider { flex: 1; }
.threshold-val { font-size: 26rpx; color: #2D9D78; font-weight: 600; min-width: 100rpx; }
.threshold-tip { font-size: 22rpx; color: #bbb; margin-top: 8rpx; }
.form-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn-cancel, .btn-submit { flex: 1; font-size: 28rpx; border-radius: 8rpx; line-height: 72rpx; padding: 0; margin: 0; }
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-submit { background: #2D9D78; color: #fff; }
