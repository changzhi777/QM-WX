<view class="page">
  <!-- 红色佣金卡（参考 2762） -->
  <view class="hero">
    <view class="hero-row">
      <view class="hero-main">
        <view class="lbl">本月佣金(税前)</view>
        <view class="num">{{summary.monthCommission || '0.00'}}</view>
      </view>
      <view class="badge">{{summary.level || 'V0'}}</view>
    </view>
    <view class="hero-sub">
      <view class="sub-item">
        <view class="sub-num">{{summary.monthSales || '0.00'}}</view>
        <view class="sub-lbl">销售金额(元)</view>
      </view>
      <view class="sub-item">
        <view class="sub-num">{{summary.orderCount || 0}}</view>
        <view class="sub-lbl">推广订单数</view>
      </view>
    </view>
    <view class="invite" bindtap="copyCode">
      <text class="invite-lbl">我的邀请码：{{summary.inviteCode || '-'}}</text>
      <text class="invite-act">复制</text>
    </view>
  </view>

  <!-- 功能宫格（6 项） -->
  <view class="grid">
    <view class="grid-item {{activeTab === 'orders' ? 'active' : ''}}" data-tab="orders" bindtap="switchTab">
      <view class="grid-ico">📋</view>
      <view class="grid-txt">分销订单</view>
    </view>
    <view class="grid-item {{activeTab === 'team' ? 'active' : ''}}" data-tab="team" bindtap="switchTab">
      <view class="grid-ico">👥</view>
      <view class="grid-txt">我的团队</view>
    </view>
    <view class="grid-item {{activeTab === 'logs' ? 'active' : ''}}" data-tab="logs" bindtap="switchTab">
      <view class="grid-ico">💰</view>
      <view class="grid-txt">佣金记录</view>
    </view>
    <view class="grid-item" bindtap="goInvite">
      <view class="grid-ico">🎁</view>
      <view class="grid-txt">邀请好友</view>
    </view>
    <view class="grid-item" bindtap="goRule">
      <view class="grid-ico">🎖</view>
      <view class="grid-txt">分销等级</view>
    </view>
    <view class="grid-item" bindtap="goRule">
      <view class="grid-ico">📖</view>
      <view class="grid-txt">分销说明</view>
    </view>
  </view>

  <!-- 等级进度（若 next 存在） -->
  <view class="level" wx:if="{{levelInfo && levelInfo.next}}">
    <view class="level-cur">当前：{{levelInfo.title}}（{{levelInfo.rate * 100}}% 佣金率）</view>
    <view class="level-next">距 {{levelInfo.next.title}}：还需佣金 ¥{{levelInfo.next.needCommission}} 或 {{levelInfo.next.needTeam}} 人</view>
  </view>

  <!-- 列表区 -->
  <view class="list">
    <view class="loading" wx:if="{{loading}}">加载中…</view>

    <!-- 分销订单 -->
    <block wx:elif="{{activeTab === 'orders'}}">
      <view wx:if="{{list.length === 0}}" class="empty">暂无推广订单</view>
      <view wx:for="{{list}}" wx:key="id" class="card">
        <view class="card-hd">
          <text class="card-title">{{item.items[0].name}} 等</text>
          <text class="card-status {{item.status}}">{{item.status === 'settled' ? '已结算' : item.status === 'cancelled' ? '已取消' : '待结算'}}</text>
        </view>
        <view class="card-bd">
          <text>订单金额 ¥{{item.orderAmount}}</text>
          <text class="comm">佣金 ¥{{item.commissionAmount}}</text>
        </view>
      </view>
    </block>

    <!-- 我的团队 -->
    <block wx:elif="{{activeTab === 'team'}}">
      <view class="team-stat">直推 {{directCount}} 人 · 间推 {{indirectCount}} 人</view>
      <view wx:if="{{list.length === 0}}" class="empty">暂无团队成员，去邀请好友吧</view>
      <view wx:for="{{list}}" wx:key="id" class="member">
        <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="member-info">
          <view class="member-name">{{item.nickname}}</view>
          <view class="member-lbl">{{item.level === 1 ? '直推' : '间推'}} · {{item.inviteeLevel}}</view>
        </view>
        <view class="member-time">{{item.joinedAt}}</view>
      </view>
    </block>

    <!-- 佣金记录 -->
    <block wx:else>
      <view wx:if="{{list.length === 0}}" class="empty">暂无佣金记录</view>
      <view wx:for="{{list}}" wx:key="id" class="log">
        <view class="log-info">
          <view class="log-type">{{item.type === 'settle' ? '佣金结算' : item.type === 'clawback' ? '退款冲红' : '调整'}}</view>
          <view class="log-time">{{item.createdAt}}</view>
        </view>
        <view class="log-amt {{item.amount < 0 ? 'neg' : 'pos'}}">{{item.amount >= 0 ? '+' : ''}}{{item.amount}}</view>
      </view>
    </block>
  </view>
</view>
