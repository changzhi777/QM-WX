/* 分销中心（参考 2762） */
.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }

.hero {
  background: linear-gradient(135deg, #0FAF8E 0%, #0d8a72 100%);
  color: #fff;
  padding: 40rpx 32rpx 32rpx;
}
.hero-row { display: flex; justify-content: space-between; align-items: flex-start; }
.hero-main .lbl { font-size: 26rpx; opacity: 0.9; }
.hero-main .num { font-size: 64rpx; font-weight: 700; margin-top: 8rpx; }
.badge {
  background: rgba(255,255,255,0.25);
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.hero-sub { display: flex; margin-top: 32rpx; }
.sub-item { flex: 1; }
.sub-num { font-size: 36rpx; font-weight: 600; }
.sub-lbl { font-size: 24rpx; opacity: 0.85; margin-top: 4rpx; }
.invite {
  margin-top: 28rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.invite-lbl { font-size: 26rpx; }
.invite-act { font-size: 26rpx; font-weight: 600; }

.grid {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  display: flex;
  flex-wrap: wrap;
}
.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}
.grid-item.active .grid-txt { color: #0FAF8E; font-weight: 600; }
.grid-ico { font-size: 48rpx; }
.grid-txt { font-size: 26rpx; color: #333; margin-top: 8rpx; }

.level {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}
.level-cur { font-size: 28rpx; font-weight: 600; color: #333; }
.level-next { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.list { margin: 0 20rpx; }
.loading, .empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
.card, .log {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card-hd { display: flex; justify-content: space-between; align-items: center; }
.card-title { font-size: 28rpx; font-weight: 600; color: #333; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.card-status.settled { background: #e8f7f2; color: #0FAF8E; }
.card-status.cancelled { background: #fce8e8; color: #e0514a; }
.card-status.pending { background: #fff4e0; color: #f0a020; }
.card-bd { display: flex; justify-content: space-between; margin-top: 16rpx; font-size: 26rpx; color: #666; }
.comm { color: #0FAF8E; font-weight: 600; }

.team-stat { font-size: 26rpx; color: #666; padding: 16rpx 8rpx; }
.member {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; }
.member-info { flex: 1; margin-left: 20rpx; }
.member-name { font-size: 28rpx; color: #333; }
.member-lbl { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.member-time { font-size: 22rpx; color: #bbb; }

.log { display: flex; justify-content: space-between; align-items: center; }
.log-type { font-size: 28rpx; color: #333; }
.log-time { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.log-amt { font-size: 32rpx; font-weight: 600; }
.log-amt.pos { color: #0FAF8E; }
.log-amt.neg { color: #e0514a; }
