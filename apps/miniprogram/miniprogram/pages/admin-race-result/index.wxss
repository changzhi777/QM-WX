/* pages/admin-race-result/index.wxss — V0.1.134 admin 风格 */

.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #888;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.empty .empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* 头部 */
.header {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.content-info {
  margin-bottom: 16rpx;
}

.content-label {
  font-size: 26rpx;
  color: #888;
}

.content-id {
  font-size: 26rpx;
  color: #333;
  font-family: monospace;
}

.btn-pick {
  background: #0FAF8E;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.enrollment-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.enrollment-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eee;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nickname {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
}

.enrollment-status {
  font-size: 22rpx;
  color: #888;
}

.result-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #fff5f0;
  border-radius: 8rpx;
}

.result-badge.empty {
  background: #f5f5f5;
}

.result-badge .rank {
  font-size: 26rpx;
  font-weight: 700;
  color: #ef4444;
}

.result-badge .time {
  font-size: 22rpx;
  color: #888;
}

.result-badge .no-result {
  font-size: 22rpx;
  color: #999;
}

/* 弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.form-panel {
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.form-user {
  font-size: 26rpx;
  color: #0FAF8E;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item .label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.form-item .input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-cancel,
.btn-submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-submit {
  background: #0FAF8E;
  color: #fff;
}