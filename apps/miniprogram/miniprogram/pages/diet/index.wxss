/* pages/diet/index.wxss — V0.2.0 饮食日记 */
.diet {
  padding: 24rpx;
  min-height: 100vh;
  background: #f5f6f8;
  box-sizing: border-box;
}

/* 汇总卡 */
.summary-card {
  background: linear-gradient(135deg, #2d9d78, #1f7a5e);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(45, 157, 120, 0.25);
}
.calorie-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 28rpx;
}
.calorie-main .num {
  font-size: 64rpx;
  font-weight: 700;
  margin-right: 12rpx;
}
.calorie-main .unit {
  font-size: 26rpx;
  opacity: 0.9;
}
.macro-row {
  display: flex;
  justify-content: space-around;
}
.macro {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.macro-val {
  font-size: 32rpx;
  font-weight: 600;
}
.macro-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

/* 搜索 */
.search-box {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
  gap: 12rpx;
}
.search-input {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
}
.search-btn {
  background: #2d9d78 !important;
  color: #fff !important;
  border-radius: 12rpx !important;
}

/* 搜索结果 */
.results {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}
.results-title {
  font-size: 24rpx;
  color: #999;
  padding: 0 28rpx 12rpx;
}
.result-item {
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.result-item:last-child {
  border-bottom: none;
}
.result-name {
  font-size: 30rpx;
  color: #333;
}
.result-brand {
  font-size: 24rpx;
  color: #999;
}

/* 手动添加按钮 */
.manual-btn {
  background: #fff !important;
  color: #2d9d78 !important;
  border: 2rpx dashed #2d9d78 !important;
  border-radius: 16rpx !important;
  font-size: 28rpx !important;
  margin-bottom: 24rpx;
}

/* 今日饮食 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
.meal-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.meal-head {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.meal-type-tag {
  background: rgba(45, 157, 120, 0.12);
  color: #2d9d78;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}
.meal-calorie {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.meal-del {
  font-size: 24rpx;
  color: #e74c3c;
}
.meal-items {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.meal-item-text {
  font-size: 26rpx;
  color: #666;
}

/* 添加弹层 */
.add-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}
.add-sheet {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.sheet-row {
  margin-bottom: 20rpx;
}
.picker-val {
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}
.sheet-input {
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}
.macro-inputs {
  display: flex;
  gap: 16rpx;
}
.sheet-input.mini {
  flex: 1;
  margin-bottom: 24rpx;
}
.sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}
.sheet-btn {
  flex: 1;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
}
.sheet-btn.cancel {
  background: #f0f0f0 !important;
  color: #666 !important;
}
.sheet-btn.confirm {
  background: #2d9d78 !important;
  color: #fff !important;
}
