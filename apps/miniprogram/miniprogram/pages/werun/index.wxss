/* pages/werun/index.wxss — 微信运动历史（V0.1.44） */
.page { padding: 24rpx; min-height: 100vh; background: #f5f5f5; box-sizing: border-box; }

/* 月份切换 */
.month-bar { display: flex; align-items: center; justify-content: center; padding: 16rpx 0 24rpx; }
.month-bar .arrow { font-size: 48rpx; color: #0faf8e; padding: 0 40rpx; line-height: 1; }
.month-bar .arrow.disabled { color: #ccc; }
.month-bar .month-label { font-size: 32rpx; font-weight: 600; min-width: 200rpx; text-align: center; }

/* 汇总卡 */
.summary-card {
  display: flex; background: #fff; border-radius: 16rpx; padding: 28rpx 0; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.summary-item { flex: 1; text-align: center; }
.summary-item .num { font-size: 36rpx; font-weight: 700; color: #0faf8e; }
.summary-item .lbl { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* 柱状图 */
.chart-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.chart-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.empty { color: #999; font-size: 26rpx; text-align: center; padding: 60rpx 0; }
.chart-scroll { white-space: nowrap; }
.chart-bars { display: inline-flex; align-items: flex-end; gap: 6rpx; height: 320rpx; padding: 0 8rpx; }
.bar-col { display: flex; flex-direction: column; align-items: center; width: 36rpx; height: 100%; justify-content: flex-end; }
.bar { width: 24rpx; background: linear-gradient(180deg, #0faf8e, rgba(15,175,142,0.5)); border-radius: 6rpx 6rpx 0 0; }
.bar-day { font-size: 16rpx; color: #999; margin-top: 8rpx; }

/* 同步按钮 */
.sync-btn {
  background: #0faf8e; color: #fff; border-radius: 48rpx; font-size: 30rpx;
  margin-top: 16rpx; line-height: 88rpx;
}
.sync-btn.loading { opacity: 0.6; }
.sync-btn::after { border: none; }

.tip { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 24rpx; }
