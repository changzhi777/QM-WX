<view class="page">
  <view class="header">
    <view class="title">账号绑定</view>
    <view class="subtitle">绑定后可用对应方式登录（微信登录仍为主入口）</view>
  </view>

  <!-- 当前绑定状态 -->
  <view class="card">
    <view class="card-title">当前绑定</view>
    <view class="status-row"><text>手机号</text><text class="status {{phone ? 'bound' : ''}}">{{phone || '未绑定'}}</text></view>
    <view class="status-row"><text>邮箱</text><text class="status {{email ? 'bound' : ''}}">{{email || '未绑定'}}</text></view>
    <view class="status-row"><text>密码</text><text class="status {{hasPassword ? 'bound' : ''}}">{{hasPassword ? '已设置' : '未设置'}}</text></view>
  </view>

  <!-- 绑定手机号 -->
  <view class="card">
    <view class="card-title">绑定手机号</view>
    <view class="input-row">
      <input class="input" type="number" placeholder="手机号" value="{{smsPhone}}" bindinput="onSmsPhoneInput" maxlength="11" />
    </view>
    <view class="input-row">
      <input class="input" type="number" placeholder="验证码" value="{{smsCode}}" bindinput="onCodeInput" maxlength="6" />
      <button class="sms-btn" bindtap="onSendSms" disabled="{{smsCountdown > 0}}">{{smsCountdown > 0 ? smsCountdown + 's' : '发送'}}</button>
    </view>
    <button class="submit-btn" bindtap="onBindPhone">绑定手机号</button>
  </view>

  <!-- 绑定邮箱 -->
  <view class="card">
    <view class="card-title">绑定邮箱</view>
    <view class="input-row">
      <input class="input" placeholder="邮箱地址" value="{{emailInput}}" bindinput="onEmailInput" />
    </view>
    <view class="input-row">
      <input class="input" password="{{true}}" placeholder="设置密码（≥6位，邮箱登录用）" value="{{emailPassword}}" bindinput="onEmailPasswordInput" />
    </view>
    <button class="submit-btn" bindtap="onBindEmail">绑定邮箱</button>
  </view>

  <!-- 设置/修改密码 -->
  <view class="card">
    <view class="card-title">{{hasPassword ? '修改密码' : '设置密码'}}</view>
    <view class="input-row">
      <input class="input" password="{{true}}" placeholder="新密码（≥6位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
    </view>
    <button class="submit-btn" bindtap="onBindPassword">{{hasPassword ? '修改密码' : '设置密码'}}</button>
  </view>
</view>
