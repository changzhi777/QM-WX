.page { min-height: 100vh; background: #f5f5f5; padding: 16rpx; padding-bottom: 40rpx; box-sizing: border-box; }
.header { padding: 32rpx; background: #fff; border-radius: 16rpx; margin-bottom: 16rpx; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.header .subtitle { font-size: 24rpx; color: #999; margin-top: 8rpx; line-height: 1.5; }

.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }

.status-row { display: flex; justify-content: space-between; padding: 14rpx 0; font-size: 26rpx; color: #999; border-bottom: 1rpx solid #f0f0f0; }
.status-row:last-child { border-bottom: none; }
.status { color: #ccc; }
.status.bound { color: #0FAF8E; }

.input-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.input { flex: 1; height: 72rpx; background: #f9f9f9; border-radius: 8rpx; padding: 0 20rpx; font-size: 28rpx; box-sizing: border-box; }
.sms-btn { width: 160rpx; height: 72rpx; line-height: 72rpx; font-size: 24rpx; background: #0FAF8E; color: #fff; border-radius: 8rpx; padding: 0; margin: 0; }
.sms-btn[disabled] { background: #ccc; color: #fff; }

.submit-btn { width: 100%; height: 80rpx; line-height: 80rpx; background: #0FAF8E; color: #fff; border-radius: 8rpx; font-size: 28rpx; margin-top: 8rpx; padding: 0; }
.submit-btn::after { border: none; }
