.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }
.loading, .empty { text-align: center; padding: 120rpx 0; color: #999; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-tip { font-size: 24rpx; color: #bbb; margin-top: 8rpx; }

.month-card { margin: 24rpx; background: #fff; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.month-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.month-label { font-size: 32rpx; font-weight: 600; color: #333; }
.month-days { font-size: 24rpx; color: #2D9D78; background: rgba(45,157,120,0.1); padding: 6rpx 18rpx; border-radius: 20rpx; }

.month-stats { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stat { flex: 1; text-align: center; background: #f9fbfa; border-radius: 12rpx; padding: 16rpx 8rpx; }
.stat-val { font-size: 32rpx; font-weight: 600; color: #2D9D78; }
.stat-label { font-size: 22rpx; color: #888; margin-top: 4rpx; }

.days-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.day-chip { display: flex; flex-direction: column; align-items: center; background: #f5f6f8; border-radius: 10rpx; padding: 10rpx 16rpx; min-width: 92rpx; }
.day-score { font-size: 26rpx; font-weight: 600; color: #333; }
.day-date { font-size: 20rpx; color: #999; margin-top: 2rpx; }
