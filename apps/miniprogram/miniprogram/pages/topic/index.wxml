<view class="page">
  <!-- 话题头部 -->
  <view class="topic-header">
    <view class="topic-title">#{{topic}}</view>
    <view class="topic-desc">{{feeds.length}} 条动态 · 分享同好</view>
  </view>

  <!-- 动态列表 -->
  <view class="feed-list">
    <view class="feed-card" wx:for="{{feeds}}" wx:key="id">
      <view class="card-head">
        <image class="avatar" src="{{item.user.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <view class="nickname">{{item.user.nickname || '跑者'}}</view>
          <view class="time">{{item.createdAt}}</view>
        </view>
      </view>
      <view class="card-content">{{item.content}}</view>
      <view class="card-meta">
        ❤️ {{item.likeCount}}  💬 {{item.commentCount}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{!hasMore && feeds.length > 0}}" class="end">— 没有更多了 —</view>
  <view wx:elif="{{!loading && feeds.length === 0}}" class="empty">
    <view class="empty-icon">📭</view>
    <view>该话题还没有动态</view>
  </view>
</view>
