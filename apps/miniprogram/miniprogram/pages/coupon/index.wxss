/* pages/coupon/index.wxss（V0.1.23） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #f0f0f0; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; }
.tab.active { color: #0FAF8E; font-weight: 600; border-bottom: 4rpx solid #0FAF8E; }
.sub-tabs { display: flex; background: #fff; padding: 16rpx 32rpx; gap: 16rpx; }
.sub { padding: 8rpx 24rpx; border-radius: 24rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.sub.active { background: #0FAF8E; color: #fff; }
.coupon-card { display: flex; align-items: center; background: #fff; margin: 16rpx; border-radius: 12rpx; overflow: hidden; }
.coupon-left { width: 200rpx; background: linear-gradient(135deg, #0FAF8E, #0d9980); color: #fff; padding: 24rpx 0; text-align: center; }
.coupon-left .amount { font-size: 40rpx; font-weight: 700; }
.coupon-left .min { font-size: 20rpx; opacity: 0.85; margin-top: 4rpx; }
.coupon-info { flex: 1; padding: 24rpx; }
.coupon-info .title { font-size: 30rpx; color: #333; font-weight: 500; }
.coupon-info .valid { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.coupon-btn { padding: 16rpx 24rpx; background: #0FAF8E; color: #fff; font-size: 24rpx; border-radius: 24rpx; margin-right: 24rpx; }
.coupon-btn.received { background: #e0e0e0; color: #999; }
.coupon-card.expired, .coupon-card.used { opacity: 0.5; }
.empty { text-align: center; color: #999; padding: 80rpx 0; font-size: 26rpx; }
