.page { padding-bottom: 40rpx; }

.tabs {
  display: flex; position: sticky; top: 0; z-index: 10;
  border-bottom: 1rpx solid var(--border);
}
.tab {
  flex: 1; padding: 24rpx 0; text-align: center;
  font-size: 28rpx; color: var(--text-secondary);
}
.tab-active { color: var(--brand); font-weight: 600; border-bottom: 4rpx solid var(--brand); }

.card { display: flex; }
.cover-wrap { position: relative; width: 240rpx; height: 180rpx; flex-shrink: 0; }
.cover { width: 100%; height: 100%; border-radius: 8rpx; background: #f0f0f0; }
.type-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  padding: 4rpx 12rpx; background: rgba(15, 175, 142, 0.9);
  color: #fff; font-size: 20rpx; border-radius: 4rpx;
}

.info { flex: 1; margin-left: 16rpx; display: flex; flex-direction: column; }
.title { font-size: 30rpx; font-weight: 600; line-height: 1.4; }
.summary {
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden; line-height: 1.4;
}
.meta { display: flex; gap: 16rpx; }
.meta .ml { margin-left: 16rpx; }

.footer { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.price .num { color: var(--danger); font-size: 36rpx; font-weight: 600; }
.price .unit { color: var(--danger); font-size: 22rpx; margin-left: 4rpx; }
.tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tag { padding: 2rpx 10rpx; background: #f0f9f6; color: var(--brand); font-size: 20rpx; border-radius: 4rpx; }

.loading, .end, .empty { padding: 40rpx 0; text-align: center; color: var(--text-tertiary); font-size: 24rpx; }
