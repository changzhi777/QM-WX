/* pages/cart/index.wxss — 购物车（参考图 2765） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 140rpx; }
.bg-white { background: #fff; }
.list { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }
.card { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; margin-bottom: 12rpx; border-radius: 12rpx; }
.check { width: 40rpx; height: 40rpx; border: 2rpx solid #ccc; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24rpx; }
.check.on { background: #0FAF8E; border-color: #0FAF8E; }
.info { flex: 1; min-width: 0; }
.name { font-size: 28rpx; color: #333; }
.price { font-size: 32rpx; color: #0FAF8E; font-weight: 600; margin: 8rpx 0; }
.qty-row { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; background: #f5f5f5; border-radius: 8rpx; font-size: 32rpx; color: #666; }
.qty-num { min-width: 48rpx; text-align: center; font-size: 28rpx; }
.footer { position: fixed; bottom: 0; left: 0; right: 0; display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-top: 1rpx solid #f0f0f0; box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04); }
.total { font-size: 28rpx; color: #666; }
.amount { font-size: 36rpx; font-weight: 600; color: #0FAF8E; }
.checkout-btn { background: #0FAF8E; color: #fff; padding: 16rpx 40rpx; border-radius: 8rpx; font-size: 28rpx; }
.loading { text-align: center; padding: 80rpx; color: #999; }
