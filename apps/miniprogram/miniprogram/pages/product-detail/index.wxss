.page { padding-bottom: 140rpx; }
.hero { width: 100%; height: 750rpx; background: #f0f0f0; }
.hero-img { width: 100%; height: 100%; }

.info .name { font-size: 32rpx; font-weight: 600; line-height: 1.4; }
.price-row { display: flex; align-items: baseline; gap: 8rpx; }
.price-num { color: var(--danger); font-size: 48rpx; font-weight: 600; }
.price-unit { color: var(--danger); font-size: 24rpx; }
.original { color: var(--text-tertiary); font-size: 24rpx; text-decoration: line-through; margin-left: 16rpx; }
.info .meta { display: flex; gap: 16rpx; }
.info .ml { margin-left: 16rpx; }

.section-title { font-size: 28rpx; font-weight: 600; }
.content-text { font-size: 28rpx; line-height: 1.6; }

.footer-placeholder { height: 140rpx; }
.footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 32rpx; box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.footer .btn-primary { height: 88rpx; line-height: 88rpx; }

.mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5);
  display: flex; align-items: flex-end; z-index: 999;
}
.sku-card {
  width: 100%; background: #fff; border-top-left-radius: 24rpx; border-top-right-radius: 24rpx;
  padding: 32rpx; box-sizing: border-box; position: relative;
}
.sku-img {
  width: 200rpx; height: 200rpx; border-radius: 8rpx;
  position: absolute; top: -60rpx; left: 32rpx; background: #f0f0f0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
.sku-info { margin-left: 232rpx; }
.sku-price .num { color: var(--danger); font-size: 40rpx; font-weight: 600; }
.sku-price .unit { color: var(--danger); font-size: 22rpx; }
.sku-stock { font-size: 24rpx; color: var(--text-tertiary); margin-top: 8rpx; }

.qty-row { display: flex; justify-content: space-between; align-items: center; margin: 40rpx 0 24rpx; }
.qty { display: flex; align-items: center; }
.qty-btn {
  width: 64rpx; height: 64rpx; line-height: 60rpx; text-align: center;
  background: #f0f0f0; border-radius: 8rpx; font-size: 32rpx;
}
.qty-input {
  width: 96rpx; height: 64rpx; text-align: center; font-size: 28rpx;
  margin: 0 8rpx; background: #f0f0f0; border-radius: 8rpx;
}

.empty, .loading { padding: 80rpx 0; text-align: center; color: var(--text-tertiary); }

/* 评价段（V0.1.113） */
.rating-summary { display: flex; align-items: baseline; gap: 4rpx; }
.rating-summary .avg { font-size: 40rpx; font-weight: 600; color: #ffb800; }
.rating-summary .avg-unit { font-size: 22rpx; color: var(--text-tertiary); }
.review-item { padding: 16rpx 0; border-top: 1rpx solid #f0f0f0; }
.review-head { display: flex; align-items: center; gap: 12rpx; }
.r-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f0f0f0; }
.r-name { font-size: 26rpx; color: #333; flex: 1; }
.r-stars { font-size: 24rpx; color: #ffb800; }
.r-content { font-size: 28rpx; color: #333; line-height: 1.5; margin-top: 8rpx; }
.no-review { text-align: center; font-size: 26rpx; color: var(--text-tertiary); padding: 24rpx 0; }
