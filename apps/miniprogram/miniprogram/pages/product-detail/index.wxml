<view class="page" wx:if="{{product}}">
  <swiper
    class="hero"
    indicator-dots="{{product.images.length > 1}}"
    autoplay="{{false}}"
    bindchange="onSwiperChange"
  >
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image class="hero-img" src="{{item || 'images/default-product.png'}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="info bg-white p-4">
    <view class="name">{{product.name}}</view>
    <view class="price-row mt-2">
      <text class="price-num">{{product.price}}</text>
      <text class="price-unit">元</text>
      <text class="original" wx:if="{{product.originalPrice && product.originalPrice !== product.price}}">
        ¥{{product.originalPrice}}
      </text>
    </view>
    <view class="meta text-sm text-secondary mt-2">
      <text>库存 {{product.stock}}</text>
      <text wx:if="{{product.brand}}" class="ml">{{product.brand}}</text>
    </view>
  </view>

  <view class="desc bg-white m-2 p-4 rounded-lg shadow" wx:if="{{product.description}}">
    <view class="section-title">商品介绍</view>
    <view class="content-text mt-2">{{product.description}}</view>
  </view>

  <view class="footer-placeholder" />

  <view class="footer bg-white">
    <block wx:if="{{canBuy}}">
      <button class="btn-primary" bindtap="onTapBuy">立即购买</button>
    </block>
    <block wx:else>
      <button class="btn-primary" bindtap="onTapBuy">立即兑换（支付开通中）</button>
    </block>
  </view>

  <!-- 数量选择弹窗 -->
  <view class="mask" wx:if="{{showSku}}" bindtap="onCloseSku">
    <view class="sku-card" catchtap="">
      <image class="sku-img" src="{{product.images[0] || 'images/default-product.png'}}" mode="aspectFill" />
      <view class="sku-info">
        <view class="sku-price">
          <text class="num">{{product.price}}</text>
          <text class="unit">元</text>
        </view>
        <view class="sku-stock">库存 {{product.stock}}</view>
      </view>
      <view class="qty-row">
        <text>购买数量</text>
        <view class="qty">
          <view class="qty-btn" bindtap="onMinus">−</view>
          <input class="qty-input" type="number" value="{{quantity}}" bindinput="onQuantityInput" />
          <view class="qty-btn" bindtap="onPlus">+</view>
        </view>
      </view>
      <button class="btn-primary" bindtap="onConfirm">确定</button>
    </view>
  </view>
</view>

<view wx:elif="{{!loading}}" class="empty">商品不存在或已下架</view>
<view wx:else class="loading">加载中...</view>
