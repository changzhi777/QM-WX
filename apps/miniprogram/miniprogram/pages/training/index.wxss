/* pages/training/index.wxss — 锻炼/训练中心（参考图 2775） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }

/* 标题 */
.header { padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; margin-bottom: 16rpx; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.header .subtitle { font-size: 26rpx; color: #999; margin-top: 8rpx; }

/* GO 跑步卡（品牌色渐变） */
.go-card {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  margin: 0 16rpx 16rpx; padding: 32rpx; border-radius: 16rpx; color: #fff;
}
.go-label { font-size: 28rpx; opacity: 0.9; margin-bottom: 20rpx; }
.target-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.target-opt { flex: 1; text-align: center; padding: 16rpx 0; background: rgba(255,255,255,0.2); border-radius: 8rpx; font-size: 26rpx; }
.target-opt.on { background: #fff; color: #2D9D78; font-weight: 600; }
.go-btn { background: #fff !important; color: #2D9D78; font-size: 36rpx; font-weight: 600; border-radius: 12rpx; line-height: 88rpx; }

/* 跑步汇总 */
.summary-card { background: #fff; margin: 0 16rpx 16rpx; padding: 24rpx; border-radius: 16rpx; display: flex; justify-content: space-around; }
.sum-item { text-align: center; }
.sum-item .v { font-size: 36rpx; font-weight: 600; color: #2D9D78; }
.sum-item .u { font-size: 22rpx; color: #999; margin-left: 4rpx; }

/* 分段 */
.section { margin: 0 16rpx 24rpx; }
.section-title { font-size: 28rpx; color: #666; margin-bottom: 16rpx; padding-left: 8rpx; }
.loading, .empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; background: #fff; border-radius: 16rpx; }

/* 训练计划横向滚动 */
.plan-scroll { white-space: nowrap; padding-bottom: 8rpx; }
.plan-card { display: inline-block; width: 280rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-right: 16rpx; vertical-align: top; box-sizing: border-box; position: relative; }
.plan-level { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; display: inline-block; margin-bottom: 12rpx; }
.plan-card.beginner .plan-level { background: #E6F7F2; color: #2D9D78; }
.plan-card.intermediate .plan-level { background: #E6F4FF; color: #1890ff; }
.plan-card.challenge .plan-level { background: #FFF7E6; color: #fa8c16; }
.plan-card.extreme .plan-level { background: #FFE6E6; color: #e64340; }
.plan-joined { position: absolute; top: 12rpx; right: 12rpx; background: #2D9D78; color: #fff; font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 12rpx; }
.plan-name { font-size: 30rpx; font-weight: 600; color: #333; }
.plan-weeks { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.plan-goal { font-size: 24rpx; color: #666; margin-top: 12rpx; }
.plan-mileage { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* 赛事卡 */
.marathon-card { background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 12rpx; display: flex; gap: 16rpx; }
.marathon-cover { width: 160rpx; height: 120rpx; border-radius: 8rpx; flex-shrink: 0; }
.marathon-info { flex: 1; min-width: 0; }
.marathon-name { font-size: 28rpx; font-weight: 600; color: #333; }
.marathon-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.marathon-summary { font-size: 22rpx; color: #888; margin-top: 6rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

/* 跑步记录 */
.record-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 12rpx; }
.record-head { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.record-source { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 6rpx; }
.record-source.garmin { background: #E6F7F2; color: #2D9D78; }
.record-source.manual { background: #f5f5f5; color: #999; }
.record-date { font-size: 22rpx; color: #999; }
.record-body { display: flex; gap: 40rpx; }
.metric { display: flex; align-items: baseline; gap: 4rpx; }
.metric .v { font-size: 32rpx; font-weight: 600; color: #333; }
.metric .u { font-size: 22rpx; color: #999; }

/* 我的训练计划进度卡（V0.1.41） */
.active-plan-card { background: #fff; margin: 0 16rpx 16rpx; padding: 24rpx; border-radius: 16rpx; }
.ap-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.ap-name { font-size: 30rpx; font-weight: 600; color: #333; }
.ap-leave { font-size: 24rpx; color: #e64340; padding: 4rpx 16rpx; border: 1rpx solid #e64340; border-radius: 20rpx; }
.ap-progress { display: flex; align-items: center; gap: 16rpx; }
.ap-bar { flex: 1; height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.ap-fill { height: 100%; background: linear-gradient(90deg, #2D9D78, #1a7a5a); border-radius: 8rpx; }
.ap-percent { font-size: 28rpx; font-weight: 600; color: #2D9D78; min-width: 80rpx; text-align: right; }
.ap-meta { font-size: 24rpx; color: #999; margin-top: 12rpx; }
.ap-done { font-size: 24rpx; color: #fa8c16; margin-top: 8rpx; }

/* V0.2.120 力量训练入口卡 */
.strength-entry {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.strength-entry__icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.strength-entry__body {
  flex: 1;
}
.strength-entry__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.strength-entry__desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.strength-entry__arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}
