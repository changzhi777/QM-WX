/* pages/group-buy-detail/index.wxss — 团购详情（V0.1.37）*/
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 140rpx; }
.loading { text-align: center; color: #999; padding: 160rpx 0; font-size: 28rpx; }

.hero-img { width: 100%; height: 600rpx; background: #f0f0f0; }

.info-card {
  background: #fff;
  margin-top: -16rpx;
  border-radius: 16rpx 16rpx 0 0;
  padding: 32rpx;
  position: relative;
  z-index: 2;
}
.name { font-size: 32rpx; font-weight: 600; color: #333; }
.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-top: 16rpx; }
.group-price { color: #e64340; font-size: 48rpx; font-weight: 600; }
.origin { color: #999; font-size: 24rpx; text-decoration: line-through; }

.progress-section { margin-top: 32rpx; }
.progress-text { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.progress-bar { height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #fa8c16, #ffa940); }
.progress-status { font-size: 24rpx; margin-top: 12rpx; color: #fa8c16; }
.progress-status.reached { color: #0faf8e; font-weight: 600; }

.desc { margin-top: 32rpx; font-size: 26rpx; color: #666; line-height: 1.6; }

.action-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 16rpx; padding: 16rpx 32rpx;
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}
.btn-buy, .btn-join {
  flex: 1; border-radius: 12rpx; font-size: 30rpx; line-height: 80rpx; padding: 0; margin: 0;
}
.btn-buy::after, .btn-join::after { border: none; }
.btn-buy { background: #f5f5f5; color: #666; }
.btn-join { background: #fa8c16; color: #fff; }
.btn-join.joined { background: #f0f0f0; color: #999; }
/* V0.1.37 团购下单按钮（成团后高亮）*/
.btn-gb { background: #e64340; color: #fff; font-weight: 600; }
.btn-gb::after { border: none; }
