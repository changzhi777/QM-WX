.page { padding-bottom: 140rpx; }
.hero { width: 100%; height: 400rpx; background: #f0f0f0; }

.info .title { font-size: 36rpx; font-weight: 600; }
.info .meta { display: flex; gap: 16rpx; }
.info .ml { margin-left: 16rpx; }
.info .tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.info .tag { padding: 4rpx 12rpx; background: #f0f9f6; color: var(--brand); font-size: 22rpx; border-radius: 4rpx; }

.section-title { font-size: 28rpx; font-weight: 600; }
.content-text { font-size: 28rpx; line-height: 1.6; color: var(--text-primary); }

.price-bar { display: flex; align-items: center; }
.price .num { color: var(--danger); font-size: 48rpx; font-weight: 600; }
.price .unit { color: var(--danger); font-size: 24rpx; margin-left: 4rpx; }

.footer-placeholder { height: 140rpx; }
.footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 32rpx; box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.footer .btn-primary { height: 88rpx; line-height: 88rpx; }

.mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.card {
  width: 640rpx; background: #fff; border-radius: 16rpx; padding: 40rpx;
}
.card .title { font-size: 32rpx; font-weight: 600; text-align: center; }
.field { margin: 16rpx 0; }
.label { display: block; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }
.input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;
}
.textarea { height: 140rpx; padding: 16rpx 20rpx; line-height: 1.4; }
.tip { font-size: 22rpx; color: var(--text-tertiary); text-align: center; margin: 8rpx 0 16rpx; }
.actions { display: flex; gap: 16rpx; }
.btn-cancel, .btn-primary {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 8rpx;
  text-align: center; font-size: 28rpx; border: none;
}
.btn-cancel { background: #f0f0f0; color: var(--text-primary); }
.btn-cancel::after, .btn-primary::after { border: none; }
.btn-primary { background: var(--brand); color: #fff; }

.empty, .loading { padding: 80rpx 0; text-align: center; color: var(--text-tertiary); }

/* ===== V0.1.134 赛事 tab + 排行榜 + 我的成绩 ===== */

.race-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
  margin: 16rpx 0;
}

.race-tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.race-tab.active {
  color: var(--brand);
  font-weight: 600;
}

.race-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: var(--brand);
}

/* 详情 tab - 赛事信息 KV */
.kv-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.kv-key { color: var(--text-secondary); }
.kv-val { color: var(--text-primary); font-weight: 500; }

.rules { padding-top: 12rpx; border-top: 1rpx dashed #eee; }
.rules-label { color: var(--text-secondary); font-size: 26rpx; }
.rules-text { color: var(--text-primary); font-size: 26rpx; line-height: 1.6; }

/* 路线 tab */
.route-text { font-size: 28rpx; line-height: 1.6; color: var(--text-primary); white-space: pre-wrap; }
.route-empty { text-align: center; padding: 40rpx 0; color: var(--text-tertiary); }

/* 排行榜 tab */
.lb-loading,
.lb-empty { text-align: center; padding: 60rpx 0; color: var(--text-tertiary); }
.lb-empty .lb-tip { display: block; font-size: 24rpx; color: var(--text-quaternary); margin-top: 12rpx; }

.lb-list { margin-top: 16rpx; }

.lb-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.lb-row.lb-top { background: #fffbf0; padding-left: 12rpx; padding-right: 12rpx; border-radius: 8rpx; border-bottom: none; margin-bottom: 8rpx; }

.lb-rank {
  width: 48rpx;
  text-align: center;
  font-weight: 700;
  font-size: 28rpx;
  color: #999;
}

.lb-top .lb-rank { color: #ef4444; font-size: 32rpx; }

.lb-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #eee; }

.lb-name { flex: 1; font-size: 26rpx; color: var(--text-primary); }

.lb-time { font-size: 24rpx; color: var(--text-primary); font-weight: 600; }
.lb-pace { font-size: 22rpx; color: var(--text-secondary); width: 120rpx; text-align: right; }

/* 我的 tab */
.my-result { margin-top: 16rpx; }

.my-empty {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-tertiary);
}

.btn-self-report {
  margin-top: 24rpx;
  background: var(--brand);
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

.btn-self-report::after { border: none; }

.finisher-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background: #eee;
}
