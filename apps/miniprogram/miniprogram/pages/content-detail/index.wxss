.page { padding-bottom: 140rpx; }
.hero { width: 100%; height: 400rpx; background: #f0f0f0; }

.info .title { font-size: 36rpx; font-weight: 600; }
.info .meta { display: flex; gap: 16rpx; }
.info .ml { margin-left: 16rpx; }
.info .tags { display: flex; gap: 8rpx; flex-wrap: wrap; }
.info .tag { padding: 4rpx 12rpx; background: #f0f9f6; color: var(--brand); font-size: 22rpx; border-radius: 4rpx; }

.section-title { font-size: 28rpx; font-weight: 600; }
.content-text { font-size: 28rpx; line-height: 1.6; color: var(--text-primary); }

.price-bar { display: flex; align-items: center; }
.price .num { color: var(--danger); font-size: 48rpx; font-weight: 600; }
.price .unit { color: var(--danger); font-size: 24rpx; margin-left: 4rpx; }

.footer-placeholder { height: 140rpx; }
.footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 32rpx; box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.footer .btn-primary { height: 88rpx; line-height: 88rpx; }

.mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.card {
  width: 640rpx; background: #fff; border-radius: 16rpx; padding: 40rpx;
}
.card .title { font-size: 32rpx; font-weight: 600; text-align: center; }
.field { margin: 16rpx 0; }
.label { display: block; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }
.input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;
}
.textarea { height: 140rpx; padding: 16rpx 20rpx; line-height: 1.4; }
.tip { font-size: 22rpx; color: var(--text-tertiary); text-align: center; margin: 8rpx 0 16rpx; }
.actions { display: flex; gap: 16rpx; }
.btn-cancel, .btn-primary {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 8rpx;
  text-align: center; font-size: 28rpx; border: none;
}
.btn-cancel { background: #f0f0f0; color: var(--text-primary); }
.btn-cancel::after, .btn-primary::after { border: none; }
.btn-primary { background: var(--brand); color: #fff; }

.empty, .loading { padding: 80rpx 0; text-align: center; color: var(--text-tertiary); }
