.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.empty { padding: 120rpx 0; text-align: center; color: var(--text-tertiary); font-size: 28rpx; }
.card { }
.prod { display: flex; align-items: center; gap: 16rpx; }
.prod-img { width: 80rpx; height: 80rpx; border-radius: 8rpx; background: #f0f0f0; flex-shrink: 0; }
.prod-name { font-size: 28rpx; color: #333; flex: 1; }
.prod .arrow { color: var(--text-tertiary); font-size: 32rpx; }
.rating { font-size: 24rpx; color: #ffb800; margin-top: 12rpx; }
.content { font-size: 28rpx; color: #333; line-height: 1.5; margin-top: 8rpx; }
.loading-more, .no-more { text-align: center; color: var(--text-tertiary); font-size: 24rpx; padding: 24rpx 0; }
