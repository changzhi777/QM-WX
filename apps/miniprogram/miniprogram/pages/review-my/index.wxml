<view class="page">
  <view class="empty" wx:if="{{!loading && list.length === 0}}">还没有写过评价</view>

  <view
    class="card bg-white m-2 p-4 rounded-lg shadow"
    wx:for="{{list}}"
    wx:key="id"
    data-id="{{item.product.id}}"
    bindtap="onTap"
  >
    <view class="prod">
      <image class="prod-img" src="{{item.product.images[0] || '/images/default-product.png'}}" mode="aspectFill" />
      <view class="prod-name">{{item.product.name}}</view>
      <view class="arrow">›</view>
    </view>
    <view class="rating">{{item.rating}}★ · {{item.createdAt}}</view>
    <view class="content" wx:if="{{item.content}}">{{item.content}}</view>
  </view>

  <view class="loading-more" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
</view>
