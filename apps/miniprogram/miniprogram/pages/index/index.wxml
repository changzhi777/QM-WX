<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="loadData" />

  <block wx:if="{{!error}}">
  <!-- Hero 品牌色渐变（V0.1.35 视觉锚点）-->
  <view class="hero">
    <block wx:if="{{isLogin && user}}">
      <view class="hero-user" bindtap="goProfile">
        <image class="hero-avatar" src="{{user.avatarUrl || 'images/default-avatar.png'}}" mode="aspectFill" />
        <view class="hero-info">
          <view class="hero-name">{{user.nickname || '跑者'}}</view>
          <view class="hero-desc">欢迎来到青沐运动 · 继续奔跑 🏃</view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="hero-title">欢迎来到青沐运动</view>
      <view class="hero-desc">运动 · 社群 · 商城</view>
      <view class="hero-actions">
        <view class="link" bindtap="goMine">登录享更多 →</view>
      </view>
    </block>
  </view>

  <!-- 本周数据卡（覆盖 hero 底部，悬浮效果）-->
  <view class="stats-card" wx:if="{{isLogin}}">
    <view class="stats-label">本周数据</view>
    <view class="stats-row" bindtap="goSport">
      <view class="stats-item">
        <view class="stats-num">{{userStats.totalDistance}}</view>
        <view class="stats-unit">公里</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{userStats.totalCheckins}}</view>
        <view class="stats-unit">打卡</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{userStats.totalPoints}}</view>
        <view class="stats-unit">积分</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{userStats.avgPace || '-'}}</view>
        <view class="stats-unit">配速</view>
      </view>
    </view>
  </view>

  <!-- 两大中心引导（运动/商城，导流 tab）-->
  <view class="redirect-card">
    <view class="redirect-row" bindtap="goSport">
      <view class="redirect-icon">🏃</view>
      <view class="redirect-text">
        <view class="redirect-title">运动中心</view>
        <view class="redirect-desc">打卡 · 跑鞋 · 目标 · 健康 · 训练</view>
      </view>
      <view class="redirect-arrow">›</view>
    </view>
    <view class="redirect-row" bindtap="goMall">
      <view class="redirect-icon">🛒</view>
      <view class="redirect-text">
        <view class="redirect-title">商城中心</view>
        <view class="redirect-desc">商品 · 购物车 · 优惠券 · 订单</view>
      </view>
      <view class="redirect-arrow">›</view>
    </view>
  </view>

  <!-- 快捷入口（高频 page，entry-grid 渲染）-->
  <entry-grid title="⚡ 快捷入口" items="{{quickEntries}}" />

  <feature-gate flag="wallet">
    <view class="wallet-card" bindtap="goMine">
      <view class="wallet-text">💰 我的钱包</view>
      <view class="wallet-arrow">›</view>
    </view>
  </feature-gate>
  </block>

  <privacy-popup visible="{{showPrivacy}}" bind:agree="onPrivacyAgree" />
</view>
