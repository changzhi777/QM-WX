<view class="page">
  <!-- V0.2.9 UV 强提示黄条（prototype 借鉴） -->
  <uv-alert wx:if="{{uv && uvShow}}" uv="{{uv}}" bind:close="onCloseUv" />

  <!-- 头部：渐变绿 + 问候 + 健康分数环 -->
  <view class="today-header">
    <view class="greeting">{{greeting}}</view>
    <view class="date-weather" wx:if="{{dateStr}}">
      <text class="date">{{dateStr}} {{weekday}}</text>
      <text wx:if="{{weather}}" class="weather">{{weather.icon}} {{weather.city}} · {{weather.text}} {{weather.temperature}}°C</text>
      <text wx:if="{{altitude !== null}}" class="altitude">🏔 {{altitude}}m</text>
    </view>
    <view class="score-ring">
      <view class="score-inner">
        <view class="score-num">{{score.score || '--'}}</view>
        <view class="score-label">健康分数</view>
      </view>
    </view>
    <view class="trend" wx:if="{{score.trend}}">
      <block wx:if="{{score.trend.diff > 0}}"><text class="up">↑ 较昨日 +{{score.trend.diff}}</text></block>
      <block wx:elif="{{score.trend.diff < 0}}"><text class="down">↓ 较昨日 {{score.trend.diff}}</text></block>
      <block wx:else><text>较昨日持平</text></block>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <block wx:elif="{{report}}">
    <!-- 健康解读卡：摘要 + 查看完整报告 + 解锁 -->
    <view class="ai-card">
      <view class="ai-header">
        <text class="ai-badge">✨ AI解读</text>
        <text class="ai-title">今日身体简报</text>
        <text class="free-tag" wx:if="{{!isMember}}">免费用户</text>
      </view>
      <view class="ai-body">{{reportSummary}}</view>
      <view class="ai-alert" wx:if="{{report.alertText}}">⚠️ {{report.alertText}}</view>
      <view class="ai-footer">
        <view class="ai-action-btn primary" bindtap="goReportDetail">查看完整报告 →</view>
        <view class="ai-action-btn unlock" wx:if="{{!isMember}}" bindtap="goMembership">解锁完整版 👑</view>
      </view>
    </view>

    <!-- 运动与天气建议（stats.weatherAnalysis insights）-->
    <view class="weather-advice-card" wx:if="{{weatherAdvice.length}}">
      <view class="advice-title">🌡️ 运动与天气建议</view>
      <view class="advice-item" wx:for="{{weatherAdvice}}" wx:key="*this">{{item}}</view>
    </view>

    <!-- 3 数据卡 -->
    <view class="data-row" wx:if="{{score}}">
      <view class="data-card">
        <view class="icon">👟</view>
        <view class="value">{{score.steps}}</view>
        <view class="label">今日步数</view>
      </view>
      <view class="data-card">
        <view class="icon">❤️</view>
        <view class="value">{{score.restingHr || '--'}}</view>
        <view class="label">静息心率</view>
      </view>
      <view class="data-card">
        <view class="icon">😴</view>
        <view class="value">{{score.sleepHours || '--'}}</view>
        <view class="label">昨晚睡眠</view>
      </view>
    </view>

    <!-- 本周趋势（柱顶数值 + 柱底日期）-->
    <view class="section-title" wx:if="{{weekTrend.length}}">本周趋势 <text class="more" bindtap="goMonthlyReport">查看月度 →</text></view>
    <view class="week-chart" wx:if="{{weekTrend.length}}">
      <view class="bars">
        <view class="bar-item" wx:for="{{weekTrend}}" wx:key="index">
          <view class="bar-wrap">
            <view class="bar-col" style="height:{{item.score}}%">
              <text class="bar-val">{{item.score}}</text>
              <view class="bar"></view>
            </view>
          </view>
          <text class="bar-date">{{item.date}}</text>
        </view>
      </view>
    </view>

    <!-- 历史报告（默认 7 日；更多历史进月度报告页，入口在本周趋势标题）-->
    <view class="section-title" wx:if="{{history.length}}">
      历史报告
    </view>
    <view class="history-list" wx:if="{{history.length}}">
      <van-cell-group>
        <van-cell
          wx:for="{{history}}"
          wx:key="id"
          title="{{item.date}}"
          label="{{item.reportText}}"
          value="{{item.healthScore}} 分"
          data-date="{{item.date}}"
          bindtap="onTapHistory"
          is-link
        />
      </van-cell-group>
    </view>
  </block>

  <view class="empty" wx:else>
    <view class="empty-icon">📊</view>
    <view>暂无健康数据</view>
    <view class="empty-tip">绑定设备后查看今日简报</view>
  </view>

  <privacy-popup visible="{{showPrivacy}}" bind:agree="onPrivacyAgree" />
</view>
