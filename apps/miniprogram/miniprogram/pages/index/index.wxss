/* pages/index/index.wxss — 今日 tab（V0.1.144 原型图 + V0.2.4 健康中心改版）*/
.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }

/* 头部：渐变绿 + 健康分数环 */
.today-header {
  background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%);
  color: #fff;
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}
.greeting { font-size: 32rpx; font-weight: 600; opacity: 0.95; margin-bottom: 16rpx; }
.date-weather { display: flex; justify-content: center; gap: 24rpx; margin-bottom: 24rpx; font-size: 24rpx; opacity: 0.85; }
.date-weather .weather { color: rgba(255,255,255,0.9); }
.date-weather .altitude { color: rgba(255,255,255,0.85); }
.score-ring {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto;
  border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.25);
  border-top: 8rpx solid #fff;
  border-right: 8rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(45deg);
}
.score-inner { transform: rotate(-45deg); }
.score-num { font-size: 72rpx; font-weight: 700; line-height: 1; }
.score-label { font-size: 22rpx; opacity: 0.8; margin-top: 8rpx; }
.trend { margin-top: 24rpx; font-size: 24rpx; opacity: 0.9; }
.trend .up { color: #fff; }
.trend .down { color: #ffd5d0; }

.loading { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

/* 健康解读卡 */
.ai-card {
  background: #fff;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}
.ai-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.ai-badge {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.ai-title { font-size: 28rpx; font-weight: 600; color: #333; flex: 1; }
.free-tag { font-size: 18rpx; color: #b8860b; background: #fff8e1; padding: 2rpx 12rpx; border-radius: 10rpx; }
.ai-body { font-size: 26rpx; color: #555; line-height: 1.7; }
.ai-alert {
  margin-top: 16rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #795548;
  line-height: 1.5;
}
.ai-footer { margin-top: 20rpx; display: flex; gap: 16rpx; }
.ai-action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 0;
  border-radius: 24rpx;
}
.ai-action-btn.primary {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(45,157,120,0.25);
}
.ai-action-btn.unlock {
  background: #fff8e1;
  color: #b8860b;
  border: 1rpx solid #ffe082;
}

/* 运动与天气建议卡（stats.weatherAnalysis insights）*/
.weather-advice-card { margin: 0 24rpx 24rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border-left: 6rpx solid #2D9D78; }
.advice-title { font-size: 28rpx; font-weight: 600; margin-bottom: 12rpx; color: #333; }
.advice-item { font-size: 26rpx; color: #555; line-height: 1.6; margin-bottom: 8rpx; }
.advice-item:last-child { margin-bottom: 0; }

/* 3 数据卡 */
.data-row { display: flex; gap: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx; }
.data-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.data-card .icon { font-size: 36rpx; }
.data-card .value { font-size: 40rpx; font-weight: 700; color: #333; margin: 8rpx 0; }
.data-card .label { font-size: 22rpx; color: #999; }

/* 本周趋势（柱顶数值）*/
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 32rpx 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-title .more { font-size: 24rpx; color: #2D9D78; font-weight: 400; }
.week-chart { background: #fff; margin: 0 24rpx 24rpx; border-radius: 16rpx; padding: 24rpx; }
.bars { display: flex; align-items: stretch; height: 240rpx; gap: 12rpx; }
.bar-item { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; }
.bar-wrap { flex: 1; width: 100%; display: flex; align-items: flex-end; }
.bar-col { width: 100%; display: flex; flex-direction: column; align-items: center; }
.bar-val { font-size: 20rpx; color: #2D9D78; font-weight: 600; margin-bottom: 4rpx; }
.bar { width: 100%; flex: 1; background: linear-gradient(180deg, #2D9D78, #1a7a5a); border-radius: 8rpx 8rpx 0 0; min-height: 8rpx; }
.bar-date { font-size: 18rpx; color: #999; height: 32rpx; line-height: 32rpx; }

/* 历史 健康报告 */
.history-list { padding: 0 24rpx; }

/* 空态 */
.empty { text-align: center; padding: 120rpx 40rpx; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-tip { font-size: 22rpx; color: #bbb; margin-top: 12rpx; }

/* P1 打卡快捷卡（sport.today 状态）*/
.checkin-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(45,157,120,0.25);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.checkin-card .checkin-icon { font-size: 40rpx; }
.checkin-card .checkin-info { flex: 1; }
.checkin-card .checkin-title { font-size: 30rpx; font-weight: 600; color: #fff; }
.checkin-card .checkin-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 4rpx; }
.checkin-card .checkin-arrow { font-size: 24rpx; color: #fff; }

/* P3 饮食摘要卡（food.myMeals 今日宏量，白卡 + 品牌色左框）*/
.diet-card {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #2D9D78;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.diet-card .diet-icon { font-size: 36rpx; }
.diet-card .diet-info { flex: 1; }
.diet-card .diet-title { font-size: 28rpx; font-weight: 600; color: #333; }
.diet-card .diet-sub { font-size: 24rpx; color: #666; margin-top: 4rpx; }
.diet-card .diet-arrow { color: #ccc; font-size: 32rpx; }

/* P3 3 数据卡点击反馈 */
.data-row-hover { opacity: 0.7; }
