.page { padding: 16rpx 0 60rpx; }
.hero-actions { margin-top: 16rpx; }
.link { color: var(--brand); font-size: 26rpx; }

.quick-grid { display: flex; gap: 16rpx; }
.quick-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 0; background: #f8f8f8; border-radius: 8rpx;
}
.q-icon { font-size: 48rpx; }
.q-text { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }
