/* pages/index/index.wxss — 今日 tab（V0.1.144 按原型图重设计）*/
.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }

/* 头部：渐变绿 + 健康分数环 */
.today-header {
  background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%);
  color: #fff;
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}
.greeting { font-size: 28rpx; opacity: 0.9; margin-bottom: 16rpx; }
.date-weather { display: flex; justify-content: center; gap: 24rpx; margin-bottom: 24rpx; font-size: 24rpx; opacity: 0.85; }
.date-weather .weather { color: rgba(255,255,255,0.9); }
.date-weather .altitude { color: rgba(255,255,255,0.85); }
.location { text-align: center; font-size: 20rpx; opacity: 0.7; margin-bottom: 20rpx; }
.score-ring {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto;
  border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.25);
  border-top: 8rpx solid #fff;
  border-right: 8rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(45deg);
}
.score-inner { transform: rotate(-45deg); }
.score-num { font-size: 72rpx; font-weight: 700; line-height: 1; }
.score-label { font-size: 22rpx; opacity: 0.8; margin-top: 8rpx; }
.trend { margin-top: 24rpx; font-size: 24rpx; opacity: 0.9; }
.trend .up { color: #fff; }
.trend .down { color: #ffd5d0; }

.loading { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

/* AI 解读卡 */
.ai-card {
  background: #fff;
  margin: -40rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}
.ai-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.ai-badge {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.ai-title { font-size: 28rpx; font-weight: 600; color: #333; }
.ai-body { font-size: 26rpx; color: #555; line-height: 1.7; }
.ai-alert {
  margin-top: 16rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
  color: #795548;
  line-height: 1.5;
}
.ai-footer { margin-top: 20rpx; }
.ai-btn {
  background: #f0f7f4;
  color: #2D9D78;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: inline-block;
}

/* 3 数据卡 */
.data-row { display: flex; gap: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx; }
.data-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.data-card .icon { font-size: 36rpx; }
.data-card .value { font-size: 40rpx; font-weight: 700; color: #333; margin: 8rpx 0; }
.data-card .label { font-size: 22rpx; color: #999; }

/* 本周趋势 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 32rpx 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-title .more { font-size: 22rpx; color: #999; font-weight: 400; }
.week-chart { background: #fff; margin: 0 24rpx 24rpx; border-radius: 16rpx; padding: 24rpx; }
.bars { display: flex; align-items: flex-end; height: 200rpx; gap: 12rpx; }
.bar-item { flex: 1; display: flex; align-items: flex-end; height: 100%; }
.bar { width: 100%; background: #2D9D78; border-radius: 8rpx 8rpx 0 0; min-height: 8rpx; opacity: 0.8; }

/* 历史 AI 报告 */
.history-list { padding: 0 24rpx; }
.history-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.history-item .left { flex: 1; overflow: hidden; }
.history-item .date { font-size: 22rpx; color: #999; }
.history-item .summary {
  font-size: 24rpx;
  color: #555;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.his-score { font-size: 44rpx; font-weight: 700; color: #2D9D78; }

/* 空态 */
.empty { text-align: center; padding: 120rpx 40rpx; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-tip { font-size: 22rpx; color: #bbb; margin-top: 12rpx; }
