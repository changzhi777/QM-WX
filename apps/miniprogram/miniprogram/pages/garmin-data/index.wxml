<view class="page">
  <!-- 标题 -->
  <view class="header bg-white">
    <view class="title">佳明运动数据</view>
    <view class="subtitle">审核佳明活动 → 导入跑群榜单</view>
  </view>

  <!-- Tab：待处理 / 已处理 -->
  <view class="tabs bg-white">
    <view class="tab {{tab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待处理</view>
    <view class="tab {{tab === 'processed' ? 'active' : ''}}" bindtap="switchTab" data-tab="processed">已处理</view>
  </view>

  <!-- 爬升补偿开关（参考图 2769，UI 占位） -->
  <view class="opt-row bg-white" bindtap="toggleClimb">
    <text>开启爬升补偿</text>
    <switch checked="{{climbCompensation}}" color="#0FAF8E" disabled />
  </view>

  <!-- 列表 -->
  <view class="list" wx:if="{{!loading}}">
    <view wx:if="{{list.length === 0}}" class="empty">暂无{{tab === 'pending' ? '待处理' : '已处理'}}活动</view>

    <view class="card bg-white" wx:for="{{list}}" wx:key="id">
      <view class="card-head">
        <text class="type">{{item.sportType}}</text>
        <text class="time">{{item.startTime}}</text>
      </view>
      <view class="card-body">
        <view class="metric"><text class="v">{{item.distanceKm}}</text><text class="u">km</text></view>
        <view class="metric"><text class="v">{{item.durationMin}}</text><text class="u">min</text></view>
        <view class="metric" wx:if="{{item.avgHr}}"><text class="v">{{item.avgHr}}</text><text class="u">bpm</text></view>
      </view>

      <!-- 已处理：状态徽标 -->
      <view class="card-status" wx:if="{{tab === 'processed'}}">
        <text class="badge {{item.status}}">{{item.status === 'imported' ? '已导入榜单' : '已忽略'}}</text>
      </view>

      <!-- 待处理：导入 / 忽略 -->
      <view class="card-actions" wx:else>
        <button class="btn-import" data-id="{{item.id}}" bindtap="onImport">导入榜单</button>
        <button class="btn-ignore" data-id="{{item.id}}" bindtap="onIgnore">忽略</button>
      </view>
    </view>
  </view>

  <view class="loading" wx:else>加载中...</view>
</view>
