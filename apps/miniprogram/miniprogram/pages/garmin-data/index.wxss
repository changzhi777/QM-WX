/* pages/garmin-data/index.wxss — 佳明数据处理（参考图 2769） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }
.header { padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.header .subtitle { font-size: 26rpx; color: #999; margin-top: 8rpx; }
.tabs { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; }
.tab.active { color: #0FAF8E; font-weight: 600; border-bottom: 4rpx solid #0FAF8E; }
.opt-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx; color: #333;
}
.list { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 80rpx 0; font-size: 28rpx; }
.card { border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-head { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.card-head .type { font-size: 30rpx; font-weight: 600; color: #0FAF8E; text-transform: capitalize; }
.card-head .time { font-size: 24rpx; color: #999; }
.card-body { display: flex; gap: 40rpx; margin-bottom: 16rpx; }
.metric { display: flex; align-items: baseline; gap: 4rpx; }
.metric .v { font-size: 34rpx; font-weight: 600; color: #333; }
.metric .u { font-size: 22rpx; color: #999; }
.card-status { padding-top: 12rpx; border-top: 1rpx solid #f0f0f0; }
.badge { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; }
.badge.imported { background: #E6F7F2; color: #0FAF8E; }
.badge.ignored { background: #f5f5f5; color: #999; }
.card-actions { display: flex; gap: 16rpx; padding-top: 12rpx; border-top: 1rpx solid #f0f0f0; }
.btn-import, .btn-ignore { flex: 1; font-size: 26rpx; border-radius: 8rpx; margin: 0; line-height: 64rpx; padding: 0; }
.btn-import { background: #0FAF8E; color: #fff; }
.btn-ignore { background: #f5f5f5; color: #666; }
.loading { text-align: center; padding: 80rpx; color: #999; }
