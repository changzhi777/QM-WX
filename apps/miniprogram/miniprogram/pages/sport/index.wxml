<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="loadAll" />

  <!-- 正常内容（error 时隐藏） -->
  <block wx:if="{{!error}}">
  <!-- 今日打卡卡 -->
  <view class="checkin-card bg-white m-2 p-4 rounded-lg shadow">
    <view class="title-row">
      <view class="title">今日打卡</view>
      <view class="date">{{today}}</view>
    </view>

    <block wx:if="{{todayDone}}">
      <view class="done">
        <view class="check-icon">✓</view>
        <view class="done-title">今日已打卡</view>
        <view class="done-stats" wx:if="{{todayCheckin}}">
          <view class="stat"><text class="stat-val">{{todayCheckin.distance}}</text><text class="stat-unit">km</text></view>
          <view class="stat"><text class="stat-val">{{todayCheckin.pace}}</text><text class="stat-unit">配速</text></view>
          <view class="stat"><text class="stat-val">+{{todayCheckin.points}}</text><text class="stat-unit">积分</text></view>
        </view>
        <view class="tip">明天再来吧！</view>
        <button class="share-btn" open-type="share">分享成就 📤</button>
      </view>
    </block>

    <block wx:else>
      <!-- V0.3 GPS 跑步记录 -->
      <view class="gps-bar" wx:if="{{!gpsRunning}}">
        <button class="gps-btn" bindtap="startGpsRun">📍 GPS 跑步记录（自动算距离）</button>
      </view>
      <view class="gps-running" wx:if="{{gpsRunning}}">
        <view class="gps-live">
          <view class="gps-stat"><text class="gps-val">{{gpsDistance}}</text><text class="gps-unit">km</text></view>
          <view class="gps-stat"><text class="gps-val">{{gpsDuration}}</text><text class="gps-unit">秒</text></view>
        </view>
        <button class="gps-stop-btn" bindtap="stopGpsRun">⏹ 停止并填入表单</button>
      </view>

      <view class="form">
        <view class="field">
          <text class="label">距离 (km) *</text>
          <input class="input" type="digit" placeholder="0.5 ~ 50" value="{{form.distance}}" bindinput="onInputDistance" />
        </view>
        <view class="field">
          <text class="label">时长 (分钟)</text>
          <input class="input" type="digit" placeholder="选填，自动算配速" value="{{form.durationMin}}" bindinput="onInputDuration" />
        </view>
        <view class="field">
          <text class="label">配速 (mm:ss)</text>
          <view class="pace">{{form.pace || '—'}}</view>
        </view>
        <view class="row">
          <view class="field-half">
            <text class="label">心率</text>
            <input class="input" type="number" placeholder="选填" value="{{form.heartRate}}" bindinput="onInputHeartRate" />
          </view>
          <view class="field-half">
            <text class="label">步频</text>
            <input class="input" type="number" placeholder="选填" value="{{form.cadence}}" bindinput="onInputCadence" />
          </view>
        </view>
        <view class="field" wx:if="{{shoes.length > 1}}">
          <text class="label">跑鞋</text>
          <picker mode="selector" range="{{shoes}}" range-key="name" value="{{shoeIndex}}" bindchange="onShoeChange">
            <view class="picker">{{shoes[shoeIndex].name}} <text class="arrow-sm">›</text></view>
          </picker>
        </view>
        <view class="field" wx:if="{{groups.length > 1}}">
          <text class="label">归属群</text>
          <picker mode="selector" range="{{groups}}" range-key="name" value="{{groupIndex}}" bindchange="onGroupChange">
            <view class="picker">{{groups[groupIndex].name}} <text class="arrow-sm">›</text></view>
          </picker>
        </view>
        <van-button type="primary" block bindtap="onSubmitCheckin" disabled="{{submitting}}" loading="{{submitting}}" custom-style="margin-top:16rpx">
          {{submitting ? '提交中...' : '打卡'}}
        </van-button>
      </view>
    </block>
  </view>

  <!-- 我的群 -->
  <view class="groups bg-white m-2 p-4 rounded-lg shadow">
    <view class="title-row">
      <view class="title">我的群</view>
      <view class="actions">
        <view class="link" bindtap="onTapJoinGroup">加入</view>
        <view class="link" bindtap="onTapCreateGroup">创建</view>
      </view>
    </view>

    <block wx:if="{{groups.length <= 1}}">
      <view class="empty">还没有群，去创建或加入一个吧</view>
    </block>
    <block wx:else>
      <view
        class="group-item"
        wx:for="{{groups}}"
        wx:key="id"
        wx:for-index="idx"
        data-id="{{item.id}}"
        bindtap="goGroup"
        wx:if="{{idx > 0}}"
      >
        <view class="g-info">
          <view class="g-name">{{item.name}}</view>
          <view class="g-meta">{{item.memberCount}} 人 · {{item.role === 'owner' ? '群主' : '成员'}}</view>
        </view>
        <view class="arrow">›</view>
      </view>
    </block>
  </view>

  <!-- V0.1.35 运动入口网格（功能从 mine 分散到运动 tab）-->
  <entry-grid title="运动工具" items="{{sportTools}}" />
  <entry-grid title="数据榜单" items="{{dataRanks}}" />
  <entry-grid title="健康设备" items="{{healthDevices}}" />
  <entry-grid title="社交赛事" items="{{socialEvents}}" />

  <!-- 创建群弹窗 -->
  <view class="mask" wx:if="{{showCreateGroup}}" bindtap="onCancelCreate">
    <view class="card" catchtap="">
      <view class="title">创建跑群</view>
      <input class="input mt-2" placeholder="群名（最多 32 字）" value="{{newGroupName}}" maxlength="32" bindinput="onInputGroupName" />
      <view class="actions mt-2">
        <button class="btn-cancel" bindtap="onCancelCreate">取消</button>
        <button class="btn-primary" bindtap="onConfirmCreate">创建</button>
      </view>
    </view>
  </view>
  </block>
</view>
