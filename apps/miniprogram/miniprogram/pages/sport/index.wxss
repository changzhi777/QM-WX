.page { padding-bottom: 60rpx; background: #f5f6f8; }

.checkin-card { border-radius: 16rpx !important; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06) !important; }
.checkin-card .title-row, .groups .title-row {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx;
}
.checkin-card .title-row {
  border-bottom: 3rpx solid #2D9D78;
  padding-bottom: 12rpx;
}
.title-row .title { font-size: 32rpx; font-weight: 600; color: #333; }
.title-row .date { font-size: 24rpx; color: #999; }
.title-row .actions { display: flex; gap: 24rpx; }
.title-row .link { font-size: 26rpx; color: #2D9D78; }

.done {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0; color: #2D9D78;
}
.check-icon {
  width: 96rpx; height: 96rpx; line-height: 96rpx; border-radius: 50%;
  background: #2D9D78; color: #fff; text-align: center;
  font-size: 52rpx; margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(45,157,120,0.3);
}
.tip { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* P3 打卡完成详情卡（2.7 精简：distance/pace/积分 3 stat）*/
.done .done-title { font-size: 30rpx; font-weight: 600; color: #333; margin-top: 8rpx; }
.done-stats { display: flex; gap: 40rpx; margin: 24rpx 0 8rpx; }
.done-stats .stat { text-align: center; }
.done-stats .stat-val { display: block; font-size: 36rpx; font-weight: 700; color: #2D9D78; }
.done-stats .stat-unit { font-size: 22rpx; color: #999; }

/* P3 打卡成就分享按钮（2.7 分享子项）*/
.share-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 24rpx;
  padding: 16rpx 40rpx;
  line-height: 1.5;
  border: none;
}
.share-btn::after { border: none; }

.form .field { margin: 20rpx 0; }
.form .row { display: flex; gap: 16rpx; }
.form .field-half { flex: 1; }
.form .label { display: block; font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.form .input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #f5f6f8; border-radius: 12rpx; font-size: 28rpx;
  box-sizing: border-box;
}
.form .pace {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: #f5f6f8; border-radius: 12rpx; font-size: 28rpx; color: #2D9D78; font-weight: 600;
}
.form .picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: #f5f6f8; border-radius: 12rpx; font-size: 28rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.arrow-sm { color: var(--text-tertiary); }

.groups .empty { padding: 40rpx 0; text-align: center; color: var(--text-tertiary); font-size: 26rpx; }
.group-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 0; border-top: 1rpx solid var(--border);
}
.group-item .g-info { flex: 1; }
.group-item .g-name { font-size: 30rpx; }
.group-item .g-meta { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.group-item .arrow { color: var(--text-tertiary); font-size: 32rpx; }

.mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.card {
  width: 600rpx; background: #fff; border-radius: 16rpx;
  padding: 40rpx;
}
.card .title { font-size: 32rpx; font-weight: 600; text-align: center; }
.card .input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;
}
.card .actions { display: flex; gap: 16rpx; }
.card .btn-cancel, .card .btn-primary {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 8rpx;
  text-align: center; font-size: 28rpx; border: none;
}
.card .btn-cancel { background: #f0f0f0; color: var(--text-primary); }
.card .btn-cancel::after, .card .btn-primary::after { border: none; }
.card .btn-primary { background: var(--brand); color: #fff; }
