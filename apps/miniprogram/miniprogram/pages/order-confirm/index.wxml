<view class="page" wx:if="{{product}}">
  <!-- 商品 -->
  <view class="goods bg-white m-2 p-4 rounded-lg shadow flex">
    <image class="cover" src="{{product.images[0] || '/images/default-product.png'}}" mode="aspectFill" />
    <view class="info">
      <view class="name">{{product.name}}</view>
      <view class="price-row">
        <text class="num">{{product.price}}</text>
        <text class="unit">元 × {{quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 积分抵扣 -->
  <view class="section bg-white m-2 p-4 rounded-lg shadow">
    <view class="row">
      <view class="lbl">使用积分</view>
      <switch checked="{{usePoints}}" bindchange="onToggleUsePoints" color="#0FAF8E" />
    </view>
    <view class="row mt-2" wx:if="{{usePoints}}">
      <view class="lbl">积分数量</view>
      <input class="points-input" type="number" placeholder="最多 {{pointsUsed || 0}}" value="{{pointsInput}}" bindinput="onPointsInput" />
    </view>
    <view class="tip" wx:if="{{usePoints}}">100 积分 = 1 元；当前可抵 {{payAmount}} 元</view>
  </view>

  <!-- 收货地址 -->
  <view class="section bg-white m-2 p-4 rounded-lg shadow">
    <view class="section-title">收货信息（选填，支付开通后可补）</view>
    <view class="field">
      <text class="lbl">姓名</text>
      <input class="addr-input" value="{{address.name}}" bindinput="onAddrName" />
    </view>
    <view class="field">
      <text class="lbl">手机</text>
      <input class="addr-input" type="number" value="{{address.phone}}" bindinput="onAddrPhone" />
    </view>
    <view class="field">
      <text class="lbl">地址</text>
      <input class="addr-input" value="{{address.detail}}" bindinput="onAddrDetail" />
    </view>
  </view>

  <view class="footer-placeholder" />

  <view class="footer bg-white">
    <view class="amount">
      <view class="total">合计 <text class="num">{{payAmount}}</text> 元</view>
      <view class="points" wx:if="{{pointsUsed > 0}}">使用 {{pointsUsed}} 积分</view>
    </view>
    <button
      class="btn-primary {{submitting ? 'btn-disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : canPay ? '提交订单' : '提交（支付开通中）'}}
    </button>
  </view>
</view>
