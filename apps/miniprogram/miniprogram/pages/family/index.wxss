/* pages/family/index.wxss — 家庭空间（V0.1.34，pic 2776） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.loading { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }

/* 家庭卡 */
.header {
  background: linear-gradient(135deg, #0faf8e 0%, #0d9b7e 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}
.fam-name { font-size: 40rpx; font-weight: 600; }
.fam-meta { font-size: 24rpx; opacity: 0.9; margin-top: 12rpx; }
.fam-meta .code { font-weight: 600; letter-spacing: 2rpx; }
.invite-btn {
  display: inline-block;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

/* 分段 */
.section { margin: 24rpx 16rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.section-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title-row .section-title { margin-bottom: 0; }
.add-btn { color: #0faf8e; font-size: 26rpx; }

/* 跑量榜 */
.rank-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 48rpx; text-align: center; font-size: 28rpx; font-weight: 600; color: #0faf8e; }
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin: 0 16rpx; background: #eee; }
.rank-name { flex: 1; font-size: 28rpx; color: #333; }
.rank-role { font-size: 20rpx; color: #fa8c16; background: #fff7e6; padding: 2rpx 12rpx; border-radius: 6rpx; margin-right: 16rpx; }
.rank-dist { font-size: 28rpx; color: #0faf8e; font-weight: 600; }

/* 目标卡 */
.goal-card { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.goal-card:last-child { border-bottom: none; }
.goal-head { display: flex; justify-content: space-between; align-items: center; }
.goal-title { font-size: 28rpx; color: #333; }
.goal-pct { font-size: 22rpx; color: #0faf8e; }
.progress-bar { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; margin: 12rpx 0; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #0faf8e, #4dd0c0); }
.goal-meta { font-size: 22rpx; color: #999; }
.empty { color: #999; font-size: 26rpx; padding: 24rpx 0; text-align: center; }

/* 离开 */
.leave-btn { margin: 32rpx 16rpx; padding: 24rpx; text-align: center; background: #fff; color: #e64340; border-radius: 12rpx; font-size: 28rpx; }
.leave-tip { text-align: center; color: #bbb; font-size: 24rpx; margin-top: 32rpx; }

/* 无家庭 */
.no-family { padding: 60rpx 32rpx; }
.nf-title { font-size: 36rpx; font-weight: 600; color: #333; text-align: center; }
.nf-desc { font-size: 26rpx; color: #999; text-align: center; margin-top: 12rpx; }
.nf-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-top: 32rpx; }
.nf-card-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.nf-input { background: #f5f5f5; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; margin-bottom: 16rpx; }
.nf-btn { background: #0faf8e; color: #fff; border-radius: 8rpx; font-size: 28rpx; }
.nf-btn::after { border: none; }

/* 弹层 */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); z-index: 100; display: flex; align-items: flex-end; }
.form-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 24rpx; box-sizing: border-box; }
.form-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.type-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.type-opt { flex: 1; text-align: center; padding: 16rpx; background: #f5f5f5; border-radius: 8rpx; font-size: 26rpx; }
.type-opt.on { background: #0faf8e; color: #fff; }
.form-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.btn-cancel { flex: 1; background: #f5f5f5; color: #666; border-radius: 8rpx; font-size: 28rpx; }
.btn-submit { flex: 1; background: #0faf8e; color: #fff; border-radius: 8rpx; font-size: 28rpx; }
.btn-cancel::after, .btn-submit::after { border: none; }
