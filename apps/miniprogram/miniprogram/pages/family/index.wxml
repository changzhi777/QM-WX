<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:elif="{{family}}">
    <!-- 家庭卡 -->
    <view class="header">
      <view class="fam-name">{{family.name}}</view>
      <view class="fam-meta">{{family.memberCount}} 位成员 · 邀请码 <text class="code">{{family.inviteCode}}</text></view>
      <view class="invite-btn" bindtap="onInvite">邀请家人</view>
    </view>

    <!-- 成员本月跑量榜 -->
    <view class="section">
      <view class="section-title">本月跑量榜</view>
      <view class="rank-item" wx:for="{{family.members}}" wx:key="userId">
        <view class="rank-num">{{index + 1}}</view>
        <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="rank-name">{{item.nickname || '跑者'}}</view>
        <view class="rank-role" wx:if="{{item.role === 'owner'}}">家长</view>
        <view class="rank-dist">{{item.monthDistance}} km</view>
      </view>
    </view>

    <!-- 家庭目标 -->
    <view class="section">
      <view class="section-title-row">
        <view class="section-title">家庭目标</view>
        <view class="add-btn" bindtap="onAddGoal">+ 添加</view>
      </view>
      <view wx:if="{{familyGoals.length === 0}}" class="empty">还没有家庭目标</view>
      <view class="goal-card" wx:for="{{familyGoals}}" wx:key="id">
        <view class="goal-head">
          <view class="goal-title">{{item.title || '家庭目标'}}</view>
          <view class="goal-pct" wx:if="{{item.completed}}">✓ 达成</view>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.percent}}%;"></view>
        </view>
        <view class="goal-meta">{{item.currentDistance}} / {{item.targetDistance}} km · {{item.percent}}%</view>
      </view>
    </view>

    <!-- V0.1.39 家庭成就（里程碑，全家累计跑量）-->
    <view class="section">
      <view class="section-title">🏆 家庭成就</view>
      <view wx:if="{{achievements.length === 0}}" class="empty">成就加载中…</view>
      <view class="achieve-item" wx:for="{{achievements}}" wx:key="km">
        <view class="achieve-icon {{item.achieved ? 'done' : ''}}">{{item.achieved ? '🏆' : '🎯'}}</view>
        <view class="achieve-info">
          <view class="achieve-km">{{item.km}} km</view>
          <view class="achieve-bar">
            <view class="achieve-fill" style="width: {{item.progress}}%;"></view>
          </view>
        </view>
        <view class="achieve-pct">{{item.achieved ? '已达成' : item.progress + '%'}}</view>
      </view>
    </view>

    <!-- 离开/转让/解散家庭（V0.1.39 owner 加转让/解散）-->
    <view class="leave-btn" wx:if="{{!family.isOwner}}" bindtap="onLeave">离开家庭</view>
    <view wx:else class="owner-actions">
      <view class="owner-btn transfer" bindtap="onTransferOwner">转让家长</view>
      <view class="owner-btn dissolve" bindtap="onDissolve">解散家庭</view>
    </view>
  </block>

  <!-- 无家庭：创建/加入 -->
  <view wx:elif="{{!loading}}" class="no-family">
    <view class="nf-title">加入家庭，一起奔跑</view>
    <view class="nf-desc">家庭成员跑量榜 + 共同目标，互相激励</view>

    <view class="nf-card">
      <view class="nf-card-title">创建家庭</view>
      <input class="nf-input" placeholder="家庭名称（如：张家跑团）" value="{{createName}}" bindinput="onInputCreate" />
      <button class="nf-btn" bindtap="onCreate">创建</button>
    </view>

    <view class="nf-card">
      <view class="nf-card-title">加入家庭</view>
      <input class="nf-input" placeholder="输入邀请码（8 位）" value="{{joinCode}}" bindinput="onInputJoin" />
      <button class="nf-btn" bindtap="onJoin">加入</button>
    </view>
  </view>

  <!-- 添加家庭目标弹层 -->
  <view class="mask" wx:if="{{goalVisible}}" bindtap="closeGoal">
    <view class="form-panel" catchtap="">
      <view class="form-title">添加家庭目标</view>
      <view class="type-row">
        <view class="type-opt {{goalType === 'monthly' ? 'on' : ''}}" data-type="monthly" bindtap="onPickGoalType">月度</view>
        <view class="type-opt {{goalType === 'yearly' ? 'on' : ''}}" data-type="yearly" bindtap="onPickGoalType">年度</view>
      </view>
      <input class="nf-input" placeholder="目标标题（可选）" value="{{goalTitle}}" bindinput="onInputGoalTitle" />
      <input class="nf-input" type="digit" placeholder="目标距离 km（如 100）" value="{{goalDistance}}" bindinput="onInputGoalDistance" />
      <view class="form-actions">
        <button class="btn-cancel" bindtap="closeGoal">取消</button>
        <button class="btn-submit" bindtap="onSubmitGoal">添加</button>
      </view>
    </view>
  </view>
</view>
