.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }

.card {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.card-title { font-size: 26rpx; color: #888; margin-bottom: 20rpx; font-weight: 600; }

.entry-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.entry-item { display: flex; flex-direction: column; align-items: center; padding: 12rpx 0; }
.entry-item:active { opacity: 0.6; }
.entry-icon {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #f0faf7;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; margin-bottom: 10rpx;
}
.entry-label { font-size: 24rpx; color: #555; }
