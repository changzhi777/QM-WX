/* pages/category/index.wxss — 全部商品分类（参考图 2766） */
.page { height: 100vh; background: #f5f5f5; }
.bg-white { background: #fff; }
.layout { display: flex; height: 100%; }
.sidebar { width: 180rpx; background: #f5f5f5; height: 100%; }
.cat-item { padding: 32rpx 12rpx; text-align: center; font-size: 26rpx; color: #666; border-left: 4rpx solid transparent; }
.cat-item.active { background: #fff; color: #0FAF8E; font-weight: 600; border-left-color: #0FAF8E; }
.cat-item .cat-name { font-size: 26rpx; }
.cat-item .count { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.content { flex: 1; height: 100%; padding: 16rpx; box-sizing: border-box; }
.empty { text-align: center; color: #999; padding: 80rpx 0; font-size: 26rpx; }
.product-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.product-card { width: calc(50% - 8rpx); border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }
.product-img-placeholder { height: 200rpx; background: #f0f0f0; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; font-size: 60rpx; margin-bottom: 12rpx; }
.product-name { font-size: 26rpx; color: #333; line-height: 1.3; height: 68rpx; overflow: hidden; }
.product-price { font-size: 30rpx; color: #0FAF8E; font-weight: 600; margin-top: 8rpx; }
