.page { padding-bottom: 40rpx; min-height: 100vh; background: #f5f5f5; }

.search { display: flex; }
.search-box {
  flex: 1; display: flex; align-items: center;
  background: #f5f5f5; border-radius: 32rpx; padding: 0 24rpx;
}
.search-input { flex: 1; height: 64rpx; font-size: 28rpx; }
.search-btn {
  padding: 8rpx 24rpx; background: var(--brand); color: #fff;
  font-size: 26rpx; border-radius: 24rpx; margin-left: 8rpx;
}

.cats { display: flex; border-top: 1rpx solid var(--border); }
.cat {
  flex: 1; padding: 24rpx 0; text-align: center;
  font-size: 28rpx; color: var(--text-secondary);
}
.cat-active { color: var(--brand); font-weight: 600; }

.grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx;
  padding: 16rpx;
}
.card { border-radius: 12rpx; overflow: hidden; }
.cover { width: 100%; height: 360rpx; background: #f0f0f0; }
.info { padding: 16rpx; }
.name {
  font-size: 26rpx; line-height: 1.4; height: 72rpx;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}
.price-row { display: flex; align-items: baseline; gap: 8rpx; margin-top: 8rpx; }
.price .num { color: var(--danger); font-size: 32rpx; font-weight: 600; }
.original { color: var(--text-tertiary); font-size: 22rpx; text-decoration: line-through; }

.loading, .end, .empty { padding: 40rpx 0; text-align: center; color: var(--text-tertiary); font-size: 24rpx; }
