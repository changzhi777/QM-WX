<view class="page">
  <!-- 搜索栏 -->
  <view class="search bg-white p-2">
    <view class="search-box">
      <input
        class="search-input"
        placeholder="搜索商品"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <view class="search-btn" bindtap="onSearch">搜索</view>
    </view>
  </view>

  <!-- 分类 -->
  <view class="cats bg-white">
    <view
      class="cat {{catIndex === index ? 'cat-active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      data-idx="{{index}}"
      bindtap="onCatChange"
    >
      {{item}}
    </view>
  </view>

  <view class="grid">
    <view
      class="card bg-white"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <image class="cover" src="{{item.images[0] || 'images/default-product.png'}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{item.name}}</view>
        <view class="price-row">
          <view class="price">
            <text class="num">{{item.price}}</text>
          </view>
          <view class="original" wx:if="{{item.originalPrice && item.originalPrice !== item.price}}">
            <text>¥{{item.originalPrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{!hasMore && list.length > 0}}" class="end">— 没有更多了 —</view>
  <view wx:elif="{{!loading && list.length === 0}}" class="empty">暂无商品</view>
</view>
