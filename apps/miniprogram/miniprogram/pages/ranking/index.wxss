/* pages/ranking/index.wxss — 我的榜单（参考图 2772） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }
.group-bar { padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.group-pick { font-size: 32rpx; font-weight: 600; color: #333; }
.tabs { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; }
.tab.active { color: #0FAF8E; font-weight: 600; border-bottom: 4rpx solid #0FAF8E; }
.periods { display: flex; padding: 16rpx 32rpx; gap: 16rpx; border-bottom: 1rpx solid #f0f0f0; }
.period { padding: 8rpx 24rpx; border-radius: 24rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.period.active { background: #0FAF8E; color: #fff; }
.my-rank { text-align: center; padding: 20rpx; color: #0FAF8E; font-size: 28rpx; font-weight: 600; }
.list { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 80rpx 0; font-size: 28rpx; }
.rank-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx; margin-bottom: 12rpx; border-radius: 12rpx;
}
.rank-num { width: 60rpx; text-align: center; font-size: 30rpx; font-weight: 600; color: #999; }
.rank-num.top { font-size: 40rpx; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; }
.avatar.ph {
  background: #0FAF8E; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 600;
}
.rank-info { flex: 1; min-width: 0; }
.rank-info .name { font-size: 30rpx; color: #333; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rank-info .meta { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.distance { font-size: 34rpx; font-weight: 600; color: #0FAF8E; }
.distance .u { font-size: 22rpx; color: #999; font-weight: 400; margin-left: 4rpx; }
.loading { text-align: center; padding: 80rpx; color: #999; }
