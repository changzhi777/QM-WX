/* pages/favorite/index.wxss — 我的收藏（V0.1.29） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }

.tabs { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; }
.tab.active { color: #0FAF8E; font-weight: 600; border-bottom: 4rpx solid #0FAF8E; }

.list { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }
.loading { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

.fav-card { background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 12rpx; display: flex; gap: 16rpx; align-items: center; }
.fav-cover { width: 140rpx; height: 140rpx; border-radius: 8rpx; flex-shrink: 0; background: #f5f5f5; }
.fav-info { flex: 1; min-width: 0; }
.fav-title { font-size: 28rpx; font-weight: 600; color: #333; }
.fav-meta { font-size: 22rpx; color: #0FAF8E; margin-top: 6rpx; }
.fav-summary { font-size: 22rpx; color: #999; margin-top: 6rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.remove-btn { font-size: 22rpx; color: #e64340; padding: 8rpx 16rpx; border: 1rpx solid #e64340; border-radius: 8rpx; flex-shrink: 0; }
