<view class="page">
  <view class="tabs bg-white">
    <view class="tab {{tab === 'content' ? 'active' : ''}}" data-tab="content" bindtap="switchTab">赛事/内容</view>
    <view class="tab {{tab === 'product' ? 'active' : ''}}" data-tab="product" bindtap="switchTab">商品</view>
  </view>

  <view class="list" wx:if="{{!loading}}">
    <view wx:if="{{favorites.length === 0}}" class="empty">暂无收藏</view>

    <view class="fav-card" wx:for="{{favorites}}" wx:key="id" data-item="{{item}}" bindtap="onTap">
      <image
        wx:if="{{item.detail && (item.detail.cover || item.detail.images)}}"
        class="fav-cover"
        src="{{item.detail.cover || item.detail.images[0]}}"
        mode="aspectFill"
      />
      <view class="fav-info">
        <view class="fav-title">{{item.detail ? (item.detail.title || item.detail.name) : '内容已删除'}}</view>
        <view class="fav-meta" wx:if="{{item.detail}}">
          <text wx:if="{{tab === 'product'}}">¥{{item.detail.price}}</text>
          <text wx:else>{{item.detail.type}} {{item.detail.location}}</text>
        </view>
        <view class="fav-summary" wx:if="{{item.detail && item.detail.summary}}">{{item.detail.summary}}</view>
      </view>
      <view class="remove-btn" data-item="{{item}}" catchtap="onRemove">取消</view>
    </view>
  </view>

  <view class="loading" wx:else>加载中...</view>
</view>
