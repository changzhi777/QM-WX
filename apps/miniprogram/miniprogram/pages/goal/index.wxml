<view class="page">
  <view class="header bg-white">
    <view class="title">跑步目标</view>
    <view class="subtitle">设定目标，跟踪进度，养成习惯</view>
  </view>

  <view class="list" wx:if="{{!loading}}">
    <view wx:if="{{goals.length === 0}}" class="empty">
      <view class="empty-text">还没有目标</view>
      <view class="empty-tip">设定一个月度或年度目标吧</view>
    </view>

    <view class="goal-card {{item.completed ? 'completed' : ''}}" wx:for="{{goals}}" wx:key="id">
      <view class="goal-head">
        <view class="goal-type">{{item.typeLabel}}</view>
        <view class="goal-title">{{item.title || item.typeLabel}}</view>
        <view class="goal-badge" wx:if="{{item.completed}}">✓ 达成</view>
      </view>
      <view class="progress">
        <view class="progress-bar">
          <view class="progress-fill {{item.completed ? 'done' : ''}}" style="width: {{item.percent}}%;"></view>
        </view>
        <view class="progress-text">
          <text class="current">{{item.currentDistance}}</text> / {{item.targetDistance}} km · {{item.percent}}%
        </view>
      </view>
      <view class="goal-actions" wx:if="{{item.status === 'active'}}">
        <view class="remove-btn" data-id="{{item.id}}" bindtap="onRemove">删除</view>
      </view>
    </view>
  </view>

  <view class="loading" wx:else>加载中...</view>

  <view class="fab" bindtap="onAdd">+ 设定目标</view>

  <!-- 添加弹层 -->
  <view class="mask" wx:if="{{formVisible}}" bindtap="closeForm">
    <view class="form-panel" catchtap="">
      <view class="form-title">设定目标</view>
      <view class="form-item">
        <text class="label">类型</text>
        <picker mode="selector" range="{{['月度', '年度', '自定义']}}" value="{{form.type === 'monthly' ? 0 : (form.type === 'yearly' ? 1 : 2)}}" bindchange="onTypeChange">
          <view class="picker">{{form.type === 'monthly' ? '月度' : (form.type === 'yearly' ? '年度' : '自定义')}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">目标距离</text>
        <input class="input" type="number" value="{{form.targetDistance}}" bindinput="onInputTarget" placeholder="km" />
      </view>
      <view class="form-item">
        <text class="label">标题（选填）</text>
        <input class="input" value="{{form.title}}" bindinput="onInputTitle" placeholder="如：夏季百公里" />
      </view>
      <view class="form-actions">
        <button class="btn-cancel" bindtap="closeForm">取消</button>
        <button class="btn-submit" bindtap="onSubmit" loading="{{submitting}}">创建</button>
      </view>
    </view>
  </view>
</view>
