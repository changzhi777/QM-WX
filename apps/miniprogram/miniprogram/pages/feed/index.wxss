/* pages/feed/index.wxss — 运动动态（V0.1.30） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 140rpx; box-sizing: border-box; }

.empty { text-align: center; padding: 160rpx 0; }
.empty-text { font-size: 32rpx; color: #666; }
.empty-tip { font-size: 24rpx; color: #bbb; margin-top: 12rpx; }
.loading, .loading-more { text-align: center; color: #999; padding: 40rpx; font-size: 26rpx; }
.no-more { text-align: center; color: #ccc; padding: 32rpx; font-size: 22rpx; }

/* 动态卡 */
.feed-card { background: #fff; margin-bottom: 16rpx; padding: 24rpx; }
.feed-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f0f0f0; }
.user-info { flex: 1; }
.nickname { font-size: 28rpx; font-weight: 600; color: #333; }
.time { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.feed-content { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 16rpx; }
.feed-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.feed-img { width: 220rpx; height: 220rpx; border-radius: 8rpx; }
.feed-run { display: inline-block; background: #E6F7F2; color: #2D9D78; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx; margin-bottom: 16rpx; }
.feed-run .run-icon { margin-right: 4rpx; }
.feed-actions { display: flex; gap: 40rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.action { font-size: 26rpx; color: #666; padding: 8rpx 0; }
.action.liked { color: #e64340; }

/* V0.1.36 话题 + 视频 + 分享 */
.feed-topic {
  display: inline-block;
  color: #1890ff;
  background: #e6f4ff;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.feed-video { width: 100%; border-radius: 8rpx; margin-bottom: 16rpx; }
.share-btn {
  background: none; border: none; padding: 8rpx 0; margin-left: auto;
  font-size: 26rpx; color: #666; line-height: 1.6;
}
.share-btn::after { border: none; }

/* FAB */
.fab {
  position: fixed; bottom: 40rpx; left: 50%; transform: translateX(-50%);
  background: #2D9D78; color: #fff; padding: 20rpx 48rpx;
  border-radius: 40rpx; font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 175, 142, 0.4); z-index: 10;
}

/* 弹层 */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: flex-end; }
.form-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; box-sizing: border-box; }
.form-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.textarea { width: 100%; min-height: 200rpx; background: #f5f5f5; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.publish-input { width: 100%; height: 72rpx; background: #f5f5f5; padding: 0 20rpx; border-radius: 8rpx; font-size: 26rpx; margin-top: 16rpx; box-sizing: border-box; }
.form-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.btn-cancel, .btn-submit { flex: 1; font-size: 28rpx; border-radius: 8rpx; line-height: 72rpx; padding: 0; margin: 0; }
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-submit { background: #2D9D78; color: #fff; }
