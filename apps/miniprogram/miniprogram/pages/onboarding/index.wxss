.page { padding: 32rpx; }

/* 进度条 */
.progress {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}
.progress-step {
  font-size: 22rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #f0f0f0;
}
.progress-step.active {
  background: var(--brand, #2d9d78);
  color: #fff;
}
.progress-line {
  width: 32rpx;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 8rpx;
}
.progress-line.active {
  background: var(--brand, #2d9d78);
}

/* 内容 */
.step-content { padding: 0 8rpx; }
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

/* 表单 */
.form-item {
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.form-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.form-input {
  font-size: 30rpx;
  color: #333;
}
.form-input.placeholder {
  color: #ccc;
}
.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  background: transparent;
  border-radius: 60rpx;
  overflow: hidden;
  line-height: 120rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}
.gender-row {
  display: flex;
  gap: 16rpx;
}
.gender-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.gender-btn.active {
  background: var(--brand, #2d9d78);
  color: #fff;
}

/* 引导卡 */
.guide-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.guide-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}
.guide-text {
  flex: 1;
}
.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.guide-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.guide-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 按钮 */
.next-btn {
  background: var(--brand, #2d9d78);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-top: 32rpx;
}
.skip-btn {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 完成 */
.finish-icon {
  font-size: 120rpx;
  text-align: center;
  margin-top: 80rpx;
}
.finish-title {
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 24rpx;
}
.finish-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-top: 12rpx;
}
