<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:elif="{{info}}">
    <!-- 头部：头像 + 昵称 -->
    <view class="header">
      <image class="avatar" src="{{info.user.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="nickname">{{info.user.nickname || '匿名跑者'}}</view>
      <view class="sub">{{info.isSelf ? '我的运动档案' : '运动档案'}}</view>
    </view>

    <!-- 最近运动动态 -->
    <view class="section-title">最近运动动态</view>
    <view wx:if="{{feedsLoading}}" class="loading">加载中...</view>
    <view wx:elif="{{feeds.length === 0}}" class="empty">暂无动态</view>
    <view wx:else class="feed-list">
      <view class="feed-card" wx:for="{{feeds}}" wx:key="id">
        <view class="feed-content">{{item.content}}</view>
        <view class="feed-shoe" wx:if="{{item.shoe}}">👟 {{item.shoe.nickname || (item.shoe.brand + ' ' + item.shoe.model)}}</view>
        <view class="feed-meta">
          <text wx:if="{{item.distanceKm}}">{{item.distanceKm}} km · </text>
          <text>{{item.likeCount}}❤️ {{item.commentCount}}💬</text>
          <text class="feed-time"> · {{item.createdAt}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
