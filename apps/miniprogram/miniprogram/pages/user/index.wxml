<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中…</view>

  <block wx:elif="{{info}}">
    <!-- 头部：头像 + 昵称 -->
    <view class="header">
      <image class="avatar" src="{{info.user.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="nickname">{{info.user.nickname || '匿名跑者'}}</view>
    </view>

    <!-- 关注数 / 粉丝数 -->
    <view class="stats">
      <view class="stat">
        <view class="num">{{info.followingCount}}</view>
        <view class="lbl">关注</view>
      </view>
      <view class="stat">
        <view class="num">{{info.followerCount}}</view>
        <view class="lbl">粉丝</view>
      </view>
    </view>

    <!-- 关注按钮（自己不显示） -->
    <view class="action-row" wx:if="{{!info.isSelf}}">
      <button
        class="btn {{info.followingBtn ? 'btn-following' : 'btn-follow'}}"
        bindtap="onToggleFollow"
        loading="{{toggling}}"
        disabled="{{toggling}}"
      >
        {{info.followingBtn ? '已关注' : '+ 关注'}}
      </button>
    </view>
    <view class="self-tip" wx:else>这是我本人</view>

    <!-- tab 切换（V0.1.116）-->
    <view class="tabs">
      <view class="tab {{tab === 'info' ? 'active' : ''}}" data-tab="info" bindtap="onSwitchTab">资料</view>
      <view class="tab {{tab === 'feeds' ? 'active' : ''}}" data-tab="feeds" bindtap="onSwitchTab">动态</view>
    </view>

    <!-- 动态列表（tab=feeds，feed.list userId 过滤）-->
    <block wx:if="{{tab === 'feeds'}}">
      <view wx:for="{{feeds}}" wx:key="id" class="feed-card bg-white m-2 p-4 rounded-lg shadow">
        <view class="feed-content">{{item.content}}</view>
        <view class="feed-meta">{{item.likeCount}}❤️ {{item.commentCount}}💬 · {{item.createdAt}}</view>
      </view>
      <view wx:if="{{feedsLoading}}" class="loading-more">加载中...</view>
      <view wx:if="{{!feedsLoading && feeds.length === 0}}" class="empty">暂无动态</view>
    </block>
  </block>
</view>
