/* pages/user/index.wxss — 运动档案（V0.1.143 改）*/
.page { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }

.header {
  background: linear-gradient(135deg, #0faf8e 0%, #4dd0c0 100%);
  padding: 60rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.4); background: #eee; }
.nickname { color: #fff; font-size: 34rpx; font-weight: 600; margin-top: 16rpx; }
.sub { color: rgba(255,255,255,0.85); font-size: 24rpx; margin-top: 8rpx; }

.section-title { font-size: 28rpx; font-weight: 600; color: #333; padding: 24rpx 32rpx 12rpx; }
.feed-list { padding: 0 16rpx; }
.feed-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.feed-content { font-size: 28rpx; color: #333; line-height: 1.5; }
.feed-shoe { font-size: 22rpx; color: #0faf8e; margin-top: 8rpx; }
.feed-meta { font-size: 22rpx; color: #999; margin-top: 12rpx; }
.feed-time { color: #ccc; }
.empty { text-align: center; color: #999; font-size: 26rpx; padding: 60rpx 0; }
