/* pages/user/index.wxss — 用户主页（V0.1.32） */
.page { min-height: 100vh; background: #f5f5f5; }
.loading { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }

.header {
  background: linear-gradient(135deg, #0faf8e 0%, #4dd0c0 100%);
  padding: 60rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background: #eee;
}
.nickname {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.stats {
  margin: -24rpx 32rpx 0;
  padding: 32rpx 0;
  border-radius: 16rpx;
  display: flex;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.stat { flex: 1; text-align: center; }
.stat .num { font-size: 36rpx; font-weight: 600; color: #0faf8e; }
.stat .lbl { font-size: 24rpx; color: #999; margin-top: 4rpx; }

.action-row { padding: 48rpx 32rpx 0; }
.btn { width: 100%; border-radius: 12rpx; font-size: 30rpx; }
.btn::after { border: none; }
.btn-follow { background: #0faf8e; color: #fff; }
.btn-following { background: #fff; color: #999; border: 1rpx solid #ddd; }

.self-tip { text-align: center; color: #bbb; font-size: 26rpx; margin-top: 48rpx; }

/* tab + 动态列表（V0.1.116）*/
.tabs { display: flex; background: #fff; margin: 24rpx 32rpx 0; border-radius: 12rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; }
.tab.active { color: #0faf8e; font-weight: 600; border-bottom: 4rpx solid #0faf8e; }
.feed-card { margin-top: 16rpx; }
.feed-content { font-size: 28rpx; color: #333; line-height: 1.5; }
.feed-meta { font-size: 22rpx; color: #999; margin-top: 12rpx; }
.loading-more, .empty { text-align: center; color: #999; font-size: 26rpx; padding: 60rpx 0; }
