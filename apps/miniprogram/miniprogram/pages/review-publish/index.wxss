.page { min-height: 100vh; background: #f5f5f5; }
.product-card { border-bottom: 1rpx solid #eee; }
.product-name { font-size: 28rpx; color: #333; }
.label { font-size: 28rpx; color: #333; font-weight: 600; }
.stars { margin-top: 16rpx; display: flex; }
.star { font-size: 56rpx; color: #ddd; margin-right: 16rpx; line-height: 1; }
.star.active { color: #ffb800; }
.mt { margin-top: 32rpx; }
.content-input {
  width: 100%;
  min-height: 200rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.ph { color: #bbb; }
.char-count { text-align: right; color: #999; font-size: 24rpx; margin-top: 8rpx; }
.images { display: flex; flex-wrap: wrap; margin-top: 16rpx; }
.img { width: 160rpx; height: 160rpx; margin-right: 16rpx; margin-bottom: 16rpx; border-radius: 12rpx; }
.add-img {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  font-size: 56rpx;
  color: #ccc;
}
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.btn-primary { background: var(--brand, #0FAF8E); color: #fff; border-radius: 12rpx; }
.footer-placeholder { height: 140rpx; }
