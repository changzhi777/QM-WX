/* pages/certificate/index.wxss — 我的证书（V0.1.28） */
.page { min-height: 100vh; background: #f5f5f5; padding: 16rpx; padding-bottom: 40rpx; box-sizing: border-box; }
.bg-white { background: #fff; }

.header { padding: 32rpx; border-radius: 16rpx; margin-bottom: 16rpx; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.header .subtitle { font-size: 26rpx; color: #999; margin-top: 8rpx; }

.loading, .empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; background: #fff; border-radius: 16rpx; }

/* 下一里程碑卡（橙色渐变） */
.next-card {
  background: linear-gradient(135deg, #fa8c16, #d97706);
  margin-bottom: 16rpx; padding: 32rpx; border-radius: 16rpx; color: #fff;
}
.next-title { font-size: 24rpx; opacity: 0.9; }
.next-name { font-size: 32rpx; font-weight: 600; margin: 8rpx 0 16rpx; }
.next-progress { display: flex; align-items: center; gap: 16rpx; }
.next-bar { flex: 1; height: 16rpx; background: rgba(255,255,255,0.3); border-radius: 8rpx; overflow: hidden; }
.next-fill { height: 100%; background: #fff; border-radius: 8rpx; transition: width 0.3s; }
.next-pct { font-size: 26rpx; font-weight: 600; min-width: 60rpx; }
.next-desc { font-size: 22rpx; opacity: 0.85; margin-top: 8rpx; }

/* 分段 */
.section { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; color: #666; margin-bottom: 16rpx; padding-left: 8rpx; }

/* 证书卡 */
.cert-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 12rpx; display: flex; align-items: center; gap: 20rpx; }
.cert-card.marathon { padding: 16rpx; }
.cert-icon { font-size: 56rpx; }
.cert-cover { width: 140rpx; height: 100rpx; border-radius: 8rpx; flex-shrink: 0; }
.cert-info { flex: 1; min-width: 0; }
.cert-name { font-size: 30rpx; font-weight: 600; color: #333; }
.cert-desc { font-size: 24rpx; color: #666; margin-top: 6rpx; }
.cert-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.cert-status { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 6rpx; display: inline-block; margin-top: 8rpx; }
.cert-status.confirmed { background: #E6F7F2; color: #0FAF8E; }
.cert-status.submitted { background: #FFF7E6; color: #fa8c16; }

.footer-tip { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 24rpx; }
