.page { min-height: 100vh; background: linear-gradient(180deg, #f0faf7 0%, #f5f6f8 30%); padding: 32rpx 24rpx 60rpx; box-sizing: border-box; }

.header { text-align: center; margin-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #2D9D78; }
.sub { font-size: 26rpx; color: #888; margin-top: 12rpx; }

.upload-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx dashed #2D9D78;
}
.upload-card:active { opacity: 0.7; }
.upload-card.loading { border-color: #ccc; }
.upload-icon { font-size: 80rpx; line-height: 1; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; font-weight: 600; color: #2D9D78; }
.upload-hint { font-size: 24rpx; color: #999; margin-top: 12rpx; }

.error {
  margin-top: 24rpx;
  background: #fff4e6;
  color: #d46b08;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border-left: 6rpx solid #fa8c16;
}

.result-card {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border-left: 8rpx solid #2D9D78;
}
.result-title { font-size: 30rpx; font-weight: 700; color: #2D9D78; margin-bottom: 20rpx; }
.result-text { font-size: 28rpx; color: #333; line-height: 1.8; white-space: pre-wrap; }

.tip { margin-top: 40rpx; font-size: 24rpx; color: #aaa; text-align: center; line-height: 1.6; }

/* V0.2.57 截图解读 */
.section-title { font-size: 28rpx; font-weight: 600; color: #555; margin: 32rpx 0 16rpx 8rpx; }
.shot-preview { margin-top: 20rpx; position: relative; }
.shot-img { width: 100%; max-height: 400rpx; border-radius: 16rpx; background: #fff; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.shot-remove { position: absolute; top: 16rpx; right: 16rpx; background: rgba(0,0,0,0.6); color: #fff; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 24rpx; }
.shot-checkin { margin-top: 16rpx; background: #f0faf7; color: #2D9D78; padding: 16rpx 24rpx; border-radius: 12rpx; font-size: 26rpx; border-left: 6rpx solid #2D9D78; }

/* V0.2.60 用户确认 checkin */
.privacy-hint { font-size: 22rpx; color: #b88; margin-top: 10rpx; }
.extract-card { margin-top: 24rpx; background: #fff; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); border-left: 8rpx solid #2D9D78; }
.extract-title { font-size: 28rpx; font-weight: 700; color: #2D9D78; margin-bottom: 16rpx; }
.extract-row { font-size: 28rpx; color: #333; line-height: 1.8; }
.extract-tip { font-size: 24rpx; color: #999; margin: 12rpx 0 20rpx; }
.confirm-btn { background: #2D9D78; color: #fff; font-size: 28rpx; border-radius: 40rpx; width: 100%; }
.confirm-btn[disabled] { background: #a0c9b8; color: #fff; }

/* V0.2.63 历史解读 */
.history-empty { font-size: 26rpx; color: #aaa; text-align: center; padding: 40rpx 0; }
.history-item { margin-top: 20rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.history-meta { display: flex; justify-content: space-between; font-size: 26rpx; color: #2D9D78; font-weight: 600; margin-bottom: 12rpx; }
.history-date { color: #aaa; font-weight: 400; }
.history-result { font-size: 26rpx; color: #333; line-height: 1.7; white-space: pre-line; }
.history-checkin { margin-top: 12rpx; font-size: 24rpx; color: #2D9D78; background: #f0faf7; padding: 10rpx 16rpx; border-radius: 8rpx; }
