<view class="page">
  <view class="header">
    <view class="title">📊 健康解读</view>
    <view class="sub">上传运动/健康数据，AI 识图 + 联动个人画像综合分析</view>
  </view>

  <!-- 📷 运动/健康截图（V0.2.57 GLM-4.6V 识图）-->
  <view class="section-title">📷 运动/健康截图</view>
  <view class="upload-card {{shotLoading ? 'loading' : ''}}" bindtap="onChooseImage">
    <view class="upload-icon">{{shotLoading ? '⏳' : '📷'}}</view>
    <view class="upload-text">{{shotLoading ? '识别分析中…' : '上传截图'}}</view>
    <view class="upload-hint">跑步成绩 / 体脂秤 / 体检报告 / 手环数据 等</view>
    <view class="privacy-hint">🔒 截图仅用于 助手分析，请勿上传含身份证号 / 病历号等敏感信息的图片</view>
  </view>

  <view class="shot-preview" wx:if="{{imageUrl}}">
    <image src="{{imageUrl}}" mode="aspectFit" class="shot-img" />
    <view class="shot-remove" catchtap="onRemoveImage">✕ 移除重选</view>
  </view>

  <!-- V0.2.60 识别运动数据 + 用户确认打卡（防误识别污染跑量）-->
  <view class="extract-card" wx:if="{{canCheckin && extract}}">
    <view class="extract-title">📋 识别到运动数据（请核对）</view>
    <view class="extract-row">{{extract.type}} · {{extract.distanceKm}}km<text wx:if="{{extract.date}}"> · {{extract.date}}</text></view>
    <view class="extract-row" wx:if="{{extract.durationSec}}">时长约 {{extract.durationSec}} 秒</view>
    <view class="extract-row" wx:if="{{extract.heartRate}}">心率 {{extract.heartRate}} bpm</view>
    <view class="extract-tip">确认后加入运动记录（同日同距离不可重复）</view>
    <button class="confirm-btn" bindtap="onConfirmCheckin" disabled="{{confirming}}" loading="{{confirming}}">{{confirming ? '提交中…' : '确认加入运动记录'}}</button>
  </view>
  <view class="shot-checkin" wx:if="{{checkinMsg}}">{{checkinMsg}}</view>
  <view class="error" wx:if="{{shotError}}">⚠️ {{shotError}}</view>
  <view class="result-card" wx:if="{{shotResult}}">
    <view class="result-title">✨ AI 综合分析</view>
    <view class="result-text">{{shotResult}}</view>
  </view>

  <!-- 📁 佳明 FIT 文件 -->
  <view class="section-title">📁 佳明 FIT 文件</view>
  <view class="upload-card {{loading ? 'loading' : ''}}" bindtap="onChooseFile">
    <view class="upload-icon">{{loading ? '⏳' : '📁'}}</view>
    <view class="upload-text">{{loading ? '解读中…请稍候' : '上传佳明 FIT 文件'}}</view>
    <view class="upload-hint" wx:if="{{fileName && !loading}}">已选：{{fileName}}</view>
  </view>

  <view class="error" wx:if="{{error}}">⚠️ {{error}}</view>

  <view class="result-card" wx:if="{{interpretation}}">
    <view class="result-title">✨ 健康解读</view>
    <view class="result-text">{{interpretation}}</view>
  </view>

  <!-- V0.2.63 历史解读（H5 上传的结果回看 + 确认打卡）-->
  <view class="section-title">🕘 历史解读</view>
  <view class="history-empty" wx:if="{{!historyLoading && history.length === 0}}">暂无历史解读记录</view>
  <view class="history-item" wx:for="{{history}}" wx:key="id">
    <view class="history-meta">
      <text>{{item.extract.distanceKm}}km · {{item.extract.summary}}</text>
      <text class="history-date">{{item.createdAt}}</text>
    </view>
    <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="history-img" />
    <view class="history-result">{{item.result}}</view>
    <view class="history-checkin" wx:if="{{item.checkinConfirmedAt}}">✅ 已加入运动记录</view>
    <button wx:elif="{{item.extract.type !== 'other' && item.extract.distanceKm > 0}}" class="confirm-btn" data-record-id="{{item.id}}" bindtap="onConfirmHistoryCheckin">确认加入运动记录</button>
  </view>

  <view class="tip" wx:if="{{!interpretation && !loading && !error && !shotResult && history.length === 0}}">
    💡 截图：跑步 app 成绩页 / 体脂秤报告 / 体检单拍照。FIT：佳明 Connect / COROS 导出。
  </view>
</view>
