/* pages/shoes-compare/index.wxss */

.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #888;
}

.header {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.shoe-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  text-align: center;
}

.vs {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
  padding: 0 16rpx;
}

.table {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.row {
  display: flex;
  border-bottom: 1rpx solid #f5f5f5;
}

.row:last-child {
  border-bottom: none;
}

.header-row {
  background: #f9fafb;
  font-weight: 600;
}

.cell {
  flex: 1;
  padding: 20rpx 12rpx;
  font-size: 26rpx;
  text-align: center;
  color: #333;
}

.cell.label {
  flex: 0 0 200rpx;
  background: #fafbfc;
  color: #666;
  font-size: 24rpx;
}

.cell.winner {
  color: #0FAF8E;
  font-weight: 700;
  background: #f0f9f6;
}

.footer {
  margin-top: 40rpx;
}

.btn-back {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #0FAF8E;
  border: 2rpx solid #0FAF8E;
  border-radius: 44rpx;
  font-size: 28rpx;
}