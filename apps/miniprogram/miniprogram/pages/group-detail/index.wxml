<view class="page">
  <!-- V0.1.42 群卡 + 公告 + 汇总 -->
  <view class="group-card" wx:if="{{detail}}">
    <view class="gc-head">
      <view class="gc-name">{{detail.name}}</view>
      <view class="gc-owner">
        <image class="gc-avatar" src="{{detail.owner.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <text class="gc-owner-name">群主 {{detail.owner.nickname || '匿名'}}</text>
      </view>
    </view>
    <view class="gc-summary">
      <view class="gc-stat"><text class="v">{{detail.memberCount}}</text><text class="u">人</text></view>
      <view class="gc-stat"><text class="v">{{detail.summary.totalDistance}}</text><text class="u">km</text></view>
      <view class="gc-stat"><text class="v">{{detail.summary.totalCheckins}}</text><text class="u">次打卡</text></view>
      <view class="gc-stat"><text class="v">{{detail.summary.activeDays}}</text><text class="u">活跃天</text></view>
    </view>
    <view class="gc-announce" wx:if="{{detail.announce}}">
      <view class="gc-announce-label">📢 群公告</view>
      <view class="gc-announce-text">{{detail.announce}}</view>
      <view class="gc-edit" wx:if="{{detail.myRole === 'owner'}}" bindtap="onEditAnnounce">编辑</view>
    </view>
    <view class="gc-announce gc-announce-empty" wx:elif="{{detail.myRole === 'owner'}}" bindtap="onEditAnnounce">
      <view class="gc-announce-label">📢 点击发布群公告</view>
    </view>
  </view>

  <!-- period 榜单（现有） -->
  <view class="header bg-white m-2 p-4 rounded-lg shadow">
    <view class="row">
      <view class="text-secondary text-sm">本群 · {{totals.memberCount}} 人</view>
      <view class="text-secondary text-sm">累计 {{totals.totalDistance}} km</view>
    </view>
    <picker mode="selector" range="{{['本周','本月','本年']}}" value="{{periodIndex}}" bindchange="onPeriodChange">
      <view class="picker mt-2">{{['本周','本月','本年'][periodIndex]}} 榜单 <text class="arrow-sm">›</text></view>
    </picker>
  </view>

  <view class="list bg-white m-2 rounded-lg shadow">
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:elif="{{members.length === 0}}" class="empty">暂无打卡数据</view>
    <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="loadRanking" />
    <view class="rank-item" wx:for="{{members}}" wx:key="userId">
      <view class="rank rank-{{item.rank <= 3 ? 'top' : 'normal'}}">{{item.rank}}</view>
      <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{item.nickname}}</view>
        <view class="meta">{{item.count}} 次打卡</view>
      </view>
      <view class="stats">
        <view class="distance">{{item.distance}} km</view>
        <view class="points">+{{item.points}} 积分</view>
      </view>
    </view>
  </view>

  <!-- V0.1.42 成员列表 -->
  <view class="list bg-white m-2 rounded-lg shadow" wx:if="{{memberList.length > 0}}">
    <view class="section-title">群成员（{{memberList.length}}）</view>
    <view class="member-item" wx:for="{{memberList}}" wx:key="userId">
      <image class="avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{item.nickname}}<text wx:if="{{item.role === 'owner'}}" class="role-tag">群主</text></view>
        <view class="meta">加入于 {{item.joinedAt}}</view>
      </view>
      <view class="stats">
        <view class="distance">{{item.monthDistance}} km</view>
        <view class="points">本月</view>
      </view>
    </view>
  </view>

  <view class="p-4"><button class="btn-cancel" bindtap="onTapQuit">退出群</button></view>
  <view class="p-4"><button class="btn-primary" bindtap="goWeeklyReport">查看本周周报</button></view>
</view>
