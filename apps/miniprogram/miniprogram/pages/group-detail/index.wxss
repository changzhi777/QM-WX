.page { padding-bottom: 60rpx; }
.header .row { display: flex; justify-content: space-between; }
.header .picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.arrow-sm { color: var(--text-tertiary); }

.list { padding: 0 24rpx; }
.loading, .empty { padding: 60rpx 0; text-align: center; color: var(--text-tertiary); }

.rank-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.rank-item:last-child { border-bottom: none; }
.rank {
  width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  border-radius: 50%; font-size: 24rpx; font-weight: 600;
}
.rank-top { background: var(--brand); color: #fff; }
.rank-normal { background: #f0f0f0; color: var(--text-secondary); }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin: 0 16rpx; }
.info { flex: 1; }
.info .name { font-size: 28rpx; }
.info .meta { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.stats { text-align: right; }
.stats .distance { font-size: 28rpx; font-weight: 600; color: var(--brand); }
.stats .points { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }

.btn-cancel {
  background: #fff; color: var(--danger);
  height: 88rpx; line-height: 88rpx; border-radius: 8rpx; font-size: 30rpx;
}
.btn-cancel::after { border: 1rpx solid var(--border); }

.btn-primary {
  background: var(--brand); color: #fff;
  height: 88rpx; line-height: 88rpx; border-radius: 8rpx; font-size: 30rpx;
}
.btn-primary::after { border: none; }

/* V0.1.42 群卡 + 公告 + 汇总 + 成员列表 */
.group-card { background: #fff; margin: 16rpx; padding: 24rpx; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.gc-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.gc-name { font-size: 34rpx; font-weight: 600; color: #333; }
.gc-owner { display: flex; align-items: center; gap: 8rpx; }
.gc-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.gc-owner-name { font-size: 24rpx; color: #666; }
.gc-summary { display: flex; justify-content: space-between; padding: 16rpx 0; border-top: 1rpx solid #f0f0f0; border-bottom: 1rpx solid #f0f0f0; }
.gc-stat { display: flex; align-items: baseline; gap: 4rpx; }
.gc-stat .v { font-size: 32rpx; font-weight: 600; color: var(--brand, #2D9D78); }
.gc-stat .u { font-size: 22rpx; color: #999; }
.gc-announce { margin-top: 16rpx; padding: 16rpx; background: #f9f9f9; border-radius: 8rpx; position: relative; }
.gc-announce-empty { display: flex; align-items: center; justify-content: center; border: 1rpx dashed #ddd; background: #fff; }
.gc-announce-label { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.gc-announce-empty .gc-announce-label { margin-bottom: 0; color: #2D9D78; }
.gc-announce-text { font-size: 26rpx; color: #333; line-height: 1.6; }
.gc-edit { position: absolute; top: 12rpx; right: 12rpx; font-size: 22rpx; color: #2D9D78; padding: 4rpx 12rpx; }

.section-title { font-size: 28rpx; font-weight: 600; color: #333; padding: 24rpx 24rpx 12rpx; border-bottom: 1rpx solid #f0f0f0; }
.role-tag { display: inline-block; font-size: 18rpx; color: #fff; background: #2D9D78; padding: 2rpx 10rpx; border-radius: 8rpx; margin-left: 8rpx; vertical-align: middle; }
