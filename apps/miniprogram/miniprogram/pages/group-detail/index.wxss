.page { padding-bottom: 60rpx; }
.header .row { display: flex; justify-content: space-between; }
.header .picker {
  height: 80rpx; line-height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.arrow-sm { color: var(--text-tertiary); }

.list { padding: 0 24rpx; }
.loading, .empty { padding: 60rpx 0; text-align: center; color: var(--text-tertiary); }

.rank-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.rank-item:last-child { border-bottom: none; }
.rank {
  width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  border-radius: 50%; font-size: 24rpx; font-weight: 600;
}
.rank-top { background: var(--brand); color: #fff; }
.rank-normal { background: #f0f0f0; color: var(--text-secondary); }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin: 0 16rpx; }
.info { flex: 1; }
.info .name { font-size: 28rpx; }
.info .meta { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.stats { text-align: right; }
.stats .distance { font-size: 28rpx; font-weight: 600; color: var(--brand); }
.stats .points { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }

.btn-cancel {
  background: #fff; color: var(--danger);
  height: 88rpx; line-height: 88rpx; border-radius: 8rpx; font-size: 30rpx;
}
.btn-cancel::after { border: 1rpx solid var(--border); }

.btn-primary {
  background: var(--brand); color: #fff;
  height: 88rpx; line-height: 88rpx; border-radius: 8rpx; font-size: 30rpx;
}
.btn-primary::after { border: none; }
