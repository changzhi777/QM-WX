/* pages/report-detail — 完整报告详情页（V0.2.4）*/
.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 60rpx; }
.loading { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

/* 头部 */
.rd-header {
  background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%);
  color: #fff;
  padding: 40rpx 32rpx 60rpx;
  text-align: center;
}
.rd-date { font-size: 26rpx; opacity: 0.9; margin-bottom: 24rpx; }
.score-ring {
  width: 220rpx; height: 220rpx; margin: 0 auto;
  border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.25);
  border-top: 8rpx solid #fff;
  border-right: 8rpx solid #fff;
  display: flex; align-items: center; justify-content: center;
  transform: rotate(45deg);
}
.score-inner { transform: rotate(-45deg); }
.score-num { font-size: 72rpx; font-weight: 700; line-height: 1; }
.score-label { font-size: 22rpx; opacity: 0.8; margin-top: 8rpx; }
.rd-trend { margin-top: 24rpx; font-size: 24rpx; opacity: 0.9; }
.rd-trend .up { color: #fff; }
.rd-trend .down { color: #ffd5d0; }

/* 数据概览条 */
.rd-strip { margin: -40rpx 24rpx 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); position: relative; z-index: 2; }

/* AI 完整解读卡 */
.rd-card {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}
.rd-card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.rd-badge {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 12rpx; font-weight: 600;
}
.rd-lock-tag { font-size: 22rpx; color: #b8860b; background: #fff8e1; padding: 4rpx 14rpx; border-radius: 12rpx; }
.rd-body { font-size: 28rpx; color: #444; line-height: 1.8; }
.rd-body.blurred { color: #aaa; }
.rd-alert {
  margin-top: 16rpx; background: #fff8e1; border-radius: 12rpx;
  padding: 16rpx; font-size: 24rpx; color: #795548; line-height: 1.5;
}

/* 锁定遮罩 */
.rd-lock-mask {
  position: absolute; left: 0; right: 0; bottom: 0;
  height: 220rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.9) 50%, #fff 100%);
  border-radius: 0 0 20rpx 20rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
  padding-bottom: 24rpx;
}
.rd-lock-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.rd-lock-text { font-size: 24rpx; color: #888; margin-bottom: 16rpx; }
.rd-upgrade {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff; font-size: 26rpx; font-weight: 600;
  padding: 16rpx 40rpx; border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(45,157,120,0.3);
}

/* 底部操作 */
.rd-actions { display: flex; gap: 16rpx; padding: 0 24rpx; }
.rd-btn {
  flex: 1; line-height: 84rpx; text-align: center;
  border-radius: 42rpx; font-size: 28rpx; font-weight: 600;
  border: none;
}
.rd-btn::after { border: none; }
.rd-share { background: #fff; color: #2D9D78; border: 1rpx solid #2D9D78; }
.rd-upgrade-btn { background: linear-gradient(135deg, #2D9D78, #1a7a5a); color: #fff; }

/* 空态 */
.empty { text-align: center; padding: 120rpx 40rpx; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-tip { font-size: 22rpx; color: #bbb; margin-top: 12rpx; }
