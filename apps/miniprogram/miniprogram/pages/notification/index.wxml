<view class="page">
  <!-- 顶部：全部已读 -->
  <view class="topbar" wx:if="{{list.length}}">
    <view class="mark-all" bindtap="onMarkAll">全部已读</view>
  </view>

  <view wx:if="{{loading && !list.length}}" class="empty">加载中…</view>

  <block wx:elif="{{list.length}}">
    <view class="list">
      <view
        wx:for="{{list}}"
        wx:key="id"
        class="card {{item.isRead ? '' : 'unread'}}"
        data-item="{{item}}"
        bindtap="onTapItem"
      >
        <image class="avatar" src="{{item.actor.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="body">
          <view class="row">
            <view class="name">{{item.actor.nickname || '跑者'}}</view>
            <view class="text">{{item.text}}</view>
            <view class="dot" wx:if="{{!item.isRead}}"></view>
          </view>
          <view class="content" wx:if="{{item.content}}">{{item.content}}</view>
          <view class="time">{{item.timeText}}</view>
        </view>
      </view>
    </view>
    <view class="bottom" wx:if="{{!hasMore}}">没有更多了</view>
  </block>

  <view wx:else class="empty">
    <view class="empty-icon">🔔</view>
    <view>暂无消息</view>
  </view>
</view>
