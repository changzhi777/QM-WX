/* pages/notification/index.wxss — 消息中心（V0.1.31） */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.topbar {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 24rpx;
}
.mark-all {
  color: #0faf8e;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.list {
  padding: 0 24rpx;
}
.card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card.unread {
  border-left: 6rpx solid #0faf8e;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eee;
}
.body {
  flex: 1;
  min-width: 0;
}
.row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}
.text {
  font-size: 28rpx;
  color: #666;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  margin-left: 8rpx;
}
.content {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.5;
  word-break: break-all;
}
.time {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}
.bottom {
  text-align: center;
  color: #bbb;
  font-size: 24rpx;
  padding: 24rpx 0 48rpx;
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  color: #999;
  font-size: 28rpx;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}
