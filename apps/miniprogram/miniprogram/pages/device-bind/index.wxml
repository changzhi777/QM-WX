<view class="page">
  <!-- 标题 -->
  <view class="header bg-white">
    <view class="title">设备绑定</view>
    <view class="subtitle">连接手环 / 手表 / 心率带，同步运动数据</view>
  </view>

  <!-- 实时心率（蓝牙连接后展示）+ V0.1.33 设备信息（电量/型号/厂商） -->
  <view class="hr-card" wx:if="{{liveHr !== null}}">
    <view class="hr-label">实时心率</view>
    <view class="hr-value">{{liveHr}}<text class="u">bpm</text></view>
    <view class="hr-meta" wx:if="{{liveBattery !== null || liveModel || liveManufacturer}}">
      <text wx:if="{{liveBattery !== null}}" class="hr-meta-item">🔋 {{liveBattery}}%</text>
      <text wx:if="{{liveManufacturer}}" class="hr-meta-item">{{liveManufacturer}}</text>
      <text wx:if="{{liveModel}}" class="hr-meta-item">{{liveModel}}</text>
      <text wx:if="{{liveBodyLocation}}" class="hr-meta-item">佩戴·{{liveBodyLocation === 'Wrist' ? '手腕' : liveBodyLocation}}</text>
    </view>
  </view>

  <!-- V0.1.43 血氧卡（0x1822 / 0x2A5F spot-check 测量结果）-->
  <view class="hr-card spo2-card" wx:if="{{liveSpO2 !== null}}">
    <view class="hr-label">血氧 SpO2</view>
    <view class="hr-value">{{liveSpO2.spo2}}<text class="u">%</text></view>
    <view class="hr-meta">
      <text class="hr-meta-item">❤️ 脉率 {{liveSpO2.pr}}</text>
    </view>
  </view>

  <!-- 已绑定设备 -->
  <view class="section" wx:if="{{bindings.length > 0}}">
    <view class="section-title">已绑定设备</view>
    <view class="card bound-card" wx:for="{{bindings}}" wx:key="id">
      <view class="bound-info">
        <view class="bound-name">{{item.deviceName}}</view>
        <view class="bound-meta">{{item.vendor === 'ble' ? '蓝牙直连' : (item.vendor === 'garmin' ? '佳明手表·蓝牙' : (item.vendor === 'xiaomi' ? '小米手环·蓝牙' : item.vendor))}} · {{item.status === 'active' ? '已连接' : '已断开'}}</view>
      </view>
      <view class="unbind-btn" data-vendor="{{item.vendor}}" data-name="{{item.deviceName}}" bindtap="onUnbind">解绑</view>
    </view>
  </view>

  <!-- 佳明 OAuth 数据（V0.1.33：BLE 未绑定时降级显示，提示用户可 BLE 绑定实时心率） -->
  <view class="section" wx:if="{{garminAutoConnected && !garminBleBound}}">
    <view class="card garmin-card">
      <view class="bound-info">
        <view class="bound-name">佳明 GARMIN</view>
        <view class="bound-meta">历史数据已连接（OAuth）· {{garminActivityCount}} 条活动</view>
      </view>
      <view class="tag">OAuth</view>
    </view>
  </view>

  <!-- 品牌宫格（按设计稿 2770：手环/手表/心率带/健康App） -->
  <view class="section">
    <view class="section-title">添加设备</view>
    <view class="brand-grid">
      <view
        class="brand-card {{!brand.available ? 'disabled' : ''}}"
        wx:for="{{brands}}"
        wx:for-item="brand"
        wx:key="key"
        data-key="{{brand.key}}"
        bindtap="onTapBrand"
      >
        <view class="brand-name">{{brand.name}}</view>
        <view class="brand-type">{{brand._categoryLabel}}</view>
        <view class="brand-status {{brand.available ? 'on' : 'off'}}">
          <block wx:if="{{brand.available}}">
            {{brand.connectionType === 'ble' ? '蓝牙连接' : (brand.connectionType === 'oauth' ? '授权连接' : '步数同步')}}
          </block>
          <block wx:else>敬请期待</block>
        </view>
      </view>
    </view>
  </view>

  <!-- 联调信息（GAP-9，真机调试可观测性） -->
  <view class="debug-section">
    <view class="debug-toggle" bindtap="toggleDebug">
      {{debugVisible ? '隐藏' : '显示'}}联调信息{{hrCount > 0 ? ' · 心率 ' + hrCount + ' 次' : ''}}
    </view>
    <view class="debug-panel" wx:if="{{debugVisible}}">
      <view class="debug-row">心率回调：<text class="debug-num">{{hrCount}}</text> 次</view>
      <view class="debug-logs">
        <view class="debug-log" wx:for="{{debugLog}}" wx:key="*this">{{item}}</view>
        <view class="debug-empty" wx:if="{{debugLog.length === 0}}">暂无日志（点"蓝牙心率设备"开始扫描）</view>
      </view>
    </view>
  </view>

  <!-- 蓝牙扫描弹层 -->
  <view class="mask" wx:if="{{scanVisible}}" bindtap="closeScan">
    <view class="scan-panel" catchtap="">
      <view class="scan-header">
        <text class="scan-title">扫描蓝牙设备</text>
        <text class="scan-close" bindtap="closeScan">✕</text>
      </view>
      <view class="scan-tip" wx:if="{{scanning}}">扫描中...请确保设备已开机并靠近手机</view>
      <view class="scan-tip" wx:elif="{{foundDevices.length === 0}}">未发现设备</view>
      <scroll-view scroll-y class="scan-list">
        <view
          class="scan-item"
          wx:for="{{foundDevices}}"
          wx:key="deviceId"
          data-device="{{item}}"
          bindtap="onSelectDevice"
        >
          <view class="scan-main">
            <view class="scan-name">{{item.name}}</view>
            <view class="scan-sub">
              <text class="brand-tag brand-{{item.detectedBrand}}">{{item.brandLabel}}</text>
              <text class="scan-rssi">信号 {{item.RSSI}}dBm</text>
            </view>
          </view>
          <view class="scan-arrow">›</view>
        </view>
      </scroll-view>
      <view class="scan-refresh" bindtap="startScan">重新扫描</view>
    </view>
  </view>

  <!-- V0.1.43 微信运动步数（方案 3，合规数据源）-->
  <view class="werun-section">
    <view class="werun-head">
      <view class="werun-title">📱 微信运动步数</view>
      <view class="werun-sync-btn" bindtap="onSyncWeRun">同步</view>
    </view>
    <view class="werun-summary" wx:if="{{werunSummary.days > 0}}">
      <view class="werun-stat"><text class="v">{{werunSummary.totalSteps}}</text><text class="u">步（{{werunSummary.days}}天）</text></view>
      <view class="werun-stat"><text class="v">{{werunSummary.totalKm}}</text><text class="u">km</text></view>
    </view>
    <view class="werun-empty" wx:elif="{{werunRecords.length === 0}}">点击「同步」拉取微信运动步数（需授权）</view>
    <scroll-view scroll-x wx:else class="werun-list">
      <view class="werun-row" wx:for="{{werunRecords}}" wx:key="date">
        <text class="werun-date">{{item.date}}</text>
        <text class="werun-step">{{item.step}}</text>
        <text class="werun-km">{{item.km}}km</text>
      </view>
    </scroll-view>
  </view>
</view>
