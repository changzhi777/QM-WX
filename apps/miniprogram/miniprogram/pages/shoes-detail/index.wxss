/* pages/shoes-detail/index.wxss — V0.1.133 */

.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #888;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 1. 基础信息卡 */
.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.brand {
  font-size: 36rpx;
  font-weight: 700;
  color: #0FAF8E;
}

.model {
  font-size: 28rpx;
  color: #333;
}

.badge.retired {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: #f0f0f0;
  color: #888;
  border-radius: 20rpx;
}

.nickname,
.meta,
.note {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 2. 阈值编辑器 */
.threshold-current {
  text-align: center;
  margin: 16rpx 0;
}

.threshold-current .num {
  font-size: 56rpx;
  font-weight: 700;
  color: #0FAF8E;
}

.threshold-current .unit {
  font-size: 28rpx;
  color: #888;
  margin-left: 8rpx;
}

.threshold-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.threshold-meta .draft {
  color: #0FAF8E;
  font-weight: 600;
}

/* 3. 累计统计 */
.stats-card {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.stat {
  flex: 0 0 48%;
  text-align: center;
  padding: 16rpx 0;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 6rpx;
}

.stat-num.health-good { color: #0FAF8E; }
.stat-num.health-warn { color: #f59e0b; }
.stat-num.health-bad  { color: #ef4444; }

.stat-label {
  font-size: 24rpx;
  color: #888;
}

/* 4. 里程曲线 */
.chart-card {
  padding-bottom: 40rpx;
}

.period-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 4rpx;
}

.period-tabs .tab {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  color: #666;
}

.period-tabs .tab.active {
  background: #0FAF8E;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

.empty .empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* 5. 返回按钮 */
.footer {
  margin-top: 40rpx;
}

.btn-back {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #0FAF8E;
  border: 2rpx solid #0FAF8E;
  border-radius: 44rpx;
  font-size: 28rpx;
}