<view class="page">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{detail}}">
    <!-- 1. 基础信息卡 -->
    <view class="card info-card">
      <view class="info-row">
        <text class="brand">{{detail.brand}}</text>
        <text class="model">{{detail.model}}</text>
        <text wx:if="{{detail.status === 'retired'}}" class="badge retired">已退役</text>
      </view>
      <view wx:if="{{detail.nickname}}" class="nickname">昵称：{{detail.nickname}}</view>
      <view wx:if="{{detail.purchasedAt}}" class="meta">
        购入：{{detail.purchasedAt}} · 已使用 {{detail.daysSincePurchase}} 天
      </view>
      <view wx:if="{{detail.note}}" class="note">备注：{{detail.note}}</view>
    </view>

    <!-- 2. 阈值编辑器（slider） -->
    <view class="card">
      <view class="card-title">更换阈值（km）</view>
      <view class="threshold-current">
        <text class="num">{{detail.thresholdKm}}</text>
        <text class="unit">km</text>
      </view>
      <slider
        min="100"
        max="2000"
        step="50"
        value="{{detail.thresholdKm}}"
        bindchanging="onThresholdChanging"
        bindchange="onThresholdChange"
        activeColor="#0FAF8E"
        block-size="20"
        show-value="{{false}}"
        disabled="{{savingThreshold}}"
      />
      <view class="threshold-meta">
        <text>100</text>
        <text class="draft">待保存：{{thresholdDraft}} km</text>
        <text>2000</text>
      </view>
    </view>

    <!-- 3. 累计统计 -->
    <view class="card stats-card">
      <view class="stat">
        <text class="stat-num">{{detail.currentKm}}</text>
        <text class="stat-label">当前里程(km)</text>
      </view>
      <view class="stat">
        <text class="stat-num health-{{detail.healthRatio < 70 ? 'good' : detail.healthRatio <= 100 ? 'warn' : 'bad'}}">
          {{detail.healthRatio}}%
        </text>
        <text class="stat-label">健康度</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{detail.totalCheckins}}</text>
        <text class="stat-label">累计打卡</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{mileageHistory.totalKm}}</text>
        <text class="stat-label">合计里程(km)</text>
      </view>
    </view>

    <!-- 4. 里程曲线（Canvas 手绘） -->
    <view class="card chart-card">
      <view class="card-title-row">
        <text class="card-title">里程曲线</text>
        <view class="period-tabs">
          <view
            class="tab {{period === 'weekly' ? 'active' : ''}}"
            data-period="weekly"
            bindtap="onPeriodChange"
          >周</view>
          <view
            class="tab {{period === 'monthly' ? 'active' : ''}}"
            data-period="monthly"
            bindtap="onPeriodChange"
          >月</view>
        </view>
      </view>

      <view wx:if="{{empty}}" class="empty">
        <text>暂无里程数据</text>
        <text class="empty-tip">去 [sport 打卡] 试试，选这双跑鞋</text>
      </view>
      <block wx:else>
        <mileage-chart
          points="{{period === 'weekly' ? mileageHistory.weekly : mileageHistory.monthly}}"
          width="{{chartWidth}}"
          height="{{chartHeight}}"
        />
      </block>
    </view>

    <!-- 5. 返回 -->
    <view class="footer">
      <button class="btn-back" bindtap="onTapBack">返回跑鞋列表</button>
    </view>
  </block>
</view>