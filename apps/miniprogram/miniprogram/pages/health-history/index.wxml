<view class="page">
  <!-- tab 切换（心率/血氧/步数）-->
  <view class="tabs">
    <view class="tab {{activeType === 'hr' ? 'active' : ''}}" data-type="hr" bindtap="onTabChange">❤️ 心率</view>
    <view class="tab {{activeType === 'spo2' ? 'active' : ''}}" data-type="spo2" bindtap="onTabChange">🩸 血氧</view>
    <view class="tab {{activeType === 'steps' ? 'active' : ''}}" data-type="steps" bindtap="onTabChange">👟 步数</view>
    <view class="tab {{activeType === 'sleep' ? 'active' : ''}}" data-type="sleep" bindtap="onTabChange">💤 睡眠</view>
  </view>

  <!-- 时间范围 -->
  <view class="ranges">
    <view class="range {{range === 1 ? 'active' : ''}}" data-range="1" bindtap="onRangeChange">今日</view>
    <view class="range {{range === 7 ? 'active' : ''}}" data-range="7" bindtap="onRangeChange">7天</view>
    <view class="range {{range === 30 ? 'active' : ''}}" data-range="30" bindtap="onRangeChange">30天</view>
  </view>

  <!-- 汇总卡（平均/最高/最低）-->
  <view class="stats-card" wx:if="{{points.length > 0}}">
    <view class="stat-item">
      <view class="stat-num">{{stats.avg}}</view>
      <view class="stat-label">平均{{typeUnit}}</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{stats.max}}</view>
      <view class="stat-label">最高</view>
    </view>
    <view class="stat-item">
      <view class="stat-num">{{stats.min}}</view>
      <view class="stat-label">最低</view>
    </view>
  </view>

  <!-- 柱状图（view 宽度模拟，参考 annual-report 范式）-->
  <view class="chart-card" wx:if="{{points.length > 0}}">
    <view class="chart">
      <view class="bar-item" wx:for="{{points}}" wx:key="index">
        <view class="bar" style="height: {{item.barHeight}}%"></view>
        <view class="bar-label" wx:if="{{item.showLabel}}">{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{points.length === 0 && !loading}}">
    <view class="empty-icon">{{typeIcon}}</view>
    <view class="empty-text">暂无{{typeLabel}}数据</view>
    <view class="empty-hint">绑定设备并测量后查看</view>
  </view>

  <!-- 最近记录 -->
  <view class="recent-card" wx:if="{{recent.length > 0}}">
    <view class="recent-title">最近记录</view>
    <view class="recent-row" wx:for="{{recent}}" wx:key="index">
      <view class="recent-time">{{item.time}}</view>
      <view class="recent-value">{{item.value}}{{typeUnit}}</view>
    </view>
  </view>
</view>
