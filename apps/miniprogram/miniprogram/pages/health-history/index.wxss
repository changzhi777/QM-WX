.page { padding-bottom: 40rpx; }

/* tab 切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 16rpx;
  margin: 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}
.tab.active {
  background: var(--brand, #0FAF8E);
  color: #fff;
  font-weight: 600;
}

/* 时间范围 */
.ranges {
  display: flex;
  margin: 0 16rpx 16rpx;
  gap: 16rpx;
}
.range {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border-radius: 12rpx;
}
.range.active {
  color: var(--brand, #0FAF8E);
  border: 2rpx solid var(--brand, #0FAF8E);
}

/* 汇总卡 */
.stats-card {
  display: flex;
  background: #fff;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 600; color: var(--brand, #0FAF8E); }
.stat-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 柱状图 */
.chart-card {
  background: #fff;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.chart {
  display: flex;
  align-items: flex-end;
  height: 300rpx;
  gap: 2rpx;
}
.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}
.bar {
  width: 100%;
  background: linear-gradient(to top, #0FAF8E, #0d9b7e);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
}
.bar-label {
  font-size: 16rpx;
  color: #999;
  margin-top: 8rpx;
  white-space: nowrap;
}

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; color: #666; margin-top: 16rpx; }
.empty-hint { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 最近记录 */
.recent-card {
  background: #fff;
  margin: 0 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.recent-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.recent-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.recent-row:last-child { border-bottom: none; }
.recent-time { font-size: 26rpx; color: #999; }
.recent-value { font-size: 28rpx; font-weight: 600; color: #333; }
