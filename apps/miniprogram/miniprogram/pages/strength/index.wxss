.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 容量概览卡 */
.volume-card {
  background: linear-gradient(135deg, #2D9D78 0%, #4FB68F 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 157, 120, 0.2);
}

.volume-card__row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.volume-card__item {
  flex: 1;
  text-align: center;
}

.volume-card__divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.volume-card__num {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.volume-card__label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.volume-card__bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 120rpx;
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar__col {
  width: 60%;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s ease;
}

.bar__date {
  font-size: 20rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

.volume-card__empty {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  opacity: 0.85;
}

/* 开始训练按钮 */
.start-btn {
  margin-top: 32rpx;
  background: #fff;
  color: #2D9D78;
  border: 2rpx solid #2D9D78;
  border-radius: 12rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}

.start-btn--loading {
  opacity: 0.5;
}

/* 历史列表 */
.section-title {
  margin-top: 40rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.session-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}

.session-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.session-item__date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.session-item__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.session-item__tag {
  background: #f5f6f8;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.session-item__volume {
  color: #2D9D78;
  font-weight: 600;
  margin-left: auto;
}

.session-item__notes {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: #f9fafb;
  padding: 12rpx;
  border-radius: 6rpx;
}
