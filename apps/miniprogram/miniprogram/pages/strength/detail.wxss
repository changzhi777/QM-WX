.container {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 80rpx 0;
}

/* 头部 */
.hero {
  background: linear-gradient(135deg, #2D9D78 0%, #4FB68F 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 157, 120, 0.2);
}

.hero__date {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
}

.hero__stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 24rpx;
}

.hero__stat {
  flex: 1;
  text-align: center;
}

.hero__stat-num {
  font-size: 36rpx;
  font-weight: 700;
}

.hero__stat-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

/* 备注 */
.notes-card {
  background: #fff;
  border-radius: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.notes-card__label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.notes-card__text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 动作组 */
.section-title {
  margin: 32rpx 0 16rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.group {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.group__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.group__count {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  margin-left: 8rpx;
}

.group__list {
  display: flex;
  flex-direction: column;
}

.set-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #333;
  border-bottom: 1rpx solid #f9fafb;
}

.set-row:last-child {
  border-bottom: none;
}

.set-row__idx {
  width: 60rpx;
  color: #2D9D78;
  font-weight: 600;
}

.set-row__detail {
  flex: 1;
}

.set-row__vol {
  color: #999;
  font-size: 24rpx;
}

/* V0.2.126 个人最佳 PB 卡 */
.pb-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.pb-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.pb-item__name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.pb-item__weight {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D9D78;
}

.pb-item__unit {
  font-size: 24rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

.pb-item__reps {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

/* V0.2.126 容量分布 */
.dist-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dist-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dist-item__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dist-item__name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dist-item__vol {
  font-size: 24rpx;
  color: #666;
  margin-right: 16rpx;
}

.dist-item__pct {
  font-size: 24rpx;
  font-weight: 600;
  color: #2D9D78;
  min-width: 80rpx;
  text-align: right;
}

.dist-item__bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.dist-item__fill {
  height: 100%;
  background: linear-gradient(90deg, #2D9D78, #4FB68F);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
