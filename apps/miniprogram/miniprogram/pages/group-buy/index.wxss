/* pages/group-buy/index.wxss — 团购列表（V0.1.37）*/
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.list { padding: 16rpx; }
.gb-card {
  display: flex;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.gb-img { width: 200rpx; height: 200rpx; border-radius: 8rpx; flex-shrink: 0; background: #f0f0f0; }
.gb-info { flex: 1; display: flex; flex-direction: column; }
.gb-name { font-size: 28rpx; color: #333; font-weight: 600; }
.gb-price-row { display: flex; align-items: baseline; gap: 12rpx; margin-top: 8rpx; }
.gb-group-price { color: #e64340; font-size: 36rpx; font-weight: 600; }
.gb-origin { color: #999; font-size: 22rpx; text-decoration: line-through; }
.gb-progress { margin-top: auto; }
.gb-progress-text { font-size: 22rpx; color: #666; margin-bottom: 6rpx; }
.gb-progress-bar { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.gb-progress-fill { height: 100%; background: linear-gradient(90deg, #fa8c16, #ffa940); }
.gb-joined-tag { font-size: 22rpx; color: #0faf8e; margin-top: 8rpx; }

.loading, .end { text-align: center; color: #999; padding: 40rpx; font-size: 24rpx; }
.empty { text-align: center; padding: 160rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 96rpx; margin-bottom: 16rpx; }
