/* pages/address/index.wxss（V0.1.23） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }
.list { padding: 16rpx; }
.empty { text-align: center; color: #999; padding: 120rpx 0; font-size: 28rpx; }
.card { padding: 24rpx; margin-bottom: 12rpx; border-radius: 12rpx; }
.name-row { display: flex; align-items: center; gap: 16rpx; }
.name { font-size: 30rpx; font-weight: 600; color: #333; }
.phone { font-size: 26rpx; color: #666; }
.default-tag { font-size: 20rpx; color: #fff; background: #0FAF8E; padding: 2rpx 12rpx; border-radius: 6rpx; }
.addr { font-size: 26rpx; color: #666; margin-top: 8rpx; line-height: 1.5; }
.actions { display: flex; gap: 24rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; justify-content: flex-end; }
.act { font-size: 24rpx; color: #0FAF8E; }
.act.danger { color: #e84; }
.add-btn { margin: 32rpx; padding: 24rpx; text-align: center; background: #0FAF8E; color: #fff; border-radius: 12rpx; font-size: 30rpx; }
.form { background: #fff; min-height: 100vh; padding: 32rpx; }
.form-title { font-size: 34rpx; font-weight: 600; margin-bottom: 32rpx; color: #333; }
.form-item { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-item .lbl { width: 160rpx; font-size: 28rpx; color: #666; }
.form-item input { flex: 1; font-size: 28rpx; }
.default-row { justify-content: space-between; }
.form-actions { display: flex; gap: 16rpx; margin-top: 48rpx; }
.btn-cancel, .btn-primary { flex: 1; font-size: 30rpx; border-radius: 8rpx; margin: 0; line-height: 80rpx; }
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-primary { background: #0FAF8E; color: #fff; }
