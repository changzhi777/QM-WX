<view class="page">
  <block wx:if="{{!showForm}}">
    <view class="list">
      <view wx:if="{{list.length === 0}}" class="empty">暂无收货地址</view>
      <view class="card bg-white" wx:for="{{list}}" wx:key="id">
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.name}}</text>
            <text class="phone">{{item.phone}}</text>
            <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
          </view>
          <view class="addr">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</view>
        </view>
        <view class="actions">
          <text wx:if="{{!item.isDefault}}" class="act" bindtap="setDefault" data-id="{{item.id}}">设为默认</text>
          <text class="act" bindtap="showEdit" data-addr="{{item}}">编辑</text>
          <text class="act danger" bindtap="remove" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
    <view class="add-btn" bindtap="showCreate">+ 新增收货地址</view>
  </block>

  <view class="form" wx:else>
    <view class="form-title">{{editingId ? '编辑地址' : '新增地址'}}</view>
    <view class="form-item"><text class="lbl">姓名</text><input value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="收货人姓名" /></view>
    <view class="form-item"><text class="lbl">电话</text><input value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="11位手机号" type="number" maxlength="11" /></view>
    <view class="form-item"><text class="lbl">省份</text><input value="{{form.province}}" data-field="province" bindinput="onInput" placeholder="省" /></view>
    <view class="form-item"><text class="lbl">城市</text><input value="{{form.city}}" data-field="city" bindinput="onInput" placeholder="市" /></view>
    <view class="form-item"><text class="lbl">区县</text><input value="{{form.district}}" data-field="district" bindinput="onInput" placeholder="区/县" /></view>
    <view class="form-item"><text class="lbl">详细地址</text><input value="{{form.detail}}" data-field="detail" bindinput="onInput" placeholder="街道门牌号" /></view>
    <view class="form-item default-row"><text class="lbl">设为默认</text><switch checked="{{form.isDefault}}" bindchange="toggleDefault" color="#0FAF8E" /></view>
    <view class="form-actions">
      <button class="btn-cancel" bindtap="cancel">取消</button>
      <button class="btn-primary" bindtap="submit">保存</button>
    </view>
  </view>
</view>
