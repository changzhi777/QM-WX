/* pages/annual-report/index.wxss — 年度报告（V0.1.27） */
.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.bg-white { background: #fff; }

/* 标题 + 年份切换 */
.header { padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.year-row { display: flex; align-items: center; justify-content: center; gap: 40rpx; }
.title { font-size: 36rpx; font-weight: 600; color: #333; min-width: 280rpx; text-align: center; }
.year-arrow { font-size: 48rpx; color: #0FAF8E; padding: 8rpx 20rpx; }

.loading, .empty { text-align: center; color: #999; padding: 80rpx; font-size: 28rpx; }

/* 年汇总大卡（品牌色渐变） */
.hero-card {
  background: linear-gradient(135deg, #0FAF8E, #0d9b7e);
  margin: 16rpx; padding: 40rpx; border-radius: 16rpx; color: #fff; text-align: center;
}
.hero-distance { font-size: 96rpx; font-weight: 700; line-height: 1.1; }
.hero-distance .u { font-size: 32rpx; margin-left: 8rpx; font-weight: 400; }
.hero-label { font-size: 26rpx; opacity: 0.9; margin-top: 8rpx; }
.hero-grid { display: flex; justify-content: space-around; margin-top: 32rpx; }
.hero-item { display: flex; flex-direction: column; align-items: center; }
.hero-item .v { font-size: 36rpx; font-weight: 600; }
.hero-item .u { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; }

/* 分段 */
.section { margin: 0 16rpx 16rpx; }
.section-title { font-size: 28rpx; color: #666; margin-bottom: 16rpx; padding-left: 8rpx; }

/* 月度柱状图 */
.chart { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.chart-row { display: flex; align-items: center; gap: 16rpx; padding: 8rpx 0; }
.chart-label { font-size: 22rpx; color: #999; width: 60rpx; }
.chart-bar-bg { flex: 1; height: 24rpx; background: #f0f0f0; border-radius: 4rpx; overflow: hidden; }
.chart-bar { height: 100%; background: #0FAF8E; border-radius: 4rpx; transition: width 0.3s; }
.chart-val { font-size: 22rpx; color: #666; width: 80rpx; text-align: right; }

/* 最长单次高亮卡 */
.highlight-card { background: #fff; border-radius: 16rpx; padding: 32rpx; text-align: center; }
.highlight-label { font-size: 26rpx; color: #666; }
.highlight-val { font-size: 56rpx; font-weight: 700; color: #fa8c16; margin: 8rpx 0; }
.highlight-date { font-size: 22rpx; color: #999; }

.footer-tip { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 24rpx; }
