.page { padding-bottom: 40rpx; }

/* 顶部 */
.header { padding: 32rpx 24rpx 16rpx; }
.header-title { font-size: 36rpx; font-weight: 600; }
.header-desc { font-size: 26rpx; color: #999; margin-top: 8rpx; }

/* 品牌宫格（3 列 flex）*/
.brand-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}
.brand-item {
  width: calc(33.33% - 11rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 0 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  border: 4rpx solid transparent;
}
.brand-item.selected {
  border-color: var(--brand, #0faf8e);
}
.brand-item.disabled {
  opacity: 0.55;
}
.brand-icon { font-size: 48rpx; }
.brand-name { font-size: 26rpx; margin-top: 8rpx; color: #333; }
.brand-cat { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.brand-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: #fff;
  background: #ccc;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

/* 展开区 */
.detail { padding: 0 16rpx; }

/* 国内源链接卡 */
.source-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.source-label { font-size: 26rpx; color: #999; margin-bottom: 12rpx; }
.source-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.source-url {
  font-size: 28rpx;
  color: var(--brand, #0faf8e);
  word-break: break-all;
  flex: 1;
}
.source-copy {
  font-size: 26rpx;
  color: #fff;
  background: var(--brand, #0faf8e);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 步骤 */
.steps {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.step { margin-bottom: 24rpx; }
.step:last-child { margin-bottom: 0; }
.step-text {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
  color: #333;
}
.step-shot {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}
.shot-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 24rpx;
}
.shot-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 跳转按钮 */
.action-btn {
  background: var(--brand, #0faf8e);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  margin-top: 8rpx;
}
.action-btn.disabled { background: #ccc; }

/* 未选中提示 */
.empty { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 64rpx; }
.empty-text { font-size: 26rpx; color: #999; margin-top: 12rpx; }

/* V0.1.43 小米上传文件树（确认格式用，阶段 2 改入库）*/
.xiaomi-files {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}
.files-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.file-row {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.file-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.file-name { font-size: 24rpx; color: #333; word-break: break-all; }
.file-preview {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  word-break: break-all;
  max-height: 240rpx;
  overflow: hidden;
}
