<view class="page">
  <!-- 顶部说明 -->
  <view class="header">
    <view class="header-title">📥 数据导入指南</view>
    <view class="header-desc">选择你的设备品牌，按步骤导入运动健康数据</view>
  </view>

  <!-- 品牌宫格（复用 DEVICE_BRANDS，4 实现 + 5 敬请期待）-->
  <view class="brand-grid">
    <view
      class="brand-item {{selectedKey === item.key ? 'selected' : ''}} {{!item.available ? 'disabled' : ''}}"
      wx:for="{{brands}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTapBrand"
    >
      <view class="brand-icon">{{item.icon}}</view>
      <view class="brand-name">{{item.name}}</view>
      <view class="brand-cat">{{item.categoryLabel}}</view>
      <view class="brand-tag" wx:if="{{!item.available}}">期待</view>
    </view>
  </view>

  <!-- 展开区（选中品牌图文说明）-->
  <view class="detail" wx:if="{{guide}}">
    <!-- 国内源链接卡 -->
    <view class="source-card" wx:if="{{guide.sourceUrl}}">
      <view class="source-label">🇨🇳 国内数据源</view>
      <view class="source-row">
        <view class="source-url">{{guide.sourceUrl}}</view>
        <view class="source-copy" bindtap="onCopyUrl">复制</view>
      </view>
    </view>

    <!-- 步骤（文字 + 截图）-->
    <view class="steps">
      <view class="step" wx:for="{{guide.steps}}" wx:for-item="step" wx:key="index">
        <view class="step-text">{{step.text}}</view>
        <view class="step-shot" wx:if="{{step.shot}}">
          <view class="shot-placeholder">📷 截图待补</view>
          <image src="{{step.shot}}" mode="aspectFit" class="shot-img"/>
        </view>
      </view>
    </view>

    <!-- 跳转按钮 -->
    <button class="action-btn {{!guide.action.available ? 'disabled' : ''}}" bindtap="onAction">
      {{guide.action.label}}
    </button>

    <!-- V0.1.43 小米上传文件树（确认格式用，阶段 2 改入库）-->
    <view class="xiaomi-files" wx:if="{{selectedKey === 'xiaomi' && xiaomiCount > 0}}">
      <view class="files-title">📦 解析到 {{xiaomiCount}} 个文件（确认格式）</view>
      <view class="file-row" wx:for="{{xiaomiFiles}}" wx:key="name">
        <view class="file-name">{{item.isDirectory ? '📁' : '📄'}} {{item.name}} ({{item.size}}B)</view>
        <view class="file-preview" wx:if="{{item.preview}}">{{item.preview}}</view>
      </view>
    </view>
  </view>

  <!-- 未选中提示 -->
  <view class="empty" wx:if="{{!guide}}">
    <view class="empty-icon">👆</view>
    <view class="empty-text">点击上方品牌查看导入步骤</view>
  </view>
</view>
