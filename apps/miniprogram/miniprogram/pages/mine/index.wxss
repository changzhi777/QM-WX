.page { min-height: 100vh; }

.header {
  background: linear-gradient(135deg, var(--brand) 0%, var(--brand-light) 100%);
  padding: 80rpx 32rpx 48rpx;
}
.user-row { display: flex; align-items: center; color: #fff; }
.avatar { width: 128rpx; height: 128rpx; border-radius: 50%; border: 4rpx solid rgba(255, 255, 255, 0.3); }
.info { flex: 1; margin-left: 24rpx; }
.nickname { font-size: 36rpx; font-weight: 600; }
.member { font-size: 24rpx; opacity: 0.85; margin-top: 8rpx; }
.arrow { color: rgba(255, 255, 255, 0.6); font-size: 36rpx; }

.stats {
  margin: -32rpx 32rpx 0; padding: 32rpx 0; border-radius: 16rpx;
  display: flex; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.stat { flex: 1; text-align: center; }
.stat .num { font-size: 36rpx; font-weight: 600; color: var(--brand); }
.stat .lbl { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }

.list { padding: 0 32rpx; }
.list-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx 0; border-bottom: 1rpx solid var(--border);
  font-size: 30rpx;
}
.list-item:last-child { border-bottom: none; }
.list-item .lbl { color: var(--text-primary); }
.list-item .arrow { color: var(--text-tertiary); }
.list-item .right { display: flex; align-items: center; gap: 12rpx; }
.badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

.list-item.contact { background: #fff; }
.list-item.contact::after { border: none; }

/* V0.1.35 入口分散引导卡（运动/商城功能已移到 tab）*/
.redirect-card {
  margin: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.redirect-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.redirect-row:last-child { border-bottom: none; }
.redirect-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0faf8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.redirect-text { flex: 1; margin-left: 20rpx; }
.redirect-title { font-size: 28rpx; font-weight: 600; color: #333; }
.redirect-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.redirect-arrow { font-size: 22rpx; color: var(--brand); flex-shrink: 0; }

.logout {
  margin: 60rpx 32rpx 0; padding: 28rpx 0; text-align: center;
  background: #fff; color: var(--danger); border-radius: 8rpx; font-size: 30rpx;
}

/* 消息弹层（V0.1.143 合并 notification）*/
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: flex-end; }
.notif-panel { background: #fff; width: 100%; border-radius: 24rpx 24rpx 0 0; padding: 32rpx; box-sizing: border-box; max-height: 80vh; display: flex; flex-direction: column; }
.notif-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.notif-title { font-size: 32rpx; font-weight: 600; color: #333; }
.notif-mark-all { font-size: 26rpx; color: var(--brand); }
.notif-loading, .notif-empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 26rpx; }
.notif-list { flex: 1; }
.notif-item { display: flex; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.notif-item.unread { background: #f8fcfb; }
.notif-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.notif-body { flex: 1; margin-left: 16rpx; }
.notif-row { display: flex; align-items: center; gap: 8rpx; }
.notif-name { font-size: 26rpx; font-weight: 600; color: #333; }
.notif-text { font-size: 26rpx; color: #666; flex: 1; }
.notif-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #ff4d4f; }
.notif-content { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.notif-time { font-size: 22rpx; color: #ccc; margin-top: 6rpx; }

/* V0.1.144 原型图我的 tab（profile-header + menu-section + hidden）*/
.profile-header { background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%); padding: 40rpx 32rpx 32rpx; color: #fff; }
.profile-row { display: flex; align-items: center; gap: 16rpx; }
.profile-header .avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 40rpx; border: none; }
.profile-info { flex: 1; }
.profile-info .name { font-size: 32rpx; font-weight: 600; }
.profile-info .status { font-size: 22rpx; opacity: 0.85; margin-top: 6rpx; }
.upgrade-btn { margin-top: 20rpx; background: rgba(255,255,255,0.2); border: 1rpx solid rgba(255,255,255,0.4); color: #fff; padding: 20rpx 24rpx; border-radius: 16rpx; font-size: 24rpx; display: flex; justify-content: space-between; align-items: center; line-height: 1.4; }
.upgrade-btn::after { border: none; }
.upgrade-btn .arrow { opacity: 0.7; }

.m-section-title { font-size: 26rpx; font-weight: 600; color: #999; padding: 24rpx 32rpx 12rpx; }
.menu-section { background: #fff; margin: 0 16rpx 16rpx; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.menu-item { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-item.contact { background: #fff; }
.menu-item.contact::after { border: none; }
.mi-icon { width: 56rpx; height: 56rpx; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; flex-shrink: 0; }
.mi-text { flex: 1; font-size: 28rpx; color: #333; }
.mi-arrow { color: #ccc; font-size: 28rpx; }
.mi-badge { background: #ff4d4f; color: #fff; font-size: 20rpx; min-width: 32rpx; height: 32rpx; line-height: 32rpx; border-radius: 16rpx; padding: 0 8rpx; text-align: center; margin-right: 8rpx; }
.new-label { background: #e8f5e9; color: #2D9D78; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 6rpx; margin-left: 8rpx; font-weight: 600; }

.hidden-section { padding: 32rpx; }
.hidden-tip { font-size: 22rpx; color: #bbb; text-align: center; }
.hidden-tags { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; margin-top: 12rpx; }
.hidden-tag { font-size: 22rpx; color: #ccc; text-decoration: line-through; }

/* ===== V0.1.152 卡片化改版 ===== */
.card { margin: 20rpx 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.user-card { padding: 28rpx; }
.user-card .user-row { display: flex; align-items: center; }
.user-card .avatar { width: 88rpx; height: 88rpx; border-radius: 50%; background: linear-gradient(135deg, #2D9D78, #1e7a5c); display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.user-card .user-info { margin-left: 20rpx; flex: 1; }
.user-card .name { font-size: 32rpx; font-weight: 600; color: #222; }
.user-card .status { font-size: 24rpx; color: #888; margin-top: 6rpx; }
.upgrade-btn { margin-top: 20rpx; background: #2D9D78; color: #fff; border-radius: 12rpx; font-size: 26rpx; display: flex; justify-content: space-between; align-items: center; padding: 0 24rpx; line-height: 76rpx; }
.upgrade-btn::after { border: none; }
.upgrade-btn .arrow { font-size: 32rpx; }

.card-title { font-size: 26rpx; font-weight: 600; color: #2D9D78; margin-bottom: 20rpx; }
.entry-grid { display: flex; flex-wrap: wrap; }
.entry-item { width: 25%; display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; }
.entry-icon { width: 88rpx; height: 88rpx; border-radius: 20rpx; background: #f0faf6; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.entry-label { font-size: 24rpx; color: #555; margin-top: 10rpx; }

.cell { display: flex; align-items: center; padding: 24rpx 8rpx; border-bottom: 1rpx solid #f5f5f5; }
.cell:last-child { border-bottom: none; }
.cell-label { flex: 1; font-size: 28rpx; color: #333; }
.cell-new { font-size: 18rpx; color: #fff; background: #2D9D78; padding: 2rpx 10rpx; border-radius: 6rpx; margin-right: 12rpx; }
.cell-badge { background: #f56c6c; color: #fff; font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 20rpx; margin-right: 12rpx; }
.cell-arrow { color: #ccc; font-size: 32rpx; }
.cell-btn { background: none; border: none; border-bottom: 1rpx solid #f5f5f5; text-align: left; color: #333; font-size: 28rpx; line-height: normal; }
.cell-btn::after { border: none; }
