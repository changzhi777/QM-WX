<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="refresh" />

  <block wx:if="{{!error}}">
  <!-- 头部 -->
  <view class="profile-header">
    <view class="profile-row" bindtap="goProfile">
      <view class="avatar">🏃</view>
      <view class="profile-info">
        <view class="name">{{user.nickname || '跑者'}}</view>
        <view class="status">{{memberLabel}} · 已绑定微信运动</view>
      </view>
    </view>
    <button class="upgrade-btn" bindtap="goMembership">
      <text>⭐ 升级季度会员 ¥99 — 解锁深度解读+无限问答</text>
      <text class="arrow">›</text>
    </button>
  </view>

  <!-- 设备与数据 -->
  <view class="m-section-title">设备与数据</view>
  <van-cell-group>
    <van-cell title="📱 设备绑定" is-link bindtap="goDeviceBind" />
    <van-cell title="📊 数据授权管理" is-link bindtap="goDeviceBind" />
  </van-cell-group>

  <!-- AI 服务 -->
  <view class="m-section-title">AI服务</view>
  <van-cell-group>
    <van-cell title="🤖 AI 私教 NEW" is-link bindtap="goAiCoach" />
    <van-cell title="📋 我的解读报告" is-link bindtap="goRunner" />
    <van-cell title="💬 问答历史" is-link bindtap="goAiCoach" />
  </van-cell-group>

  <!-- 通用 -->
  <view class="m-section-title">通用</view>
  <van-cell-group>
    <van-cell title="🔔 消息中心" is-link bindtap="onShowNotif" value="{{notifUnread > 0 ? (notifUnread > 99 ? '99+' : notifUnread) : ''}}" />
    <van-cell title="⚙️ 设置（资料/账号绑定）" is-link bindtap="goProfile" />
    <van-button open-type="contact" session-from="mine_page" block custom-style="text-align:left;border-radius:0;height:96rpx;">❓ 帮助与反馈</van-button>
    <van-cell title="📄 用户协议" is-link bindtap="goAgreement" />
  </van-cell-group>

  <!-- 隐藏功能（后续版本上线）-->
  <view class="hidden-section">
    <view class="hidden-tip">以下功能已隐藏，将在后续版本上线：</view>
    <view class="hidden-tags">
      <text class="hidden-tag">🛒 商城</text>
      <text class="hidden-tag">👟 跑鞋</text>
      <text class="hidden-tag">👥 跑群</text>
      <text class="hidden-tag">🏆 榜单</text>
      <text class="hidden-tag">📦 打卡</text>
      <text class="hidden-tag">🎯 赛事</text>
    </view>
  </view>

  <view class="logout" wx:if="{{user}}" bindtap="onTapReactivate">重新激活授权</view>
  </block>

  <!-- 消息弹层（V0.1.143 合并 notification）-->
  <view class="mask" wx:if="{{showNotif}}" bindtap="onCloseNotif">
    <view class="notif-panel" catchtap="">
      <view class="notif-header">
        <view class="notif-title">消息</view>
        <view class="notif-mark-all" wx:if="{{notifList.length}}" bindtap="onMarkAllNotif">全部已读</view>
      </view>
      <view wx:if="{{notifLoading}}" class="notif-loading">加载中…</view>
      <view wx:elif="{{notifList.length === 0}}" class="notif-empty">暂无消息 🔔</view>
      <scroll-view scroll-y class="notif-list" wx:else>
        <view class="notif-item {{item.isRead ? '' : 'unread'}}" wx:for="{{notifList}}" wx:key="id" data-item="{{item}}" bindtap="onTapNotif">
          <image class="notif-avatar" src="{{item.actor.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="notif-body">
            <view class="notif-row">
              <view class="notif-name">{{item.actor.nickname || '跑者'}}</view>
              <view class="notif-text">{{item.text}}</view>
              <view class="notif-dot" wx:if="{{!item.isRead}}"></view>
            </view>
            <view class="notif-content" wx:if="{{item.content}}">{{item.content}}</view>
            <view class="notif-time">{{item.timeText}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
