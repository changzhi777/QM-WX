<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="refresh" />

  <!-- 正常内容（error 时隐藏） -->
  <block wx:if="{{!error}}">
  <!-- 头部：用户信息 -->
  <view class="header">
    <block wx:if="{{user}}">
      <view class="user-row" bindtap="goProfile">
        <image class="avatar" src="{{user.avatarUrl || 'images/default-avatar.png'}}" mode="aspectFill" />
        <view class="info">
          <view class="nickname">{{user.nickname || '未设置昵称'}}</view>
          <view class="member">{{memberLabel}} · {{user.points}} 积分</view>
        </view>
        <view class="arrow">›</view>
      </view>
    </block>
    <block wx:else>
      <view class="user-row" bindtap="onTapLogin">
        <image class="avatar" src="images/default-avatar.png" mode="aspectFill" />
        <view class="info">
          <view class="nickname">点击登录</view>
          <view class="member">登录后享受更多服务</view>
        </view>
      </view>
    </block>
  </view>

  <!-- 跑者数据汇总（参考图 2768，stats.myRunnerStats） -->
  <view class="stats bg-white" wx:if="{{user}}">
    <view class="stat">
      <view class="num">{{runnerStats.yearDistance}}</view>
      <view class="lbl">年跑量(km)</view>
    </view>
    <view class="stat">
      <view class="num">{{runnerStats.yearCheckins}}</view>
      <view class="lbl">年打卡</view>
    </view>
    <view class="stat">
      <view class="num">{{runnerStats.totalDistance}}</view>
      <view class="lbl">总跑量(km)</view>
    </view>
    <view class="stat">
      <view class="num">{{runnerStats.avgPace || '-'}}</view>
      <view class="lbl">平均配速</view>
    </view>
  </view>

  <!-- 佳明运动数据（B-2，2026-07-01） -->
  <view class="stats bg-white mt-2" wx:if="{{user}}" style="display:block;padding:24rpx;">
    <view style="font-size:30rpx;font-weight:600;margin-bottom:16rpx;">佳明运动数据</view>
    <view wx:if="{{garminLoading}}" style="color:#999;font-size:26rpx;">加载中…</view>
    <block wx:elif="{{garminActivities.length}}">
      <view wx:for="{{garminActivities}}" wx:key="id" style="display:flex;justify-content:space-between;align-items:center;padding:14rpx 0;border-bottom:1rpx solid #f0f0f0;">
        <view style="font-size:28rpx;flex:1;">{{item.name || item.type}}</view>
        <view style="font-size:26rpx;color:#666;">{{item.distanceKm}}km · {{item.durationMin}}min</view>
      </view>
    </block>
    <view wx:else style="color:#999;font-size:26rpx;">暂无佳明数据</view>
  </view>

  <!-- 功能列表 -->
  <view class="list bg-white mt-2">
    <view class="list-item" bindtap="goNotification">
      <view class="lbl">消息中心</view>
      <view class="right">
        <view class="badge" wx:if="{{notifUnread > 0}}">{{notifUnread > 99 ? '99+' : notifUnread}}</view>
        <view class="arrow">›</view>
      </view>
    </view>

    <feature-gate flag="wallet">
      <view class="list-item" bindtap="goWallet">
        <view class="lbl">我的钱包</view>
        <view class="arrow">›</view>
      </view>
    </feature-gate>

    <feature-gate flag="membershipPurchase">
      <view class="list-item" bindtap="goMembership">
        <view class="lbl">会员中心</view>
        <view class="arrow">›</view>
      </view>
    </feature-gate>

    <view class="list-item" bindtap="goProfile">
      <view class="lbl">个人资料</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goOrderList">
      <view class="lbl">我的订单</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goCategory">
      <view class="lbl">全部商品</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goCart">
      <view class="lbl">购物车</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goCoupon">
      <view class="lbl">优惠券</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goPoints">
      <view class="lbl">积分中心</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goAddress">
      <view class="lbl">地址管理</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goDistribution">
      <view class="lbl">分销中心</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goTiantian">
      <view class="lbl">天天跑</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goContent">
      <view class="lbl">赛事 / 本地服务</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goFavorite">
      <view class="lbl">我的收藏</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goFeed">
      <view class="lbl">运动动态</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goWeeklyReport">
      <view class="lbl">跑群周报</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goHealth">
      <view class="lbl">今日健康</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goDeviceBind">
      <view class="lbl">设备绑定</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goTraining">
      <view class="lbl">锻炼训练</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goShoes">
      <view class="lbl">我的跑鞋</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goAnnualReport">
      <view class="lbl">年度报告</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goGoal">
      <view class="lbl">跑步目标</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goCertificate">
      <view class="lbl">我的证书</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goGarminData">
      <view class="lbl">佳明数据处理</view>
      <view class="arrow">›</view>
    </view>

    <view class="list-item" bindtap="goRanking">
      <view class="lbl">我的榜单</view>
      <view class="arrow">›</view>
    </view>

    <feature-gate flag="bindApp">
      <view class="list-item" bindtap="goBindApp">
        <view class="lbl">绑定运动 APP</view>
        <view class="arrow">›</view>
      </view>
    </feature-gate>

    <button
      class="list-item contact"
      open-type="contact"
      session-from="mine_page"
    >
      <view class="lbl">联系客服</view>
      <view class="arrow">›</view>
    </button>

    <view class="list-item" bindtap="goAgreement">
      <view class="lbl">用户协议与隐私政策</view>
      <view class="arrow">›</view>
    </view>
  </view>

  <view class="logout" wx:if="{{user}}" bindtap="onTapLogout">
    退出登录
  </view>
  </block>
</view>
