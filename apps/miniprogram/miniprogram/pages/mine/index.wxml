<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="refresh" />

  <block wx:if="{{!error}}">
    <!-- 顶部：融合 level-card（头像+名字+成长等级+积分进度）替代原 user-card -->
    <level-card
      wx:if="{{user}}"
      growth-level="{{growthLevel}}"
      total-points-earned="{{totalPointsEarned}}"
      nickname="{{user.nickname || '跑者'}}"
      avatar="🏃"
      member-level="{{memberLevel}}"
    />

    <!-- 非会员升级入口（原型 profile-header 升级按钮）-->
    <view class="upgrade-cell" wx:if="{{!isMember}}" bindtap="goMembership">
      <text class="upgrade-text">⭐ 升级会员 — 解锁完整解读 + 无限问答</text>
      <text class="mi-arrow">›</text>
    </view>

    <!-- 设备与数据 -->
    <view class="section">
      <view class="section-title">设备与数据</view>
      <view class="menu-section">
        <view class="menu-item" bindtap="goDeviceBind">
          <view class="mi-icon bg-green">📱</view>
          <view class="mi-text">设备绑定</view>
          <view class="mi-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goProfile">
          <view class="mi-icon bg-blue">📊</view>
          <view class="mi-text">数据授权管理</view>
          <view class="mi-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- AI服务 -->
    <view class="section">
      <view class="section-title">健康服务</view>
      <view class="menu-section">
        <view class="menu-item" bindtap="goAiCoach">
          <view class="mi-icon bg-purple">🤖</view>
          <view class="mi-text">健康助手 <text class="new-label">NEW</text></view>
          <view class="mi-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goRunner">
          <view class="mi-icon bg-orange">📋</view>
          <view class="mi-text">我的解读报告</view>
          <view class="mi-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goAiCoach">
          <view class="mi-icon bg-pink">💬</view>
          <view class="mi-text">问答历史</view>
          <view class="mi-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 通用 -->
    <view class="section">
      <view class="section-title">通用</view>
      <view class="menu-section">
        <view class="menu-item" bindtap="onShowNotif">
          <view class="mi-icon bg-cyan">🔔</view>
          <view class="mi-text">消息中心</view>
          <text class="mi-badge" wx:if="{{notifUnread > 0}}">{{notifUnread > 99 ? '99+' : notifUnread}}</text>
          <view class="mi-arrow">›</view>
        </view>
        <view class="menu-item" bindtap="goProfile">
          <view class="mi-icon bg-gray">⚙️</view>
          <view class="mi-text">设置</view>
          <view class="mi-arrow">›</view>
        </view>
        <button class="menu-item cell-btn" open-type="contact" session-from="mine_page">
          <view class="mi-icon bg-gray">❓</view>
          <view class="mi-text">帮助与反馈</view>
          <view class="mi-arrow">›</view>
        </button>
        <view class="menu-item" bindtap="goAgreement">
          <view class="mi-icon bg-gray">📄</view>
          <view class="mi-text">用户服务协议</view>
          <view class="mi-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 更多功能（待定入口 → pages/more）-->
    <view class="section">
      <view class="menu-section">
        <view class="menu-item" bindtap="goMore">
          <view class="mi-icon bg-more">📋</view>
          <view class="mi-text">
            更多功能
            <view class="mi-sub">打卡/跑鞋/训练/榜单/健康/饮食/动态/赛事</view>
          </view>
          <view class="mi-arrow">›</view>
        </view>
      </view>
    </view>

    <view class="logout" wx:if="{{user}}" bindtap="onTapReactivate">重新激活授权</view>
  </block>

  <!-- 消息弹层（V0.1.143 合并 notification，保留）-->
  <view class="mask" wx:if="{{showNotif}}" bindtap="onCloseNotif">
    <view class="notif-panel" catchtap="">
      <view class="notif-header">
        <view class="notif-title">消息</view>
        <view class="notif-mark-all" wx:if="{{notifList.length}}" bindtap="onMarkAllNotif">全部已读</view>
      </view>
      <view wx:if="{{notifLoading}}" class="notif-loading">加载中…</view>
      <view wx:elif="{{notifList.length === 0}}" class="notif-empty">暂无消息</view>
      <scroll-view scroll-y class="notif-list" wx:else>
        <view class="notif-item {{item.isRead ? '' : 'unread'}}" wx:for="{{notifList}}" wx:key="id" data-item="{{item}}" bindtap="onTapNotif">
          <image class="notif-avatar" src="{{item.actor.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="notif-body">
            <view class="notif-row">
              <view class="notif-name">{{item.actor.nickname || '跑者'}}</view>
              <view class="notif-text">{{item.text}}</view>
              <view class="notif-dot" wx:if="{{!item.isRead}}"></view>
            </view>
            <view class="notif-content" wx:if="{{item.content}}">{{item.content}}</view>
            <view class="notif-time">{{item.timeText}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
