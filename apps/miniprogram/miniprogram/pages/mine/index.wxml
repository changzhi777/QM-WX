<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="refresh" />

  <block wx:if="{{!error}}">
  <!-- A 用户卡（V0.1.152 卡片化）-->
  <view class="card user-card">
    <view class="user-row" bindtap="goProfile">
      <view class="avatar">🏃</view>
      <view class="user-info">
        <view class="name">{{user.nickname || '跑者'}}</view>
        <view class="status">{{memberLabel}} · 已绑定微信运动</view>
      </view>
    </view>
    <button class="upgrade-btn" bindtap="goMembership">
      <text>升级季度会员 ¥99 — 解锁深度解读+无限问答</text>
      <text class="arrow">›</text>
    </button>
  </view>

  <!-- B 运动入口卡（4 列网格，V0.1.152 隐藏功能上线 + 上传数据包新）-->
  <view class="card">
    <view class="card-title">运动</view>
    <view class="entry-grid">
      <view class="entry-item" bindtap="goSportTab"><view class="entry-icon">🏃</view><view class="entry-label">打卡</view></view>
      <view class="entry-item" bindtap="goShoes"><view class="entry-icon">👟</view><view class="entry-label">跑鞋</view></view>
      <view class="entry-item" bindtap="goTraining"><view class="entry-icon">📋</view><view class="entry-label">训练</view></view>
      <view class="entry-item" bindtap="goRanking"><view class="entry-icon">🏆</view><view class="entry-label">榜单</view></view>
      <view class="entry-item" bindtap="goDeviceBind"><view class="entry-icon">📤</view><view class="entry-label">上传数据</view></view>
      <view class="entry-item" bindtap="goContent"><view class="entry-icon">🎯</view><view class="entry-label">赛事</view></view>
      <view class="entry-item" bindtap="goFeed"><view class="entry-icon">📰</view><view class="entry-label">动态</view></view>
      <view class="entry-item" bindtap="goHealth"><view class="entry-icon">❤️</view><view class="entry-label">健康</view></view>
    </view>
  </view>

  <!-- C AI 服务卡 -->
  <view class="card">
    <view class="card-title">AI 服务</view>
    <view class="cell" bindtap="goAiCoach"><text class="cell-label">AI 私教</text><text class="cell-new">NEW</text><text class="cell-arrow">›</text></view>
    <view class="cell" bindtap="goRunner"><text class="cell-label">我的解读报告</text><text class="cell-arrow">›</text></view>
  </view>

  <!-- D 设置卡 -->
  <view class="card">
    <view class="cell" bindtap="onShowNotif">
      <text class="cell-label">消息中心</text>
      <text class="cell-badge" wx:if="{{notifUnread > 0}}">{{notifUnread > 99 ? '99+' : notifUnread}}</text>
      <text class="cell-arrow">›</text>
    </view>
    <view class="cell" bindtap="goProfile"><text class="cell-label">设置（资料/账号绑定）</text><text class="cell-arrow">›</text></view>
    <button class="cell cell-btn" open-type="contact" session-from="mine_page">帮助与反馈</button>
    <view class="cell" bindtap="goAgreement"><text class="cell-label">用户协议</text><text class="cell-arrow">›</text></view>
  </view>

  <view class="logout" wx:if="{{user}}" bindtap="onTapReactivate">重新激活授权</view>
  </block>

  <!-- 消息弹层（V0.1.143 合并 notification，保留）-->
  <view class="mask" wx:if="{{showNotif}}" bindtap="onCloseNotif">
    <view class="notif-panel" catchtap="">
      <view class="notif-header">
        <view class="notif-title">消息</view>
        <view class="notif-mark-all" wx:if="{{notifList.length}}" bindtap="onMarkAllNotif">全部已读</view>
      </view>
      <view wx:if="{{notifLoading}}" class="notif-loading">加载中…</view>
      <view wx:elif="{{notifList.length === 0}}" class="notif-empty">暂无消息</view>
      <scroll-view scroll-y class="notif-list" wx:else>
        <view class="notif-item {{item.isRead ? '' : 'unread'}}" wx:for="{{notifList}}" wx:key="id" data-item="{{item}}" bindtap="onTapNotif">
          <image class="notif-avatar" src="{{item.actor.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="notif-body">
            <view class="notif-row">
              <view class="notif-name">{{item.actor.nickname || '跑者'}}</view>
              <view class="notif-text">{{item.text}}</view>
              <view class="notif-dot" wx:if="{{!item.isRead}}"></view>
            </view>
            <view class="notif-content" wx:if="{{item.content}}">{{item.content}}</view>
            <view class="notif-time">{{item.timeText}}</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
