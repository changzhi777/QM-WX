/* pages/health/index.wxss — 今日健康看板（参考图 2774） */
.page { min-height: 100vh; background: #f5f5f5; padding: 16rpx; padding-bottom: 40rpx; box-sizing: border-box; }
.bg-white { background: #fff; }

/* 标题 */
.header { padding: 32rpx; border-radius: 16rpx; margin-bottom: 16rpx; }
.header .title { font-size: 36rpx; font-weight: 600; color: #333; }
.header .subtitle { font-size: 26rpx; color: #999; margin-top: 8rpx; }

.loading, .empty-page { text-align: center; color: #999; padding: 80rpx 0; font-size: 28rpx; }

/* 通用卡片 */
.card { background: #fff; border-radius: 16rpx; }
.card-title { font-size: 26rpx; color: #888; margin-bottom: 12rpx; }

/* 今日运动大卡 */
.activity-card { padding: 24rpx; margin-bottom: 16rpx; }
.activity-grid { display: flex; justify-content: space-around; }
.activity-grid .metric { display: flex; align-items: baseline; gap: 4rpx; }
.activity-grid .v { font-size: 40rpx; font-weight: 600; color: #0FAF8E; }
.activity-grid .u { font-size: 22rpx; color: #999; }

/* 健康指标 2 列网格 */
.grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.metric-card { width: calc(50% - 8rpx); padding: 24rpx; box-sizing: border-box; }
.big-num { font-size: 48rpx; font-weight: 600; color: #333; margin: 8rpx 0 12rpx; }
.big-num .u { font-size: 24rpx; color: #999; margin-left: 4rpx; font-weight: 400; }
.sub-row { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.empty { font-size: 24rpx; color: #ccc; margin-top: 24rpx; }

/* 占位卡（无数据源） */
.metric-card.placeholder { background: #fafafa; border: 1rpx dashed #e0e0e0; }
.placeholder-text { font-size: 22rpx; color: #bbb; margin-top: 24rpx; }

/* 体成分卡（紫色渐变，最新一次体脂秤测量） */
.body-comp-card { padding: 28rpx; margin-bottom: 16rpx; background: linear-gradient(135deg, #7B61FF 0%, #B57BFF 100%); color: #fff; }
.bc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.bc-title { font-size: 28rpx; font-weight: 600; }
.bc-ts { font-size: 22rpx; color: rgba(255,255,255,0.75); }
.bc-main { display: flex; align-items: baseline; gap: 24rpx; margin-bottom: 24rpx; }
.bc-weight { font-size: 64rpx; font-weight: 700; }
.bc-weight .u { font-size: 28rpx; font-weight: 400; margin-left: 4rpx; }
.bc-bmi { font-size: 26rpx; color: rgba(255,255,255,0.9); }
.bc-grid { display: flex; flex-wrap: wrap; gap: 16rpx 0; }
.bc-item { width: 33.33%; display: flex; flex-direction: column; gap: 4rpx; box-sizing: border-box; }
.bc-label { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.bc-val { font-size: 30rpx; font-weight: 600; }

/* 体成分引导卡（未测量） */
.body-comp-empty { padding: 32rpx; margin-bottom: 16rpx; }
.bc-empty-title { font-size: 28rpx; font-weight: 600; color: #333; }
.bc-empty-tip { font-size: 24rpx; color: #999; margin-top: 12rpx; line-height: 1.5; }
.bc-empty-btn { font-size: 26rpx; color: #7B61FF; margin-top: 20rpx; font-weight: 600; }

.footer-tip { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 24rpx; }
