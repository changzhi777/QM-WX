<view class="page">
  <view class="header bg-white p-4">
    <view class="title">跑群周报</view>
    <view class="text-sm text-secondary mt-2">每周自动生成 · 战报可分享到群</view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{reports.length === 0}}" class="empty">
    本周还没有数据
    <view class="text-sm text-secondary mt-2">加入一个跑群开始打卡吧</view>
  </view>
  <view wx:else class="list">
    <view
      class="card bg-white m-2 p-4 rounded-lg shadow"
      wx:for="{{reports}}"
      wx:key="groupId"
      data-id="{{item.groupId}}"
      bindtap="onSelectReport"
    >
      <view class="card-head">
        <view class="g-name">{{item.groupName}}</view>
        <view class="period text-sm text-secondary">{{item.period}}</view>
      </view>
      <view class="card-stats mt-2">
        <view class="stat">
          <view class="num">{{item.totalDistance}}</view>
          <view class="lbl">公里</view>
        </view>
        <view class="stat">
          <view class="num">{{item.totalCheckins}}</view>
          <view class="lbl">打卡</view>
        </view>
        <view class="stat">
          <view class="num">{{item.totalMembers}}</view>
          <view class="lbl">参与</view>
        </view>
      </view>
      <view class="card-champion" wx:if="{{item.champion}}">
        🏆 冠军：<text class="champion-name">{{item.champion.nickname}}</text>
        <text class="champion-distance"> · {{item.champion.distance}} km</text>
      </view>
      <view class="card-action">查看战报 ›</view>
    </view>
  </view>

  <!-- 战报图全屏弹窗 -->
  <view class="poster-mask" wx:if="{{current}}" bindtap="onClosePoster">
    <view class="poster-card" catchtap="">
      <view class="poster-canvas-wrap">
        <canvas
          type="2d"
          id="posterCanvas"
          class="poster-canvas"
          style="width: 750rpx; height: 1200rpx;"
        />
      </view>
      <view class="poster-actions">
        <button class="btn-cancel" bindtap="onSubscribe">订阅下周报</button>
        <button class="btn-primary" bindtap="onSavePoster">保存到相册</button>
      </view>
    </view>
  </view>
</view>
