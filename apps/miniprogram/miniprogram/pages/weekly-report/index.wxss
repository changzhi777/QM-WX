.page { padding-bottom: 40rpx; min-height: 100vh; background: #f5f5f5; }

.header .title { font-size: 36rpx; font-weight: 600; }
.empty { padding: 80rpx 0; text-align: center; color: var(--text-tertiary); }

.list .card-head { display: flex; justify-content: space-between; align-items: center; }
.list .g-name { font-size: 32rpx; font-weight: 600; }
.list .card-stats { display: flex; }
.list .stat { flex: 1; text-align: center; }
.list .stat .num { font-size: 36rpx; font-weight: 600; color: var(--brand); }
.list .stat .lbl { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.list .card-champion {
  margin-top: 16rpx; padding: 12rpx 16rpx; background: #FFF8E1;
  border-radius: 8rpx; font-size: 26rpx;
}
.list .champion-name { color: #FF6B35; font-weight: 600; }
.list .champion-distance { color: var(--text-secondary); }
.list .card-action { text-align: right; color: var(--brand); margin-top: 16rpx; font-size: 26rpx; }

.poster-mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.7);
  display: flex; align-items: center; justify-content: center; z-index: 999;
}
.poster-card {
  width: 750rpx; max-height: 90vh; overflow-y: auto;
  background: transparent; display: flex; flex-direction: column; align-items: center;
}
.poster-canvas-wrap {
  width: 750rpx; height: 1200rpx; background: #fff; border-radius: 16rpx; overflow: hidden;
}
.poster-canvas { display: block; }

.poster-actions {
  display: flex; gap: 16rpx; margin-top: 32rpx; width: 100%; padding: 0 32rpx; box-sizing: border-box;
}
.poster-actions button {
  flex: 1; height: 88rpx; line-height: 88rpx; border-radius: 8rpx; font-size: 28rpx; border: none;
}
.btn-cancel { background: #fff; color: var(--text-primary); }
.btn-cancel::after { border: none; }
.btn-primary { background: var(--brand); color: #fff; }
.btn-primary::after { border: none; }
