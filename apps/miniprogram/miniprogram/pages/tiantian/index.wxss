/* 天天跑首页（参考 2767） */
.page { min-height: 100vh; background: #f5f6f8; padding-bottom: 40rpx; }

.search {
  margin: 20rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  display: flex;
  align-items: center;
}
.search-ico { font-size: 28rpx; margin-right: 12rpx; }
.search-ph { color: #bbb; font-size: 26rpx; }

.entries {
  display: flex;
  margin: 0 20rpx 20rpx;
  gap: 16rpx;
}
.entry {
  flex: 1;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  color: #fff;
  text-align: center;
}
.entry-run { background: linear-gradient(135deg, #0FAF8E, #0d8a72); }
.entry-act { background: linear-gradient(135deg, #f0a020, #d97e0a); }
.entry-ck { background: linear-gradient(135deg, #4a90e2, #357ab8); }
.entry-title { font-size: 30rpx; font-weight: 700; }
.entry-sub { font-size: 22rpx; opacity: 0.9; margin-top: 6rpx; }

.banner {
  margin: 0 20rpx 20rpx;
  background: linear-gradient(135deg, #fff4e0, #ffe4c4);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.banner-txt { font-size: 26rpx; color: #8a5a0a; font-weight: 600; }
.banner-act { font-size: 24rpx; color: #d97e0a; }

.grid {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  display: flex;
  flex-wrap: wrap;
}
.grid-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}
.grid-ico { font-size: 44rpx; }
.grid-txt { font-size: 22rpx; color: #666; margin-top: 6rpx; }

.section { margin: 0 20rpx; }
.section-hd {
  background: linear-gradient(90deg, #ff7a45, #f0a020);
  border-radius: 16rpx 16rpx 0 0;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: baseline;
}
.section-title { font-size: 30rpx; font-weight: 700; color: #fff; }
.section-sub { font-size: 22rpx; color: rgba(255,255,255,0.9); margin-left: 16rpx; }

.loading, .empty { text-align: center; color: #999; font-size: 26rpx; padding: 60rpx 0; background: #fff; }

.goods {
  background: #fff;
  padding: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  border-radius: 0 0 16rpx 16rpx;
}
.good {
  width: calc(50% - 8rpx);
  background: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
}
.good-img { width: 100%; height: 300rpx; background: #f0f0f0; }
.good-name { font-size: 26rpx; color: #333; padding: 12rpx 16rpx 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.good-price-row { padding: 0 16rpx 16rpx; display: flex; align-items: baseline; }
.good-price { font-size: 32rpx; color: #e0514a; font-weight: 700; }
.good-orig { font-size: 22rpx; color: #bbb; text-decoration: line-through; margin-left: 12rpx; }
