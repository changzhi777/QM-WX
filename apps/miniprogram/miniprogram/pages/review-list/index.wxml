<view class="page">
  <view class="summary bg-white m-2 p-4 rounded-lg shadow" wx:if="{{stats.count > 0}}">
    <view class="avg-row">
      <text class="avg">{{stats.avg}}</text>
      <text class="avg-unit">分</text>
      <text class="count">{{stats.count}} 条评价</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无评价</view>

  <view class="card bg-white m-2 p-4 rounded-lg shadow" wx:for="{{list}}" wx:key="id">
    <view class="review-head">
      <image class="avatar" src="{{item.user.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <text class="name">{{item.user.nickname || '匿名用户'}}</text>
      <text class="stars">{{item.rating}}★</text>
      <text class="date">{{item.createdAt}}</text>
    </view>
    <view class="content" wx:if="{{item.content}}">{{item.content}}</view>
    <view class="images" wx:if="{{item.images.length > 0}}">
      <image
        wx:for="{{item.images}}"
        wx:key="*this"
        wx:for-item="img"
        class="img"
        src="{{img}}"
        mode="aspectFill"
        data-current="{{img}}"
        data-urls="{{item.images}}"
        bindtap="onPreviewImage"
      />
    </view>
  </view>

  <view class="loading-more" wx:if="{{loading}}">加载中...</view>
  <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
</view>
