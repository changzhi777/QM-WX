.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.summary { }
.avg-row { display: flex; align-items: baseline; gap: 8rpx; }
.avg { font-size: 56rpx; font-weight: 700; color: #ffb800; }
.avg-unit { font-size: 26rpx; color: #999; }
.count { font-size: 24rpx; color: var(--text-tertiary); margin-left: 16rpx; }
.empty { padding: 120rpx 0; text-align: center; color: var(--text-tertiary); font-size: 28rpx; }
.card { }
.review-head { display: flex; align-items: center; gap: 12rpx; }
.avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: #f0f0f0; flex-shrink: 0; }
.name { font-size: 26rpx; color: #333; flex: 1; }
.stars { font-size: 24rpx; color: #ffb800; }
.date { font-size: 22rpx; color: var(--text-tertiary); }
.content { font-size: 28rpx; color: #333; line-height: 1.5; margin-top: 12rpx; }
.images { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; }
.img { width: 200rpx; height: 200rpx; border-radius: 8rpx; background: #f0f0f0; }
.loading-more, .no-more { text-align: center; color: var(--text-tertiary); font-size: 24rpx; padding: 24rpx 0; }
