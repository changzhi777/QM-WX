/* AI 私教（V0.1.140 UI/UX 优化）*/
.coach-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f0faf7 0%, #f5f5f5 40%);
}

/* 人设切换（A）*/
.persona-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #eee;
}
.persona-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}
.persona-chip.active {
  background: linear-gradient(135deg, #0FAF8E, #0d9b7e);
  box-shadow: 0 4rpx 12rpx rgba(15, 175, 142, 0.3);
}
.persona-emoji { font-size: 32rpx; }
.persona-label { font-size: 22rpx; color: #666; margin-top: 4rpx; }
.persona-chip.active .persona-label { color: #fff; }

/* 操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.top-bar .title { font-size: 30rpx; font-weight: 600; color: #333; }
.top-actions { display: flex; gap: 16rpx; }
.op-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  background: #f5f5f5;
  border-radius: 50%;
}
.op-btn.disabled { opacity: 0.4; }
.share-btn {
  padding: 0;
  margin: 0;
  border: none;
}
.share-btn::after { border: none; }

/* 消息列表 */
.msg-list { flex: 1; padding: 24rpx; box-sizing: border-box; }
.msg { display: flex; flex-direction: column; margin-bottom: 24rpx; }
.msg.user { align-items: flex-end; }
.msg.assistant { align-items: flex-start; }
.bubble {
  max-width: 76%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.msg.user .bubble {
  background: linear-gradient(135deg, #0FAF8E, #0d9b7e);
  color: #fff;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(15, 175, 142, 0.2);
}
.msg.assistant .bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* B 建议卡片 */
.suggestions { margin-top: 12rpx; width: 76%; }
.sug-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-left: 6rpx solid #0FAF8E;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}
.sug-card.sug-addGoal { border-left-color: #ff9800; }
.sug-card.sug-adoptPlan { border-left-color: #2196f3; }
.sug-icon { font-size: 28rpx; margin-right: 12rpx; }
.sug-label { flex: 1; font-size: 26rpx; color: #333; }
.sug-arrow { color: #0FAF8E; font-size: 28rpx; }

.regen-row { display: flex; justify-content: center; padding: 4rpx 0 24rpx; }
.regen-row view {
  font-size: 24rpx;
  color: #0FAF8E;
  padding: 8rpx 24rpx;
  border: 1rpx solid #0FAF8E;
  border-radius: 24rpx;
}

/* 快捷问题 */
.quick-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.quick-chip {
  font-size: 24rpx;
  color: #0FAF8E;
  background: #f0faf7;
  padding: 12rpx 22rpx;
  border-radius: 24rpx;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.voice-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  margin-right: 12rpx;
}
.input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.send-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #0FAF8E, #0d9b7e);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.send-btn.disabled { opacity: 0.4; }
.stop-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ff6b6b;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 会话弹层 */
.conv-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.conv-panel {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.conv-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #eee;
}
.conv-title { font-size: 30rpx; font-weight: 600; color: #333; }
.conv-close { font-size: 32rpx; color: #999; padding: 0 8rpx; }
.conv-list { max-height: 56vh; }
.conv-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.conv-info { flex: 1; min-width: 0; }
.conv-msg {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.conv-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.conv-del { font-size: 32rpx; color: #ff6b6b; padding: 8rpx 16rpx; flex-shrink: 0; }
.conv-empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }
