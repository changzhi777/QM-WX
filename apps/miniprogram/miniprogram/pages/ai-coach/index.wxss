/* 健康助手（V0.2.4 改版：原 AI 私教）*/
.coach-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f0faf7 0%, #f5f5f5 40%);
}

/* V0.2.30 AI 建议气泡（原型 chat-preview，今日 dailyReport reportText）*/
.ai-advice-preview { padding: 16rpx 24rpx; }
.preview-title { font-size: 26rpx; color: #888; margin-bottom: 12rpx; }
.ai-bubble {
  background: #fff;
  border-left: 6rpx solid #2D9D78;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.ai-bubble-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #2D9D78;
  background: rgba(45,157,120,0.12);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.ai-bubble-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 人设切换（A）*/
.persona-bar {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid #eee;
}
.persona-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.2s;
}
.persona-chip.active {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  box-shadow: 0 4rpx 12rpx rgba(15, 175, 142, 0.3);
}
.persona-emoji { font-size: 32rpx; }
.persona-label { font-size: 22rpx; color: #666; margin-top: 4rpx; }
.persona-chip.active .persona-label { color: #fff; }

/* 操作栏（4 按钮均分全宽，V0.2.4）*/
.top-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%);
  position: sticky;
  top: 0;
  z-index: 11;
}
.top-actions { display: flex; gap: 12rpx; flex: 1; }
.op-btn {
  flex: 1;
  padding: 14rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.op-btn:active { background: rgba(255,255,255,0.35); }
.op-btn.disabled { opacity: 0.4; }
.share-btn {
  padding: 14rpx 0;
  margin: 0;
  border: 1rpx solid rgba(255,255,255,0.3);
}
.share-btn::after { border: none; }

/* 消息列表 */
.msg-list { flex: 1; padding: 24rpx; box-sizing: border-box; }
.msg { display: flex; flex-direction: column; margin-bottom: 24rpx; }
.msg.user { align-items: flex-end; }
.msg.assistant { align-items: flex-start; }
.bubble {
  max-width: 76%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.msg.user .bubble {
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 157, 120, 0.25);
}
.msg.assistant .bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* B 建议卡片 */
.suggestions { margin-top: 12rpx; width: 76%; }
.sug-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-left: 6rpx solid #2D9D78;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.sug-card.sug-addGoal { border-left-color: #ff9800; }
.sug-card.sug-adoptPlan { border-left-color: #2196f3; }
.sug-icon { font-size: 28rpx; margin-right: 12rpx; }
.sug-label { flex: 1; font-size: 26rpx; color: #333; }
.sug-arrow { color: #2D9D78; font-size: 28rpx; }

.regen-row { display: flex; justify-content: center; padding: 4rpx 0 24rpx; }
.regen-row view {
  font-size: 24rpx;
  color: #2D9D78;
  padding: 10rpx 28rpx;
  border: 1rpx solid #2D9D78;
  border-radius: 24rpx;
}

/* 快速提问（批 1：横滚胶囊，纠 V0.2.4 网格改错）*/
.quick-section { padding: 16rpx 24rpx; background: #f5f6f8; border-top: 1rpx solid #eee; }
.quick-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.quick-scroll { white-space: nowrap; }
.quick-chip {
  display: inline-block;
  font-size: 26rpx;
  color: #2D9D78;
  background: #fff;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  margin-right: 12rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}
.quick-chip:active { background: #f0faf7; }

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  gap: 12rpx;
}
.input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.send-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #2D9D78, #1a7a5a);
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.send-btn.disabled { opacity: 0.4; }
.stop-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ff6b6b;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 会话弹层 */
.conv-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.conv-panel {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.conv-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #eee;
}
.conv-title { font-size: 30rpx; font-weight: 600; color: #333; }
.conv-close { font-size: 32rpx; color: #999; padding: 0 8rpx; }
.conv-list { max-height: 56vh; }
.conv-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.conv-info { flex: 1; min-width: 0; }
.conv-msg {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.conv-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.conv-del { font-size: 32rpx; color: #ff6b6b; padding: 8rpx 16rpx; flex-shrink: 0; }
.conv-empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }

/* V0.1.144 头部：健康助手 + 健康提醒 + AI 主动提醒 */
.ai-header { background: linear-gradient(135deg, #2D9D78 0%, #1a7a5a 100%); color: #fff; padding: 24rpx 32rpx 28rpx; }
.ai-page-title { font-size: 36rpx; font-weight: 600; }
.ai-page-sub { font-size: 24rpx; opacity: 0.9; margin: 6rpx 0 16rpx; }

.ai-alert-card { margin: 16rpx; background: linear-gradient(135deg, #fff8e1, #fff3cd); border-radius: 16rpx; padding: 20rpx; display: flex; gap: 12rpx; align-items: flex-start; border: 1rpx solid #ffe082; }
.ai-alert-icon { font-size: 32rpx; flex-shrink: 0; }
.ai-alert-body { flex: 1; }
.ai-alert-title { font-size: 24rpx; font-weight: 600; color: #e65100; margin-bottom: 6rpx; }
.ai-alert-text { font-size: 24rpx; color: #795548; line-height: 1.5; }

/* V0.1.144 AI 等待动画（pending + 首个 token 未到）*/
.thinking { display: flex; align-items: center; gap: 12rpx; }
.thinking-text { font-size: 26rpx; color: #999; }
