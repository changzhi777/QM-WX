<!-- AI 私教（V0.1.140 UI/UX 优化 — 人设切换 + 建议卡片 + 图标操作 + voice）-->
<view class="coach-page">
  <!-- 人设切换（A）-->
  <view class="persona-bar">
    <view
      wx:for="{{personaList}}"
      wx:key="key"
      class="persona-chip {{persona === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSelectPersona"
    >
      <text class="persona-emoji">{{item.emoji}}</text>
      <text class="persona-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="top-bar">
    <view class="title">AI 私教</view>
    <view class="top-actions">
      <view class="op-btn {{sending ? 'disabled' : ''}}" bindtap="onTapGeneratePlan">📋</view>
      <view class="op-btn {{sending ? 'disabled' : ''}}" bindtap="onNewChat">✨</view>
      <view class="op-btn {{sending ? 'disabled' : ''}}" bindtap="onShowConversations">💬</view>
      <button class="op-btn share-btn" open-type="share">📤</button>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation enhanced show-scrollbar="{{false}}">
    <view wx:for="{{messages}}" wx:key="index" class="msg {{item.role}}">
      <block wx:if="{{item.type === 'plan'}}">
        <plan-card plan="{{item.plan}}" bind:adopt="onAdoptPlan" bind:regenerate="onRegeneratePlan" bind:tweak="onTweakPlan" />
      </block>
      <block wx:else>
        <view class="bubble">
          <text>{{item.content}}{{item.pending ? '▍' : ''}}</text>
        </view>
        <!-- B 建议卡片（正则提取 📋建议：）-->
        <view wx:if="{{item.suggestions && item.suggestions.length}}" class="suggestions">
          <view
            wx:for="{{item.suggestions}}"
            wx:for-item="sug"
            wx:key="label"
            class="sug-card sug-{{sug.type}}"
            data-sug="{{sug}}"
            bindtap="onTapSuggestion"
          >
            <text class="sug-icon">{{sug.type === 'addGoal' ? '🎯' : (sug.type === 'adoptPlan' ? '📋' : '💡')}}</text>
            <text class="sug-label">{{sug.label}}</text>
            <text class="sug-arrow">›</text>
          </view>
        </view>
      </block>
    </view>

    <view
      wx:if="{{messages.length > 0 && !sending && messages[messages.length-1].role === 'assistant' && messages[messages.length-1].type !== 'plan' && hasHistory}}"
      class="regen-row"
    >
      <view bindtap="onRegenerate">🔄 重新生成</view>
    </view>
  </scroll-view>

  <!-- 快捷问题 -->
  <view class="quick-chips" wx:if="{{!hasHistory && !sending}}">
    <view wx:for="{{quickQuestions}}" wx:key="*this" class="quick-chip" data-q="{{item}}" bindtap="onTapQuick">{{item}}</view>
  </view>

  <!-- 输入栏（含 🎤 voice）-->
  <view class="input-bar">
    <view class="voice-btn" bindtap="onTapVoice">🎤</view>
    <input class="input" value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="onSend" placeholder="问我训练、恢复、营养…" disabled="{{sending}}" adjust-position="{{true}}" />
    <block wx:if="{{sending}}">
      <view class="stop-btn" bindtap="onStop">停止</view>
    </block>
    <block wx:else>
      <view class="send-btn {{!inputText ? 'disabled' : ''}}" bindtap="onSend">发送</view>
    </block>
  </view>

  <!-- 会话弹层 -->
  <view class="conv-mask" wx:if="{{showConversations}}" bindtap="onCloseConversations">
    <view class="conv-panel" catchtap="">
      <view class="conv-head">
        <text class="conv-title">历史会话</text>
        <view class="conv-close" bindtap="onCloseConversations">✕</view>
      </view>
      <scroll-view class="conv-list" scroll-y>
        <view wx:for="{{conversationList}}" wx:key="conversationId" class="conv-item" data-cid="{{item.conversationId}}" bindtap="onSelectConversation">
          <view class="conv-info">
            <view class="conv-msg">{{item.lastMessage}}</view>
            <view class="conv-meta">{{item.messageCount}} 条 · {{item.lastTime}}</view>
          </view>
          <view class="conv-del" data-cid="{{item.conversationId}}" catchtap="onDeleteConversation">🗑</view>
        </view>
        <view wx:if="{{conversationList.length === 0}}" class="conv-empty">暂无历史会话</view>
      </scroll-view>
    </view>
  </view>
</view>
