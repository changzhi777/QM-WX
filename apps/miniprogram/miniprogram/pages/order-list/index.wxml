<view class="page">
  <error-state wx:if="{{error}}" message="{{errorMsg}}" bind:retry="load" />
  <scroll-view class="status-tabs" scroll-x>
    <view wx:for="{{tabs}}" wx:key="key" class="status-tab {{activeStatus === item.key ? 'active' : ''}}" bindtap="switchTab" data-status="{{item.key}}">{{item.label}}</view>
  </scroll-view>
  <view class="empty" wx:if="{{!loading && !error && list.length === 0}}">暂无订单</view>
  <view
    class="card bg-white m-2 p-4 rounded-lg shadow"
    wx:for="{{list}}"
    wx:key="id"
  >
    <view class="head">
      <view class="order-id">订单号：{{item.id}}</view>
      <view class="status" style="color: {{item.statusColor}}">{{item.statusLabel}}</view>
    </view>
    <view class="items">
      <view class="item" wx:for="{{item.items}}" wx:key="id" wx:for-item="it">
        <text class="name">{{it.name}}</text>
        <text class="qty">× {{it.qty}}</text>
        <text
          class="review-link"
          wx:if="{{item.status === 'done' || item.status === 'paid' || item.status === 'shipped'}}"
          data-product-id="{{it.productId}}"
          data-order-id="{{item.id}}"
          data-product-name="{{it.name}}"
          bindtap="onReview"
        >去评价</text>
      </view>
    </view>
    <view class="footer-row">
      <view class="amount">
        合计 <text class="num">{{item.payAmount}}</text> 元
        <text class="points" wx:if="{{item.pointsUsed > 0}}">（{{item.pointsUsed}} 积分）</text>
      </view>
      <button
        class="btn-cancel"
        wx:if="{{item.status === 'pending_pay' || item.status === 'paid'}}"
        data-id="{{item.id}}"
        bindtap="onCancel"
      >取消订单</button>
    </view>
  </view>
</view>
