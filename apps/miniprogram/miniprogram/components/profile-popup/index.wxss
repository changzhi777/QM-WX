.mask {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex; align-items: center; justify-content: center;
}

.card {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.title { font-size: 36rpx; font-weight: 600; text-align: center; }
.desc { font-size: 24rpx; color: var(--text-secondary); text-align: center; margin-top: 8rpx; }

.avatar-wrap { display: flex; justify-content: center; margin: 40rpx 0 24rpx; }
.avatar-btn {
  display: flex; flex-direction: column; align-items: center;
  background: transparent; border: none; padding: 0; line-height: normal;
}
.avatar-btn::after { border: none; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; background: #f0f0f0; }
.avatar-tip { font-size: 22rpx; color: var(--text-tertiary); margin-top: 8rpx; }

.field { margin: 24rpx 0 40rpx; }
.label { font-size: 26rpx; color: var(--text-secondary); display: block; margin-bottom: 8rpx; }
.input {
  width: 100%; height: 80rpx; padding: 0 20rpx;
  background: #f5f5f5; border-radius: 8rpx; font-size: 28rpx;
  box-sizing: border-box;
}

.actions { display: flex; gap: 16rpx; }
.btn-cancel, .btn-primary {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 8rpx;
  text-align: center; font-size: 28rpx; border: none;
}
.btn-cancel { background: #f0f0f0; color: var(--text-primary); }
.btn-cancel::after { border: none; }
.btn-primary { background: var(--brand); color: #fff; }
.btn-primary::after { border: none; }
.btn-disabled { background: var(--text-tertiary); }
