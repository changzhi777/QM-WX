.mask {
  position: fixed; inset: 0; background: rgba(0, 0, 0, 0.6);
  display: flex; align-items: center; justify-content: center; z-index: 9999;
}
.card {
  width: 640rpx; background: #fff; border-radius: 16rpx;
  padding: 48rpx 40rpx;
}
.title { font-size: 36rpx; font-weight: 600; text-align: center; }
.content { font-size: 28rpx; line-height: 1.6; color: var(--text-primary); margin: 24rpx 0 40rpx; }
.link { color: var(--brand); text-decoration: underline; }
.btn-primary {
  background: var(--brand); color: #fff; height: 88rpx; line-height: 88rpx;
  border-radius: 8rpx; font-size: 30rpx; border: none;
}
.btn-primary::after { border: none; }
