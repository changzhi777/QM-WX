/* 计划卡组件（V0.1.139）*/
.plan-card {
  max-width: 86%;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.plan-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.plan-title { font-size: 30rpx; font-weight: 600; color: #333; }
.plan-level {
  font-size: 22rpx;
  color: #0FAF8E;
  border: 1rpx solid #0FAF8E;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
}
.plan-meta { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.plan-goal {
  font-size: 26rpx;
  color: #333;
  background: #f0faf7;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.day-list { margin-bottom: 16rpx; }
.day-item {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.day-item:last-child { border-bottom: none; }
.day-name {
  width: 80rpx;
  font-size: 24rpx;
  color: #0FAF8E;
  font-weight: 600;
  flex-shrink: 0;
}
.day-content { flex: 1; }
.day-type {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
  margin-right: 10rpx;
  color: #fff;
}
.type-easy { background: #4caf50; }
.type-interval, .type-tempo { background: #ff9800; }
.type-long { background: #2196f3; }
.type-rest { background: #9e9e9e; }
.type-cross { background: #9c27b0; }
.day-text { font-size: 24rpx; color: #555; }
.plan-actions { display: flex; gap: 12rpx; }
.btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  color: #555;
}
.btn.primary {
  background: #0FAF8E;
  color: #fff;
  border-color: #0FAF8E;
}
