<view class="quick-cards">
  <view
    wx:for="{{cards}}"
    wx:key="q"
    class="quick-card card-{{item.color}}"
    data-q="{{item.q}}"
    data-tag="{{item.tag}}"
    bindtap="onTap"
  >
    <view class="card-icon">{{item.icon}}</view>
    <view class="card-q">{{item.q}}</view>
    <view class="card-sub">{{item.sub}}</view>
  </view>
</view>
