.quick-cards {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 16rpx 24rpx;
}

.quick-card {
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  cursor: pointer;
  transition: transform 0.15s ease;
}
.quick-card:active {
  transform: scale(0.96);
}

.card-green {
  background: linear-gradient(160deg, #22ad78, #0c6b45);
  color: #fff;
}
.card-purple {
  background: linear-gradient(135deg, #5d6cd8, #8a5cf0);
  color: #fff;
}
.card-yellow {
  background: linear-gradient(135deg, #fdecc0, #fbd677);
  color: #7a4b06;
}
.card-white {
  background: #f5f6f5;
  color: #1a1a1a;
  border: 1rpx solid #e9e9e9;
}
.card-orange {
  background: linear-gradient(135deg, #ffb888, #e8830c);
  color: #fff;
}

.card-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.card-tag {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.card-q {
  font-size: 18rpx;
  opacity: 0.88;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
