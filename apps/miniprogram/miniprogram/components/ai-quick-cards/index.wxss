.quick-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.quick-card {
  border-radius: 20rpx;
  padding: 28rpx 22rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  cursor: pointer;
  transition: transform 0.15s ease;
  min-height: 168rpx;
}
.quick-card:active {
  transform: scale(0.96);
}

.card-green {
  background: linear-gradient(160deg, #22ad78, #0c6b45);
  color: #fff;
}
.card-purple {
  background: linear-gradient(135deg, #5d6cd8, #8a5cf0);
  color: #fff;
}
.card-yellow {
  background: linear-gradient(135deg, #fdecc0, #fbd677);
  color: #7a4b06;
}
.card-orange {
  background: linear-gradient(135deg, #ffb888, #e8830c);
  color: #fff;
}

.card-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}

.card-q {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
  margin-bottom: 6rpx;
}

.card-sub {
  font-size: 22rpx;
  opacity: 0.85;
  line-height: 1.3;
}
