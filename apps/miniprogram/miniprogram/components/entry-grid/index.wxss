/* components/entry-grid/index.wxss — 通用入口网格（V0.1.35）*/
/* flexbox 4 列（兼容小程序，不用 CSS Grid）*/

/* 卡片容器 + 段标题（每个 entry-grid 自带卡片样式）*/
.entry-grid-wrap {
  background: #fff;
  border-radius: 16rpx;
  margin: 16rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.entry-grid-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 24rpx 0;
}

.entry-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 8rpx;
}
.entry-item {
  width: 25%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  position: relative;
}
.entry-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0faf8 0%, #e0f5f0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.entry-label {
  font-size: 24rpx;
  color: #333;
  margin-top: 12rpx;
}
.entry-badge {
  position: absolute;
  top: 8rpx;
  right: 24rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 14rpx;
  padding: 0 6rpx;
  text-align: center;
}
