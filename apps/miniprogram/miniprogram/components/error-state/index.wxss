.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.error-state .icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.error-state .message {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 32rpx;
  max-width: 480rpx;
  word-break: break-word;
}

.error-state .retry-btn {
  font-size: 28rpx;
  color: #fff;
  background-color: var(--brand, #0FAF8E);
  border-radius: 999rpx;
  padding: 12rpx 60rpx;
  line-height: 1.5;
  min-height: 0;
}
