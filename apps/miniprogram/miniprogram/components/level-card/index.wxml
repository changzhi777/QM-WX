<!-- V0.2.32 升级：融合 user-card（头像+名字+会员皇冠），作 mine 顶部主卡 -->
<view class="level-card">
  <view class="row">
    <view class="avatar">{{avatar}}</view>
    <view class="level-meta">
      <view class="name-row">
        <text class="name">{{nickname}}</text>
        <text class="vip-tag" wx:if="{{memberLevel && memberLevel !== 'free'}}">👑</text>
      </view>
      <view class="level-line">{{icon}} {{label}} · 累计积分 <text class="num">{{totalPointsEarned}}</text></view>
    </view>
    <view class="level-tier">{{growthLevel === 'diamond' ? 'MAX' : (nextLevelLabel || '—')}}</view>
  </view>
  <view class="progress" wx:if="{{nextLevel}}">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <view class="progress-text" wx:if="{{nextLevel}}">
    距离 <text class="next">{{nextLevelLabel}}</text> 还差 <text class="num">{{pointsToNext}}</text> 积分
  </view>
  <view class="max-tip" wx:else>已达成最高等级，继续保持 ✨</view>
</view>
